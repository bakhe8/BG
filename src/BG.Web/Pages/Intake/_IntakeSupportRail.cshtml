@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Intake.WorkspaceModel
@{
    var actorContextMode = Model.Workspace.ActiveActor is null
        ? ActorContextPanelMode.EmptyState
        : Model.IsActorContextLocked
            ? ActorContextPanelMode.LockedPills
            : ActorContextPanelMode.SelectorField;
    var actorContextModel = new ActorContextPanelModel(
        T["IntakeWorkspace_ActorContextTitle"].Value,
        null,
        actorContextMode,
        "bg-card")
    {
        EmptyMessage = T["IntakeWorkspace_NoEligibleActorBody"].Value,
        Pills = Model.IsActorContextLocked && Model.Workspace.ActiveActor is not null
            ? new[]
            {
                T["WorkspaceShell_CurrentUserScopeNotice"].Value,
                $"{Model.Workspace.ActiveActor.DisplayName} ({Model.Workspace.ActiveActor.Username})"
            }
            : Array.Empty<string>(),
        ExternalFormId = "intake-workspace-form",
        ActorFieldLabel = T["IntakeWorkspace_ActorField"].Value,
        ActorFieldName = "Input.IntakeActorUserId",
        ActorFieldId = "Input_IntakeActorUserId",
        Options = Model.Workspace.AvailableActors
            .Select(actor => new ActorContextOptionModel(
                actor.Id.ToString(),
                $"{actor.DisplayName} ({actor.Username})",
                actor.Id == Model.Input.IntakeActorUserId))
            .ToArray()
    };
}

<article class="bg-card">
    <label class="section-caption">@T["IntakeWorkspace_SelectedScenarioLabel"]</label>

    <div class="d-flex flex-wrap gap-2 mb-4">
        <bg-badge variant="info">@T[Model.SelectedScenario.TitleResourceKey]</bg-badge>
        <bg-badge variant="success">@T[Model.SelectedDocumentForm.BankResourceKey]</bg-badge>
    </div>

    <nav class="d-flex flex-column gap-2" aria-label="@T["IntakeWorkspace_SelectedScenarioLabel"]">
        @foreach (var scenario in Model.Workspace.Scenarios)
        {
            var isActive = scenario.Key == Model.SelectedScenario.Key;
            <a class="btn btn-sm text-start p-2 rounded-3 @(isActive ? "bg-brand-gold-soft border-gold fw-bold text-dark" : "btn-light text-muted border-transparent")"
               asp-page="/Intake/Workspace"
               asp-route-actor="@(Model.IsActorContextLocked ? null : Model.Workspace.ActiveActor?.Id)"
               asp-route-scenario="@scenario.Key"
               style="@(isActive ? "border: 1px solid var(--bg-brand-gold) !important;" : "")">
                <i class="bi @(isActive ? "bi-check-circle-fill text-brand-green" : "bi-circle text-muted") me-2"></i>
                @T[scenario.TitleResourceKey]
            </a>
        }
    </nav>
</article>

<partial name="/Pages/Shared/_ActorContextPanel.cshtml" model="actorContextModel" />

<article class="bg-card">
    <label class="section-caption">@T["IntakeWorkspace_RequiredFieldsTitle"]</label>

    <div class="d-flex flex-wrap gap-2">
        @foreach (var fieldKey in Model.SelectedScenario.RequiredReviewFieldKeys)
        {
            <bg-badge variant="info">@T[fieldKey]</bg-badge>
        }
    </div>
</article>
