@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Intake.WorkspaceModel
@{
    ViewData["Title"] = T["IntakeWorkspace_PageTitle"];
}

<section class="section-shell">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice-banner is-success">@Model.StatusMessage</div>
    }

    @if (Model.Workspace.HasEligibleActor && !string.IsNullOrWhiteSpace(Model.Workspace.ContextNoticeResourceKey))
    {
        <div class="notice-banner is-success">@T[Model.Workspace.ContextNoticeResourceKey]</div>
    }

    @if (!Model.Workspace.HasEligibleActor)
    {
        <div class="notice-banner">@T["IntakeWorkspace_NoEligibleActorBody"]</div>
    }

    <div class="section-header">
        <span class="eyebrow">@T["NavIntake"]</span>
        <h1>@T["IntakeWorkspace_Heading"]</h1>
        <p class="compact-copy">@T["IntakeWorkspace_Summary"]</p>
    </div>

    <section class="hero-panel intake-hero">
        <div class="hero-copy">
            <span class="eyebrow">@T["IntakeWorkspace_PrimaryFlow"]</span>
            <h2>@T["IntakeWorkspace_SelectedScenarioLabel"]: @T[Model.SelectedScenario.TitleResourceKey]</h2>
            <p>@T[Model.SelectedScenario.SummaryResourceKey]</p>
        </div>
        <div class="hero-metrics">
            <div class="metric-card">
                <span>@T["IntakeWorkspace_MetricRole"]</span>
                <strong>@T[Model.Workspace.PrimaryRoleResourceKey]</strong>
            </div>
            <div class="metric-card">
                <span>@T["IntakeWorkspace_MetricSave"]</span>
                <strong>@T[Model.Workspace.SaveModeResourceKey]</strong>
            </div>
            <div class="metric-card">
                <span>@T["IntakeWorkspace_MetricReview"]</span>
                <strong>@T[Model.Workspace.ReviewGateResourceKey]</strong>
            </div>
        </div>
    </section>

    <section class="scenario-strip">
        @foreach (var scenario in Model.Workspace.Scenarios)
        {
            var isActive = scenario.Key == Model.SelectedScenario.Key;
            <a class="scenario-card @(isActive ? "active" : null)"
               asp-page="/Intake/Workspace"
               asp-route-actor="@(Model.IsActorContextLocked ? null : Model.Workspace.ActiveActor?.Id)"
               asp-route-scenario="@scenario.Key">
                <span class="scenario-title">@T[scenario.TitleResourceKey]</span>
                <span class="selection-copy">@T[scenario.SummaryResourceKey]</span>
            </a>
        }
    </section>

    <article class="info-card full-span">
        <div class="card-header">
            <div>
                <h2>@T["IntakeWorkspace_ActorContextTitle"]</h2>
                <p class="compact-copy">@T["IntakeWorkspace_ActorContextSummary"]</p>
            </div>
        </div>

        @if (!Model.Workspace.HasEligibleActor || Model.Workspace.ActiveActor is null)
        {
            <p class="compact-copy">@T["IntakeWorkspace_NoEligibleActorBody"]</p>
        }
        else if (Model.IsActorContextLocked)
        {
            <div class="pill-list">
                <span class="pill">@T["WorkspaceShell_CurrentUserScopeNotice"]</span>
                <span class="pill">@Model.Workspace.ActiveActor.DisplayName (@Model.Workspace.ActiveActor.Username)</span>
            </div>
        }
        else
        {
            <form method="get" class="action-row">
                <input type="hidden" name="scenario" value="@Model.SelectedScenario.Key" />
                <div>
                    <label class="form-label" for="actor">@T["IntakeWorkspace_ActorField"]</label>
                    <select id="actor" name="actor" class="form-control">
                        @foreach (var actor in Model.Workspace.AvailableActors)
                        {
                            <option value="@actor.Id" selected="@(actor.Id == Model.Workspace.ActiveActor.Id ? "selected" : null)">
                                @actor.DisplayName (@actor.Username)
                            </option>
                        }
                    </select>
                </div>
                <button type="submit" class="btn btn-outline-primary action-button">@T["IntakeWorkspace_LoadActorAction"]</button>
            </form>
        }
    </article>

    <article class="info-card full-span">
        <div class="card-header">
            <div>
                <h2>@T["IntakeWorkspace_SubmissionTitle"]</h2>
                <p class="compact-copy">@T["IntakeWorkspace_SubmissionSummary"]</p>
            </div>
            <div class="draft-status">
                <span class="section-caption">@T["IntakeWorkspace_DraftStatusTitle"]</span>
                <strong>@T[Model.HasDraft ? "IntakeWorkspace_DraftReady" : "IntakeWorkspace_DraftPending"]</strong>
            </div>
        </div>

        <form method="post" enctype="multipart/form-data" class="stack-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <input asp-for="Input.IntakeActorUserId" type="hidden" />
            <input asp-for="Input.ScenarioKey" type="hidden" />
            <input asp-for="Input.StagedDocumentToken" type="hidden" />
            <input asp-for="Input.ExtractionRouteResourceKey" type="hidden" />
            <input asp-for="Input.PageCount" type="hidden" />
            <input asp-for="Input.OriginalFileName" type="hidden" />

            <div class="intake-form-grid">
                <section class="intake-pane">
                    <h3>@T["IntakeWorkspace_SourceDocumentTitle"]</h3>
                    <label class="form-label" asp-for="Input.UploadedDocument">@T["IntakeWorkspace_FileField"]</label>
                    <input asp-for="Input.UploadedDocument" class="form-control" type="file" accept=".pdf,.png,.jpg,.jpeg,.tif,.tiff" />
                    <p class="compact-copy">@T["IntakeWorkspace_FileHint"]</p>

                    @if (Model.HasDraft)
                    {
                        <div class="data-pairs draft-pairs">
                            <div>
                                <dt>@T["IntakeWorkspace_FileNameLabel"]</dt>
                                <dd>@Model.Input.OriginalFileName</dd>
                            </div>
                            <div>
                                <dt>@T["IntakeWorkspace_PageCountLabel"]</dt>
                                <dd>@Model.Input.PageCount</dd>
                            </div>
                            <div>
                                <dt>@T["IntakeWorkspace_ExtractionRouteLabel"]</dt>
                                <dd>@T[Model.Input.ExtractionRouteResourceKey ?? "IntakeExtractionRoute_PdfTextFirst"]</dd>
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="compact-copy">@T["IntakeWorkspace_NoDraftBody"]</p>
                    }

                    <div class="pill-section">
                        <span class="section-caption">@T["IntakeWorkspace_CaptureProvenanceTitle"]</span>
                        <p class="compact-copy">@T["IntakeWorkspace_CaptureProvenanceSummary"]</p>

                        <label class="form-label" asp-for="Input.CaptureChannel">@T["IntakeWorkspace_CaptureChannelField"]</label>
                        <select asp-for="Input.CaptureChannel" class="form-control">
                            @foreach (var option in Model.CaptureChannelOptions)
                            {
                                <option value="@option.Value">@T[option.ResourceKey]</option>
                            }
                        </select>

                        <label class="form-label" asp-for="Input.SourceSystemName">@T["IntakeWorkspace_SourceSystemNameField"]</label>
                        <input asp-for="Input.SourceSystemName" class="form-control" maxlength="128" />

                        <label class="form-label" asp-for="Input.SourceReference">@T["IntakeWorkspace_SourceReferenceField"]</label>
                        <input asp-for="Input.SourceReference" class="form-control" maxlength="128" />

                        <p class="compact-copy">@T[Model.CaptureChannelHintResourceKey]</p>
                    </div>

                    <div class="action-row">
                        <button type="submit" asp-page-handler="Extract" class="btn btn-outline-primary action-button">
                            @T["IntakeWorkspace_ExtractAction"]
                        </button>
                        <button type="submit"
                                asp-page-handler="Save"
                                class="btn btn-primary action-button"
                                disabled="@((Model.HasDraft && Model.Workspace.HasEligibleActor) ? null : "disabled")">
                            @T["IntakeWorkspace_SaveAction"]
                        </button>
                    </div>
                </section>

                <section class="intake-pane">
                    <h3>@T["IntakeWorkspace_VerifiedFieldsTitle"]</h3>

                    <label class="form-label" asp-for="Input.GuaranteeNumber">@T["IntakeField_GuaranteeNumber"]</label>
                    <input asp-for="Input.GuaranteeNumber" class="form-control" maxlength="64" />

                    @if (Model.IsNewGuaranteeScenario)
                    {
                        <label class="form-label" asp-for="Input.BankName">@T["IntakeField_BankName"]</label>
                        <input asp-for="Input.BankName" class="form-control" maxlength="128" />

                        <label class="form-label" asp-for="Input.BeneficiaryName">@T["IntakeField_Beneficiary"]</label>
                        <input asp-for="Input.BeneficiaryName" class="form-control" maxlength="256" />

                        <label class="form-label" asp-for="Input.PrincipalName">@T["IntakeField_Principal"]</label>
                        <input asp-for="Input.PrincipalName" class="form-control" maxlength="256" />

                        <label class="form-label" asp-for="Input.GuaranteeCategory">@T["IntakeField_GuaranteeCategory"]</label>
                        <select asp-for="Input.GuaranteeCategory" class="form-control">
                            <option value="">@T["IntakeWorkspace_SelectGuaranteeCategory"]</option>
                            @foreach (var option in Model.GuaranteeCategoryOptions)
                            {
                                <option value="@option.Value">@T[option.ResourceKey]</option>
                            }
                        </select>

                        <div class="inline-form-grid">
                            <div>
                                <label class="form-label" asp-for="Input.Amount">@T["IntakeField_Amount"]</label>
                                <input asp-for="Input.Amount" class="form-control" inputmode="decimal" />
                            </div>
                            <div>
                                <label class="form-label" asp-for="Input.CurrencyCode">@T["IntakeField_CurrencyCode"]</label>
                                <input asp-for="Input.CurrencyCode" class="form-control" maxlength="3" />
                            </div>
                        </div>

                        <div class="inline-form-grid">
                            <div>
                                <label class="form-label" asp-for="Input.IssueDate">@T["IntakeField_IssueDate"]</label>
                                <input asp-for="Input.IssueDate" class="form-control" type="date" />
                            </div>
                            <div>
                                <label class="form-label" asp-for="Input.ExpiryDate">@T["IntakeField_ExpiryDate"]</label>
                                <input asp-for="Input.ExpiryDate" class="form-control" type="date" />
                            </div>
                        </div>
                    }
                    else
                    {
                        @if (!Model.IsAttachmentScenario)
                        {
                            <div class="inline-form-grid">
                                <div>
                                    <label class="form-label" asp-for="Input.OfficialLetterDate">@T["IntakeField_OfficialLetterDate"]</label>
                                    <input asp-for="Input.OfficialLetterDate" class="form-control" type="date" />
                                </div>
                                <div>
                                    <label class="form-label" asp-for="Input.BankReference">@T["IntakeField_BankReference"]</label>
                                    <input asp-for="Input.BankReference" class="form-control" maxlength="64" />
                                </div>
                            </div>
                        }

                        @if (Model.IsExtensionScenario)
                        {
                            <label class="form-label" asp-for="Input.NewExpiryDate">@T["IntakeField_NewExpiryDate"]</label>
                            <input asp-for="Input.NewExpiryDate" class="form-control" type="date" />
                        }

                        @if (Model.IsReductionScenario)
                        {
                            <label class="form-label" asp-for="Input.Amount">@T["IntakeField_Amount"]</label>
                            <input asp-for="Input.Amount" class="form-control" inputmode="decimal" />
                        }

                        @if (Model.IsStatusScenario)
                        {
                            <label class="form-label" asp-for="Input.StatusStatement">@T["IntakeField_StatusStatement"]</label>
                            <textarea asp-for="Input.StatusStatement" class="form-control" rows="4"></textarea>
                        }

                        @if (Model.IsAttachmentScenario)
                        {
                            <label class="form-label" asp-for="Input.AttachmentNote">@T["IntakeField_AttachmentNote"]</label>
                            <textarea asp-for="Input.AttachmentNote" class="form-control" rows="4"></textarea>
                        }
                    }
                </section>

                <section class="intake-pane review-pane">
                    <h3>@T["IntakeWorkspace_ReviewCardTitle"]</h3>
                    <p class="compact-copy">@T[Model.HasDraft ? "IntakeWorkspace_ReviewCardBody" : "IntakeWorkspace_ReviewCardPendingBody"]</p>

                    <div class="review-table">
                        @foreach (var field in Model.ReviewFields)
                        {
                            var confidenceClass = field.ConfidencePercent >= 95
                                ? "is-high"
                                : field.ConfidencePercent >= 90
                                    ? "is-medium"
                                    : "is-low";

                            <div class="review-row">
                                <div>
                                    <strong>@T[field.LabelResourceKey]</strong>
                                    <div class="selection-copy">@field.Value</div>
                                </div>
                                <div class="review-meta">
                                    <span class="confidence-chip @confidenceClass">@field.ConfidencePercent%</span>
                                    @if (!string.IsNullOrWhiteSpace(field.ProvenanceResourceKey))
                                    {
                                        <span class="pill">@T[field.ProvenanceResourceKey]</span>
                                    }
                                    @if (field.RequiresExplicitReview)
                                    {
                                        <span class="review-flag">@T["IntakeWorkspace_ReviewRequired"]</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div class="intake-outcome">
                        <div>
                            <span class="section-caption">@T["IntakeWorkspace_SaveOutcomeTitle"]</span>
                            <p class="compact-copy">@T[Model.SelectedScenario.SaveOutcomeResourceKey]</p>
                        </div>
                        <div>
                            <span class="section-caption">@T["IntakeWorkspace_HandoffTitle"]</span>
                            <p class="compact-copy">@T[Model.SelectedScenario.HandoffResourceKey]</p>
                        </div>
                    </div>
                </section>
            </div>
        </form>
    </article>

    <div class="intake-grid">
        <article class="info-card">
            <h2>@T["IntakeWorkspace_OperatorScopeTitle"]</h2>
            <div class="scope-grid">
                <section>
                    <span class="section-caption">@T["IntakeWorkspace_AllowedTitle"]</span>
                    <ul class="plain-list">
                        @foreach (var actionKey in Model.Workspace.AllowedActionKeys)
                        {
                            <li>@T[actionKey]</li>
                        }
                    </ul>
                </section>
                <section>
                    <span class="section-caption">@T["IntakeWorkspace_ExcludedTitle"]</span>
                    <ul class="plain-list">
                        @foreach (var actionKey in Model.Workspace.ExcludedActionKeys)
                        {
                            <li>@T[actionKey]</li>
                        }
                    </ul>
                </section>
            </div>
        </article>

        <article class="info-card">
            <h2>@T["IntakeWorkspace_RequiredFieldsTitle"]</h2>
            <div class="pill-list">
                @foreach (var fieldKey in Model.SelectedScenario.RequiredReviewFieldKeys)
                {
                    <span class="pill">@T[fieldKey]</span>
                }
            </div>
        </article>

        <article class="info-card">
            <h2>@T["IntakeWorkspace_FutureScannerTitle"]</h2>
            <ul class="plain-list">
                @foreach (var itemKey in Model.Workspace.FutureIntegrationKeys)
                {
                    <li>@T[itemKey]</li>
                }
            </ul>
        </article>

        <article class="info-card full-span">
            <h2>@T["IntakeWorkspace_PipelineTitle"]</h2>
            <div class="pipeline-grid">
                @for (var index = 0; index < Model.Workspace.PipelineStepKeys.Count; index++)
                {
                    <section class="pipeline-step">
                        <span class="pipeline-index">@(index + 1)</span>
                        <p>@T[Model.Workspace.PipelineStepKeys[index]]</p>
                    </section>
                }
            </div>
        </article>

        <article class="info-card full-span">
            <h2>@T["IntakeWorkspace_QualityTitle"]</h2>
            <div class="quality-grid">
                @foreach (var qualityKey in Model.Workspace.QualityGateKeys)
                {
                    <section class="quality-item">
                        <span class="quality-dot"></span>
                        <p>@T[qualityKey]</p>
                    </section>
                }
            </div>
        </article>
    </div>
</section>
