@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Intake.WorkspaceModel
@{
    var previewUrl = Model.HasDraft && !string.IsNullOrWhiteSpace(Model.Input.StagedDocumentToken)
        ? Url.Page("/Intake/Workspace", pageHandler: "Preview", values: new { token = Model.Input.StagedDocumentToken })
        : null;
    var previewExtension = System.IO.Path.GetExtension(Model.Input.OriginalFileName ?? string.Empty).ToLowerInvariant();
    var canPreviewPdf = previewExtension == ".pdf";
    var canPreviewImage =
        previewExtension == ".png" ||
        previewExtension == ".jpg" ||
        previewExtension == ".jpeg";
}

<!-- ANTIGRAVITY_SYNC_CHECK_123 -->
<bg-section title="@T[Model.SelectedScenario.TitleResourceKey]" icon="bi bi-file-earmark-text">
    
    <div class="mb-4">
        <p class="text-secondary mb-3">@T[Model.SelectedScenario.SummaryResourceKey]</p>
        <bg-badge class="bg-badge-@(Model.HasDraft ? "success" : "warning")">
            <i class="bi @(Model.HasDraft ? "bi-check-circle" : "bi-clock-history") me-2"></i>
            @T[Model.HasDraft ? "IntakeWorkspace_DraftReady" : "IntakeWorkspace_DraftPending"]
        </bg-badge>
    </div>

    @* Scenario Overview Card *@
    <div class="bg-card">
        <label class="section-caption">@T["IntakeWorkspace_Summary"]</label>
        <div class="row g-4">
            <div class="col-6">
                <span class="d-block x-small text-muted text-uppercase mb-1">@T["IntakeWorkspace_DetectedFormTitle"]</span>
                <strong class="text-dark d-block">@T[Model.SelectedDocumentForm.TitleResourceKey]</strong>
            </div>
            <div class="col-6 border-start ps-4">
                <span class="d-block x-small text-muted text-uppercase mb-1">@T["IntakeWorkspace_HandoffTitle"]</span>
                <strong class="text-dark d-block">@T[Model.SelectedScenario.SaveOutcomeResourceKey]</strong>
            </div>
        </div>
    </div>

    @* Capture Zone Card - Collapsible for active drafts (C-SURF-06) *@
    @if (Model.HasDraft)
    {
        <details class="bg-card mb-4 border-0 shadow-none overflow-hidden">
            <summary class="section-caption text-primary d-flex align-items-center cursor-pointer mb-0">
                <i class="bi bi-cloud-arrow-up me-2"></i>
                <span class="text-uppercase small fw-bold">@T["IntakeWorkspace_CaptureZoneTitle"] — @T["IntakeWorkspace_UpdateDocumentAction"]</span>
            </summary>
            <div class="mt-3 text-center p-4 border border-dashed rounded-4 bg-light">
                <input asp-for="Input.UploadedDocument" class="form-control mb-3 bg-white" type="file" accept=".pdf,.png,.jpg,.jpeg,.tif,.tiff" />
                <button type="submit" formaction="@Url.Page("/Intake/Workspace", pageHandler: "Extract")" class="bg-btn bg-btn-secondary">
                    <i class="bi bi-stars me-2"></i>@T["IntakeWorkspace_BeginExtractAction"]
                </button>
            </div>
        </details>
    }
    else
    {
        <div class="bg-card">
            <label class="section-caption">@T["IntakeWorkspace_CaptureZoneTitle"]</label>
            <div class="mb-4 text-center p-5 border border-dashed rounded-4 bg-light">
                <i class="bi bi-cloud-arrow-up-fill fs-1 text-muted d-block mb-3 opacity-25"></i>
                <label class="form-label fw-bold d-block mb-3" asp-for="Input.UploadedDocument">@T["IntakeWorkspace_FileField"]</label>
                <input asp-for="Input.UploadedDocument" class="form-control mb-3 bg-white" type="file" accept=".pdf,.png,.jpg,.jpeg,.tif,.tiff" />
                <button type="submit" formaction="@Url.Page("/Intake/Workspace", pageHandler: "Extract")" class="bg-btn bg-btn-primary w-100">
                    <i class="bi bi-stars me-2"></i>@T["IntakeWorkspace_BeginExtractAction"]
                </button>
            </div>
        </div>
    }

    @if (Model.HasDraft)
    {
        <div class="bg-card intake-document-preview-card">
            <div class="intake-document-preview-header d-flex justify-content-between align-items-center mb-3">
                <label class="section-caption mb-0">@T["IntakeWorkspace_DocumentPreviewTitle"]</label>
                
                <div class="d-flex gap-2">
                    @* Integrated Preview Controls (C-SURF-02) *@
                    @if (canPreviewImage)
                    {
                        <div class="btn-group btn-group-sm me-2">
                            <button type="button" class="btn btn-outline-secondary" onclick="document.querySelector('.intake-document-preview-image').classList.toggle('rotate-90')">
                                <i class="bi bi-arrow-clockwise"></i>
                            </button>
                            <button type="button" class="btn btn-outline-secondary" onclick="document.querySelector('.intake-document-preview-image').classList.toggle('zoom-in')">
                                <i class="bi bi-zoom-in"></i>
                            </button>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(previewUrl))
                    {
                        <a class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm"
                           href="@previewUrl"
                           target="_blank"
                           rel="noopener">
                            <i class="bi bi-box-arrow-up-right me-2"></i>@T["IntakeWorkspace_OpenDocumentAction"]
                        </a>
                    }
                </div>
            </div>

            <div class="preview-viewport-container bg-light rounded-4 overflow-hidden border shadow-inner">
                @if (canPreviewPdf && !string.IsNullOrWhiteSpace(previewUrl))
                {
                    <iframe class="intake-document-preview-frame w-100"
                            src="@(previewUrl + "#toolbar=0&navpanes=0")"
                            title="@T["IntakeWorkspace_DocumentPreviewFrameTitle"]"
                            style="min-height: 800px; border: none;">
                    </iframe>
                }
                else if (canPreviewImage && !string.IsNullOrWhiteSpace(previewUrl))
                {
                    <div class="image-preview-wrapper p-4 d-flex justify-content-center align-items-center bg-white" style="min-height: 500px;">
                        <img class="intake-document-preview-image img-fluid rounded"
                             src="@previewUrl"
                             alt="@T["IntakeWorkspace_DocumentPreviewFrameTitle"]"
                             style="transition: transform 0.3s ease; max-height: 80vh; transform-origin: center;" />
                    </div>
                }
                else
                {
                    <div class="alert alert-light border-0 shadow-none rounded-0 p-5 mb-0 text-center">
                        <i class="bi bi-exclamation-circle fs-3 text-muted d-block mb-2"></i>
                        @T["IntakeWorkspace_DocumentPreviewUnavailable"]
                    </div>
                }
            </div>
        </div>

        @* Source Document Trace Card *@
        <div class="bg-card">
            <label class="section-caption">@T["IntakeWorkspace_SourceDocumentTitle"]</label>
            <div class="row g-3">
                <div class="col-12">
                    <div class="p-3 bg-white border rounded-3">
                        <span class="d-block x-small text-muted text-uppercase mb-1">@T["IntakeWorkspace_FileNameLabel"]</span>
                        <span class="fw-bold text-truncate d-block">@Model.Input.OriginalFileName</span>
                    </div>
                </div>
                <div class="col-6">
                    <div class="p-3 bg-white border rounded-3">
                        <span class="d-block x-small text-muted text-uppercase mb-1">@T["IntakeWorkspace_CaptureChannelLabel"]</span>
                        <span class="fw-bold d-block">@T[Model.CaptureChannelHintResourceKey]</span>
                    </div>
                </div>
                <div class="col-6">
                    <div class="p-3 bg-white border rounded-3">
                        <span class="d-block x-small text-muted text-uppercase mb-1">@T["IntakeWorkspace_CapturedAtLabel"]</span>
                        <span class="fw-bold d-block">@DateTime.Now.ToString("g")</span>
                    </div>
                </div>
            </div>
        </div>
    }

</bg-section>
