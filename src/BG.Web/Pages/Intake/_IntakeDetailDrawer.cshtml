@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Intake.WorkspaceModel

<details class="bg-card p-0 overflow-hidden mb-3" open>
    <summary class="p-3 bg-brand-gold-soft border-bottom cursor-pointer d-flex justify-content-between align-items-center">
        <span class="fw-bold text-dark"><i class="bi bi-file-earmark-medical me-2 text-brand-green"></i>@T["IntakeWorkspace_DocumentFormTitle"]</span>
        <bg-badge variant="info">@T[Model.SelectedDocumentForm.BankResourceKey]</bg-badge>
    </summary>
    <div class="p-4">
        <div class="mb-4">
            <label class="form-label fw-bold small" asp-for="Input.DocumentFormKey">@T["IntakeWorkspace_DocumentFormField"]</label>
            <select asp-for="Input.DocumentFormKey" class="form-control" form="intake-workspace-form">
                @foreach (var form in Model.SelectedScenario.SupportedDocumentForms)
                {
                    <option value="@form.Key">@T[form.TitleResourceKey]</option>
                }
            </select>
            <p class="x-small text-muted mt-2">@T["IntakeWorkspace_DocumentFormSummary"]</p>
        </div>

        <div class="bg-white border rounded-4 p-3 mb-3">
            <label class="section-caption">@T["IntakeWorkspace_DetectedFormTitle"]</label>
            <h5 class="fw-bold mb-1">@T[Model.SelectedDocumentForm.TitleResourceKey]</h5>
            <p class="small text-secondary mb-3">@T[Model.SelectedDocumentForm.SummaryResourceKey]</p>

            <label class="section-caption x-small mb-2">@T["IntakeWorkspace_FormExpectedCuesTitle"]</label>
            <div class="d-flex flex-wrap gap-1 mb-3">
                @foreach (var cueKey in Model.SelectedDocumentForm.ExpectedCueResourceKeys)
                {
                    <bg-badge variant="info" class="x-small">@T[cueKey]</bg-badge>
                }
            </div>

            <label class="section-caption x-small mb-2">@T["IntakeWorkspace_FormExpectedFieldsTitle"]</label>
            <div class="d-flex flex-wrap gap-1">
                @foreach (var fieldKey in Model.SelectedDocumentForm.ExpectedFieldKeys)
                {
                    <bg-badge variant="success" class="x-small">@T[fieldKey]</bg-badge>
                }
            </div>
        </div>
    </div>
</details>

<details class="bg-card p-0 overflow-hidden mb-3">
    <summary class="p-3 bg-brand-gold-soft border-bottom cursor-pointer d-flex justify-content-between align-items-center">
        <span class="fw-bold text-dark"><i class="bi bi-fingerprint me-2 text-brand-green"></i>@T["IntakeWorkspace_CaptureProvenanceTitle"]</span>
        <i class="bi bi-chevron-down small text-muted"></i>
    </summary>
    <div class="p-4">
        <div class="mb-3">
            <label class="form-label fw-bold small" asp-for="Input.CaptureChannel">@T["IntakeWorkspace_CaptureChannelField"]</label>
            <select asp-for="Input.CaptureChannel" class="form-control" form="intake-workspace-form">
                @foreach (var option in Model.CaptureChannelOptions)
                {
                    <option value="@option.Value">@T[option.ResourceKey]</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold small" asp-for="Input.SourceSystemName">@T["IntakeWorkspace_SourceSystemNameField"]</label>
            <input asp-for="Input.SourceSystemName" class="form-control" maxlength="128" form="intake-workspace-form" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold small" asp-for="Input.SourceReference">@T["IntakeWorkspace_SourceReferenceField"]</label>
            <input asp-for="Input.SourceReference" class="form-control" maxlength="128" form="intake-workspace-form" />
        </div>

        <div class="alert alert-light border-0 bg-opacity-10 bg-dark small mt-2">
            <i class="bi bi-info-circle me-2"></i>@T[Model.CaptureChannelHintResourceKey]
        </div>
    </div>
</details>

<details class="bg-card p-0 overflow-hidden mb-3">
    <summary class="p-3 bg-brand-gold-soft border-bottom cursor-pointer d-flex justify-content-between align-items-center">
        <span class="fw-bold text-dark"><i class="bi bi-list-check me-2 text-brand-green"></i>@T["IntakeWorkspace_SupportingReviewTitle"]</span>
        <bg-badge variant="info">@Model.SupportingReviewFieldCount</bg-badge>
    </summary>
    <div class="p-4">
        @if (Model.SupportingReviewFieldCount == 0)
        {
            <div class="text-center py-4 text-muted small">
                <i class="bi bi-clipboard-x fs-2 d-block mb-2 opacity-50"></i>
                @T["IntakeWorkspace_ReviewCardPendingBody"]
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var field in Model.SupportingReviewFields)
                {
                    var confidenceVariant = field.ConfidencePercent >= 95 ? "success" : field.ConfidencePercent >= 90 ? "warning" : "error";

                    <div class="p-3 bg-white border rounded-4 d-flex justify-content-between align-items-center">
                        <div class="flex-grow-1 me-3">
                            <span class="d-block x-small text-muted text-uppercase fw-bold">@T[field.LabelResourceKey]</span>
                            <span class="fw-bold d-block my-1">@field.Value</span>
                            <div class="d-flex align-items-center gap-2 x-small text-muted">
                                <i class="bi @(field.IsExpectedByDocumentForm ? "bi-check-circle" : "bi-plus-circle")"></i>
                                <span>@T[field.IsExpectedByDocumentForm ? "IntakeWorkspace_FormExpectedField" : "IntakeWorkspace_FormSupplementalField"]</span>
                                @if (!string.IsNullOrWhiteSpace(field.ProvenanceResourceKey))
                                {
                                    <span class="mx-1">•</span>
                                    <span>@T[field.ProvenanceResourceKey]</span>
                                }
                            </div>
                        </div>
                        <bg-badge variant="@confidenceVariant">@field.ConfidencePercent%</bg-badge>
                    </div>
                }
            </div>
        }
    </div>
</details>

<details class="bg-card p-0 overflow-hidden">
    <summary class="p-3 bg-brand-gold-soft border-bottom cursor-pointer d-flex justify-content-between align-items-center">
        <span class="fw-bold text-dark"><i class="bi bi-diagram-3 me-2 text-brand-green"></i>@T["IntakeWorkspace_ProcessingContextTitle"]</span>
        <i class="bi bi-chevron-down small text-muted"></i>
    </summary>
    <div class="p-4">
        <div class="d-flex flex-column gap-3">
            <div class="bg-white border rounded-4 p-3">
                <label class="section-caption x-small mb-2">@T["IntakeWorkspace_SaveOutcomeTitle"]</label>
                <h6 class="fw-bold mb-1">@T["IntakeWorkspace_HandoffTitle"]</h6>
                <p class="small text-secondary mb-1">@T[Model.SelectedScenario.SaveOutcomeResourceKey]</p>
                <p class="small text-muted mb-0 italic">@T[Model.SelectedScenario.HandoffResourceKey]</p>
            </div>

            <div class="bg-white border rounded-4 p-3">
                <label class="section-caption x-small mb-2">@T["IntakeWorkspace_OperatorScopeTitle"]</label>
                <h6 class="fw-bold mb-2">@T["IntakeWorkspace_AllowedTitle"]</h6>
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var actionKey in Model.Workspace.AllowedActionKeys)
                    {
                        <span class="badge bg-light text-dark fw-normal border">@T[actionKey]</span>
                    }
                </div>
            </div>

            <div class="bg-white border rounded-4 p-3">
                <label class="section-caption x-small mb-2">@T["IntakeWorkspace_PipelineTitle"]</label>
                <h6 class="fw-bold mb-3">@T["IntakeWorkspace_ProcessingContextTitle"]</h6>
                <div class="d-flex flex-column gap-2">
                    @for (var index = 0; index < Model.Workspace.PipelineStepKeys.Count; index++)
                    {
                        <div class="d-flex align-items-center gap-3 p-2 bg-light rounded-3 small">
                            <span class="badge bg-brand-green rounded-circle" style="width: 24px; height: 24px;">@(index + 1)</span>
                            <span>@T[Model.Workspace.PipelineStepKeys[index]]</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</details>
