@using BG.Application.Intake
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Intake.WorkspaceModel

<bg-section title="@T["IntakeWorkspace_VerifiedFieldsTitle"]" icon="bi bi-shield-check">
    <div class="bg-card intake-verify-card">
        <label class="section-caption">@T["IntakeWorkspace_VerifyZoneTitle"]</label>

        @if (Model.HasDraft)
        {
            @if (Model.CriticalReviewFields.Count > 0)
            {
                <div class="alert alert-light small border-0 shadow-none mb-0">
                    @T["IntakeWorkspace_ReviewRequired"]
                </div>
            }
        }
        else
        {
            <div class="alert alert-light mt-1 small italic border-0 shadow-none">@T["IntakeWorkspace_ReviewCardPendingBody"]</div>
        }

        <div class="mb-3">
            @{
                var guaranteeNumberReview = Model.GetReviewField(IntakeFieldKeys.GuaranteeNumber);
            }
            <label class="form-label fw-bold small" asp-for="Input.GuaranteeNumber">@T["IntakeField_GuaranteeNumber"]</label>
            @if (guaranteeNumberReview is not null)
            {
                <div class="intake-review-inline">
                    <bg-badge variant="@Model.ResolveReviewBadgeVariant(guaranteeNumberReview)">@guaranteeNumberReview.ConfidencePercent%</bg-badge>
                    @if (guaranteeNumberReview.RequiresExplicitReview)
                    {
                        <span class="intake-field-review-note">@T["IntakeWorkspace_ReviewRequired"]</span>
                    }
                </div>
            }
            <input asp-for="Input.GuaranteeNumber" class="form-control" maxlength="64" />
        </div>

        @if (Model.IsNewGuaranteeScenario)
        {
            <div class="mb-3">
                @{
                    var bankNameReview = Model.GetReviewField(IntakeFieldKeys.BankName);
                }
                <label class="form-label fw-bold small" asp-for="Input.BankName">@T["IntakeField_BankName"]</label>
                @if (bankNameReview is not null)
                {
                    <div class="intake-review-inline">
                        <bg-badge variant="@Model.ResolveReviewBadgeVariant(bankNameReview)">@bankNameReview.ConfidencePercent%</bg-badge>
                        @if (bankNameReview.RequiresExplicitReview)
                        {
                            <span class="intake-field-review-note">@T["IntakeWorkspace_ReviewRequired"]</span>
                        }
                    </div>
                }
                <input asp-for="Input.BankName" class="form-control" maxlength="128" />
            </div>

            <div class="mb-3">
                @{
                    var beneficiaryReview = Model.GetReviewField(IntakeFieldKeys.Beneficiary);
                }
                <label class="form-label fw-bold small" asp-for="Input.BeneficiaryName">@T["IntakeField_Beneficiary"]</label>
                @if (beneficiaryReview is not null)
                {
                    <div class="intake-review-inline">
                        <bg-badge variant="@Model.ResolveReviewBadgeVariant(beneficiaryReview)">@beneficiaryReview.ConfidencePercent%</bg-badge>
                        @if (beneficiaryReview.RequiresExplicitReview)
                        {
                            <span class="intake-field-review-note">@T["IntakeWorkspace_ReviewRequired"]</span>
                        }
                    </div>
                }
                <input asp-for="Input.BeneficiaryName" class="form-control" maxlength="256" />
            </div>

            <div class="mb-3">
                @{
                    var principalReview = Model.GetReviewField(IntakeFieldKeys.Principal);
                }
                <label class="form-label fw-bold small" asp-for="Input.PrincipalName">@T["IntakeField_Principal"]</label>
                @if (principalReview is not null)
                {
                    <div class="intake-review-inline">
                        <bg-badge variant="@Model.ResolveReviewBadgeVariant(principalReview)">@principalReview.ConfidencePercent%</bg-badge>
                        @if (principalReview.RequiresExplicitReview)
                        {
                            <span class="intake-field-review-note">@T["IntakeWorkspace_ReviewRequired"]</span>
                        }
                    </div>
                }
                <input asp-for="Input.PrincipalName" class="form-control" maxlength="256" />
            </div>

            <div class="mb-3">
                @{
                    var categoryReview = Model.GetReviewField(IntakeFieldKeys.GuaranteeCategory);
                }
                <label class="form-label fw-bold small" asp-for="Input.GuaranteeCategory">@T["IntakeField_GuaranteeCategory"]</label>
                @if (categoryReview is not null)
                {
                    <div class="intake-review-inline">
                        <bg-badge variant="@Model.ResolveReviewBadgeVariant(categoryReview)">@categoryReview.ConfidencePercent%</bg-badge>
                        @if (categoryReview.RequiresExplicitReview)
                        {
                            <span class="intake-field-review-note">@T["IntakeWorkspace_ReviewRequired"]</span>
                        }
                    </div>
                }
                <select asp-for="Input.GuaranteeCategory" class="form-control">
                    <option value="">@T["IntakeWorkspace_SelectGuaranteeCategory"]</option>
                    @foreach (var option in Model.GuaranteeCategoryOptions)
                    {
                        <option value="@option.Value">@T[option.ResourceKey]</option>
                    }
                </select>
            </div>

            <div class="row g-3">
                <div class="col-8">
                    @{
                        var amountReview = Model.GetReviewField(IntakeFieldKeys.Amount);
                    }
                    <label class="form-label fw-bold small" asp-for="Input.Amount">@T["IntakeField_Amount"]</label>
                    @if (amountReview is not null)
                    {
                        <div class="intake-review-inline">
                            <bg-badge variant="@Model.ResolveReviewBadgeVariant(amountReview)">@amountReview.ConfidencePercent%</bg-badge>
                            @if (amountReview.RequiresExplicitReview)
                            {
                                <span class="intake-field-review-note">@T["IntakeWorkspace_ReviewRequired"]</span>
                            }
                        </div>
                    }
                    <input asp-for="Input.Amount" class="form-control" inputmode="decimal" />
                </div>
                <div class="col-4">
                    @{
                        var currencyReview = Model.GetReviewField(IntakeFieldKeys.CurrencyCode);
                    }
                    <label class="form-label fw-bold small" asp-for="Input.CurrencyCode">@T["IntakeField_CurrencyCode"]</label>
                    @if (currencyReview is not null)
                    {
                        <div class="intake-review-inline">
                            <bg-badge variant="@Model.ResolveReviewBadgeVariant(currencyReview)">@currencyReview.ConfidencePercent%</bg-badge>
                            @if (currencyReview.RequiresExplicitReview)
                            {
                                <span class="intake-field-review-note">@T["IntakeWorkspace_ReviewRequired"]</span>
                            }
                        </div>
                    }
                    <input asp-for="Input.CurrencyCode" class="form-control" maxlength="3" />
                </div>
            </div>

            <div class="row g-3 mt-1">
                <div class="col-6">
                    @{
                        var issueDateReview = Model.GetReviewField(IntakeFieldKeys.IssueDate);
                    }
                    <label class="form-label fw-bold small" asp-for="Input.IssueDate">@T["IntakeField_IssueDate"]</label>
                    @if (issueDateReview is not null)
                    {
                        <div class="intake-review-inline">
                            <bg-badge variant="@Model.ResolveReviewBadgeVariant(issueDateReview)">@issueDateReview.ConfidencePercent%</bg-badge>
                            @if (issueDateReview.RequiresExplicitReview)
                            {
                                <span class="intake-field-review-note">@T["IntakeWorkspace_ReviewRequired"]</span>
                            }
                        </div>
                    }
                    <input asp-for="Input.IssueDate" class="form-control" type="date" />
                </div>
                <div class="col-6">
                    @{
                        var expiryDateReview = Model.GetReviewField(IntakeFieldKeys.ExpiryDate);
                    }
                    <label class="form-label fw-bold small" asp-for="Input.ExpiryDate">@T["IntakeField_ExpiryDate"]</label>
                    @if (expiryDateReview is not null)
                    {
                        <div class="intake-review-inline">
                            <bg-badge variant="@Model.ResolveReviewBadgeVariant(expiryDateReview)">@expiryDateReview.ConfidencePercent%</bg-badge>
                            @if (expiryDateReview.RequiresExplicitReview)
                            {
                                <span class="intake-field-review-note">@T["IntakeWorkspace_ReviewRequired"]</span>
                            }
                        </div>
                    }
                    <input asp-for="Input.ExpiryDate" class="form-control" type="date" />
                </div>
            </div>
        }
        else
        {
            @if (!Model.IsAttachmentScenario)
            {
                <div class="row g-3">
                    <div class="col-6">
                        @{
                            var officialLetterDateReview = Model.GetReviewField(IntakeFieldKeys.OfficialLetterDate);
                        }
                        <label class="form-label fw-bold small" asp-for="Input.OfficialLetterDate">@T["IntakeField_OfficialLetterDate"]</label>
                        @if (officialLetterDateReview is not null)
                        {
                            <div class="intake-review-inline">
                                <bg-badge variant="@Model.ResolveReviewBadgeVariant(officialLetterDateReview)">@officialLetterDateReview.ConfidencePercent%</bg-badge>
                                @if (officialLetterDateReview.RequiresExplicitReview)
                                {
                                    <span class="intake-field-review-note">@T["IntakeWorkspace_ReviewRequired"]</span>
                                }
                            </div>
                        }
                        <input asp-for="Input.OfficialLetterDate" class="form-control" type="date" />
                    </div>
                    <div class="col-6">
                        @{
                            var bankReferenceReview = Model.GetReviewField(IntakeFieldKeys.BankReference);
                        }
                        <label class="form-label fw-bold small" asp-for="Input.BankReference">@T["IntakeField_BankReference"]</label>
                        @if (bankReferenceReview is not null)
                        {
                            <div class="intake-review-inline">
                                <bg-badge variant="@Model.ResolveReviewBadgeVariant(bankReferenceReview)">@bankReferenceReview.ConfidencePercent%</bg-badge>
                                @if (bankReferenceReview.RequiresExplicitReview)
                                {
                                    <span class="intake-field-review-note">@T["IntakeWorkspace_ReviewRequired"]</span>
                                }
                            </div>
                        }
                        <input asp-for="Input.BankReference" class="form-control" maxlength="64" />
                    </div>
                </div>
            }

            @if (Model.IsExtensionScenario)
            {
                <div class="mt-3">
                    @{
                        var newExpiryDateReview = Model.GetReviewField(IntakeFieldKeys.NewExpiryDate);
                    }
                    <label class="form-label fw-bold small" asp-for="Input.NewExpiryDate">@T["IntakeField_NewExpiryDate"]</label>
                    @if (newExpiryDateReview is not null)
                    {
                        <div class="intake-review-inline">
                            <bg-badge variant="@Model.ResolveReviewBadgeVariant(newExpiryDateReview)">@newExpiryDateReview.ConfidencePercent%</bg-badge>
                            @if (newExpiryDateReview.RequiresExplicitReview)
                            {
                                <span class="intake-field-review-note">@T["IntakeWorkspace_ReviewRequired"]</span>
                            }
                        </div>
                    }
                    <input asp-for="Input.NewExpiryDate" class="form-control" type="date" />
                </div>
            }

            @if (Model.IsReductionScenario)
            {
                <div class="mt-3">
                    @{
                        var confirmedAmountReview = Model.GetReviewField(IntakeFieldKeys.Amount);
                    }
                    <label class="form-label fw-bold small" asp-for="Input.Amount">@T["IntakeField_Amount"]</label>
                    @if (confirmedAmountReview is not null)
                    {
                        <div class="intake-review-inline">
                            <bg-badge variant="@Model.ResolveReviewBadgeVariant(confirmedAmountReview)">@confirmedAmountReview.ConfidencePercent%</bg-badge>
                            @if (confirmedAmountReview.RequiresExplicitReview)
                            {
                                <span class="intake-field-review-note">@T["IntakeWorkspace_ReviewRequired"]</span>
                            }
                        </div>
                    }
                    <input asp-for="Input.Amount" class="form-control" inputmode="decimal" />
                </div>
            }

            @if (Model.IsStatusScenario)
            {
                <div class="mt-3">
                    @{
                        var statusStatementReview = Model.GetReviewField(IntakeFieldKeys.StatusStatement);
                    }
                    <label class="form-label fw-bold small" asp-for="Input.StatusStatement">@T["IntakeField_StatusStatement"]</label>
                    @if (statusStatementReview is not null)
                    {
                        <div class="intake-review-inline">
                            <bg-badge variant="@Model.ResolveReviewBadgeVariant(statusStatementReview)">@statusStatementReview.ConfidencePercent%</bg-badge>
                            @if (statusStatementReview.RequiresExplicitReview)
                            {
                                <span class="intake-field-review-note">@T["IntakeWorkspace_ReviewRequired"]</span>
                            }
                        </div>
                    }
                    <textarea asp-for="Input.StatusStatement" class="form-control" rows="4"></textarea>
                </div>
            }

            @if (Model.IsAttachmentScenario)
            {
                <div class="mt-3">
                    @{
                        var attachmentNoteReview = Model.GetReviewField(IntakeFieldKeys.AttachmentNote);
                    }
                    <label class="form-label fw-bold small" asp-for="Input.AttachmentNote">@T["IntakeField_AttachmentNote"]</label>
                    @if (attachmentNoteReview is not null)
                    {
                        <div class="intake-review-inline">
                            <bg-badge variant="@Model.ResolveReviewBadgeVariant(attachmentNoteReview)">@attachmentNoteReview.ConfidencePercent%</bg-badge>
                            @if (attachmentNoteReview.RequiresExplicitReview)
                            {
                                <span class="intake-field-review-note">@T["IntakeWorkspace_ReviewRequired"]</span>
                            }
                        </div>
                    }
                    <textarea asp-for="Input.AttachmentNote" class="form-control" rows="4"></textarea>
                </div>
            }
        }
    </div>

    <div class="mt-4 pt-4 border-top d-flex justify-content-end">
        <button type="submit"
                formaction="@Url.Page("/Intake/Workspace", pageHandler: "Save")"
                class="bg-btn bg-btn-primary"
                disabled="@(Model.CanFinalize ? null : "disabled")">
            <i class="bi bi-check-all me-2"></i>@T["IntakeWorkspace_SaveAction"]
        </button>
    </div>
</bg-section>
