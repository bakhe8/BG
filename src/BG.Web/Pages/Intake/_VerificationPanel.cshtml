@using BG.Application.Intake
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Intake.WorkspaceModel
@{
    var guaranteeNumberReview = Model.HasDraft ? Model.GetReviewField(IntakeFieldKeys.GuaranteeNumber) : null;
    var bankNameReview = Model.HasDraft ? Model.GetReviewField(IntakeFieldKeys.BankName) : null;
    var beneficiaryReview = Model.HasDraft ? Model.GetReviewField(IntakeFieldKeys.Beneficiary) : null;
    var principalReview = Model.HasDraft ? Model.GetReviewField(IntakeFieldKeys.Principal) : null;
    var categoryReview = Model.HasDraft ? Model.GetReviewField(IntakeFieldKeys.GuaranteeCategory) : null;
    var amountReview = Model.HasDraft ? Model.GetReviewField(IntakeFieldKeys.Amount) : null;
    var currencyReview = Model.HasDraft ? Model.GetReviewField(IntakeFieldKeys.CurrencyCode) : null;
    var issueDateReview = Model.HasDraft ? Model.GetReviewField(IntakeFieldKeys.IssueDate) : null;
    var expiryDateReview = Model.HasDraft ? Model.GetReviewField(IntakeFieldKeys.ExpiryDate) : null;
    var officialLetterDateReview = Model.HasDraft ? Model.GetReviewField(IntakeFieldKeys.OfficialLetterDate) : null;
    var bankReferenceReview = Model.HasDraft ? Model.GetReviewField(IntakeFieldKeys.BankReference) : null;
    var newExpiryDateReview = Model.HasDraft ? Model.GetReviewField(IntakeFieldKeys.NewExpiryDate) : null;
    var confirmedAmountReview = Model.HasDraft ? Model.GetReviewField(IntakeFieldKeys.Amount) : null;
    var statusStatementReview = Model.HasDraft ? Model.GetReviewField(IntakeFieldKeys.StatusStatement) : null;
    var attachmentNoteReview = Model.HasDraft ? Model.GetReviewField(IntakeFieldKeys.AttachmentNote) : null;
}

<section class="intake-panel intake-panel--verification">
    <div class="intake-panel__header">
        <i class="bi bi-shield-check"></i>
        <span>@T["IntakeWorkspace_VerifiedFieldsTitle"]</span>
    </div>

    @if (Model.HasDraft && Model.CriticalReviewFields.Count > 0)
    {
        <div class="intake-review-banner">
            <i class="bi bi-exclamation-triangle me-2"></i>@T["IntakeWorkspace_ReviewRequired"]
        </div>
    }
    else if (!Model.HasDraft)
    {
        <div class="intake-review-banner intake-review-banner--pending">
            @T["IntakeWorkspace_ReviewCardPendingBody"]
        </div>
    }

    <div class="intake-field-list">
        <article class="intake-field-row is-full-width">
            <div class="intake-field-row__meta">
                <div class="intake-field-row__label">@T["IntakeField_GuaranteeNumber"]</div>
                @if (guaranteeNumberReview is not null)
                {
                    <div class="intake-field-row__confidence">
                        <bg-badge variant="@Model.ResolveReviewBadgeVariant(guaranteeNumberReview)">@guaranteeNumberReview.ConfidencePercent%</bg-badge>
                    </div>
                }
            </div>
            @if (guaranteeNumberReview?.RequiresExplicitReview == true)
            {
                <div class="intake-field-row__state">@T["IntakeWorkspace_ReviewRequired"]</div>
            }
            <div class="intake-field-row__input">
                <input asp-for="Input.GuaranteeNumber" class="form-control" maxlength="64" />
            </div>
        </article>

        @if (Model.IsNewGuaranteeScenario)
        {
            <article class="intake-field-row">
                <div class="intake-field-row__meta">
                    <div class="intake-field-row__label">@T["IntakeField_BankName"]</div>
                    @if (bankNameReview is not null)
                    {
                        <div class="intake-field-row__confidence">
                            <bg-badge variant="@Model.ResolveReviewBadgeVariant(bankNameReview)">@bankNameReview.ConfidencePercent%</bg-badge>
                        </div>
                    }
                </div>
                @if (bankNameReview?.RequiresExplicitReview == true)
                {
                    <div class="intake-field-row__state">@T["IntakeWorkspace_ReviewRequired"]</div>
                }
                <div class="intake-field-row__input">
                    <input asp-for="Input.BankName" class="form-control" maxlength="128" />
                </div>
            </article>

            <article class="intake-field-row">
                <div class="intake-field-row__meta">
                    <div class="intake-field-row__label">@T["IntakeField_Beneficiary"]</div>
                    @if (beneficiaryReview is not null)
                    {
                        <div class="intake-field-row__confidence">
                            <bg-badge variant="@Model.ResolveReviewBadgeVariant(beneficiaryReview)">@beneficiaryReview.ConfidencePercent%</bg-badge>
                        </div>
                    }
                </div>
                @if (beneficiaryReview?.RequiresExplicitReview == true)
                {
                    <div class="intake-field-row__state">@T["IntakeWorkspace_ReviewRequired"]</div>
                }
                <div class="intake-field-row__input">
                    <input asp-for="Input.BeneficiaryName" class="form-control" maxlength="256" />
                </div>
            </article>

            <article class="intake-field-row">
                <div class="intake-field-row__meta">
                    <div class="intake-field-row__label">@T["IntakeField_Principal"]</div>
                    @if (principalReview is not null)
                    {
                        <div class="intake-field-row__confidence">
                            <bg-badge variant="@Model.ResolveReviewBadgeVariant(principalReview)">@principalReview.ConfidencePercent%</bg-badge>
                        </div>
                    }
                </div>
                @if (principalReview?.RequiresExplicitReview == true)
                {
                    <div class="intake-field-row__state">@T["IntakeWorkspace_ReviewRequired"]</div>
                }
                <div class="intake-field-row__input">
                    <input asp-for="Input.PrincipalName" class="form-control" maxlength="256" />
                </div>
            </article>

            <article class="intake-field-row">
                <div class="intake-field-row__meta">
                    <div class="intake-field-row__label">@T["IntakeField_GuaranteeCategory"]</div>
                    @if (categoryReview is not null)
                    {
                        <div class="intake-field-row__confidence">
                            <bg-badge variant="@Model.ResolveReviewBadgeVariant(categoryReview)">@categoryReview.ConfidencePercent%</bg-badge>
                        </div>
                    }
                </div>
                @if (categoryReview?.RequiresExplicitReview == true)
                {
                    <div class="intake-field-row__state">@T["IntakeWorkspace_ReviewRequired"]</div>
                }
                <div class="intake-field-row__input">
                    <select asp-for="Input.GuaranteeCategory" class="form-control">
                        <option value="">@T["IntakeWorkspace_SelectGuaranteeCategory"]</option>
                        @foreach (var option in Model.GuaranteeCategoryOptions)
                        {
                            <option value="@option.Value">@T[option.ResourceKey]</option>
                        }
                    </select>
                </div>
            </article>

            <article class="intake-field-row is-full-width">
                <div class="intake-coupled-grid intake-coupled-grid--amount">
                    <div class="intake-coupled-grid__label">
                        <div class="intake-field-row__meta">
                            <div class="intake-field-row__label">@T["IntakeField_Amount"]</div>
                            @if (amountReview is not null) { <bg-badge variant="@Model.ResolveReviewBadgeVariant(amountReview)">@amountReview.ConfidencePercent%</bg-badge> }
                        </div>
                    </div>
                    <div class="intake-coupled-grid__label">
                        <div class="intake-field-row__meta">
                            <div class="intake-field-row__label">@T["IntakeField_CurrencyCode"]</div>
                            @if (currencyReview is not null) { <bg-badge variant="@Model.ResolveReviewBadgeVariant(currencyReview)">@currencyReview.ConfidencePercent%</bg-badge> }
                        </div>
                    </div>
                    <div class="intake-coupled-grid__state">
                        @if (amountReview?.RequiresExplicitReview == true) { <div class="intake-field-row__state">@T["IntakeWorkspace_ReviewRequired"]</div> }
                    </div>
                    <div class="intake-coupled-grid__state">
                        @if (currencyReview?.RequiresExplicitReview == true) { <div class="intake-field-row__state">@T["IntakeWorkspace_ReviewRequired"]</div> }
                        else if (amountReview?.RequiresExplicitReview == true) { <div class="intake-field-row__state invisible">@T["IntakeWorkspace_ReviewRequired"]</div> }
                    </div>
                    <div class="intake-coupled-grid__input">
                        <input asp-for="Input.Amount" class="form-control" inputmode="decimal" />
                    </div>
                    <div class="intake-coupled-grid__input">
                        <input asp-for="Input.CurrencyCode" class="form-control text-uppercase" maxlength="3" placeholder="@T["IntakeField_CurrencyCode"]" />
                    </div>
                </div>
            </article>

            <article class="intake-field-row is-full-width">
                <div class="intake-coupled-grid intake-coupled-grid--dates">
                    <div class="intake-coupled-grid__label">
                        <div class="intake-field-row__meta">
                            <div class="intake-field-row__label">@T["IntakeField_IssueDate"]</div>
                            @if (issueDateReview is not null) { <bg-badge variant="@Model.ResolveReviewBadgeVariant(issueDateReview)">@issueDateReview.ConfidencePercent%</bg-badge> }
                        </div>
                    </div>
                    <div class="intake-coupled-grid__label">
                        <div class="intake-field-row__meta">
                            <div class="intake-field-row__label">@T["IntakeField_ExpiryDate"]</div>
                            @if (expiryDateReview is not null) { <bg-badge variant="@Model.ResolveReviewBadgeVariant(expiryDateReview)">@expiryDateReview.ConfidencePercent%</bg-badge> }
                        </div>
                    </div>
                    <div class="intake-coupled-grid__state">
                        @if (issueDateReview?.RequiresExplicitReview == true) { <div class="intake-field-row__state">@T["IntakeWorkspace_ReviewRequired"]</div> }
                    </div>
                    <div class="intake-coupled-grid__state">
                        @if (expiryDateReview?.RequiresExplicitReview == true) { <div class="intake-field-row__state">@T["IntakeWorkspace_ReviewRequired"]</div> }
                        else if (issueDateReview?.RequiresExplicitReview == true) { <div class="intake-field-row__state invisible">@T["IntakeWorkspace_ReviewRequired"]</div> }
                    </div>
                    <div class="intake-coupled-grid__input">
                        <input asp-for="Input.IssueDate" class="form-control" type="date" />
                    </div>
                    <div class="intake-coupled-grid__input">
                        <input asp-for="Input.ExpiryDate" class="form-control" type="date" />
                    </div>
                </div>
            </article>
        }
        else
        {
            if (!Model.IsAttachmentScenario)
            {
                <article class="intake-field-row">
                    <div class="intake-field-row__meta">
                        <div class="intake-field-row__label">@T["IntakeField_OfficialLetterDate"]</div>
                        @if (officialLetterDateReview is not null) { <bg-badge variant="@Model.ResolveReviewBadgeVariant(officialLetterDateReview)">@officialLetterDateReview.ConfidencePercent%</bg-badge> }
                    </div>
                    @if (officialLetterDateReview?.RequiresExplicitReview == true) { <div class="intake-field-row__state">@T["IntakeWorkspace_ReviewRequired"]</div> }
                    <div class="intake-field-row__input">
                        <input asp-for="Input.OfficialLetterDate" class="form-control" type="date" />
                    </div>
                </article>

                <article class="intake-field-row">
                    <div class="intake-field-row__meta">
                        <div class="intake-field-row__label">@T["IntakeField_BankReference"]</div>
                        @if (bankReferenceReview is not null) { <bg-badge variant="@Model.ResolveReviewBadgeVariant(bankReferenceReview)">@bankReferenceReview.ConfidencePercent%</bg-badge> }
                    </div>
                    @if (bankReferenceReview?.RequiresExplicitReview == true) { <div class="intake-field-row__state">@T["IntakeWorkspace_ReviewRequired"]</div> }
                    <div class="intake-field-row__input">
                        <input asp-for="Input.BankReference" class="form-control" maxlength="64" />
                    </div>
                </article>
            }

            if (Model.IsExtensionScenario)
            {
                <article class="intake-field-row">
                    <div class="intake-field-row__meta">
                        <div class="intake-field-row__label">@T["IntakeField_NewExpiryDate"]</div>
                        @if (newExpiryDateReview is not null) { <bg-badge variant="@Model.ResolveReviewBadgeVariant(newExpiryDateReview)">@newExpiryDateReview.ConfidencePercent%</bg-badge> }
                    </div>
                    @if (newExpiryDateReview?.RequiresExplicitReview == true) { <div class="intake-field-row__state">@T["IntakeWorkspace_ReviewRequired"]</div> }
                    <div class="intake-field-row__input">
                        <input asp-for="Input.NewExpiryDate" class="form-control" type="date" />
                    </div>
                </article>
            }

            if (Model.IsReductionScenario)
            {
                <article class="intake-field-row">
                    <div class="intake-field-row__meta">
                        <div class="intake-field-row__label">@T["IntakeField_Amount"]</div>
                        @if (confirmedAmountReview is not null) { <bg-badge variant="@Model.ResolveReviewBadgeVariant(confirmedAmountReview)">@confirmedAmountReview.ConfidencePercent%</bg-badge> }
                    </div>
                    @if (confirmedAmountReview?.RequiresExplicitReview == true) { <div class="intake-field-row__state">@T["IntakeWorkspace_ReviewRequired"]</div> }
                    <div class="intake-field-row__input">
                        <input asp-for="Input.Amount" class="form-control" inputmode="decimal" />
                    </div>
                </article>
            }

            if (Model.IsStatusScenario)
            {
                <article class="intake-field-row is-full-width">
                    <div class="intake-field-row__meta">
                        <div class="intake-field-row__label">@T["IntakeField_StatusStatement"]</div>
                        @if (statusStatementReview is not null) { <bg-badge variant="@Model.ResolveReviewBadgeVariant(statusStatementReview)">@statusStatementReview.ConfidencePercent%</bg-badge> }
                    </div>
                    @if (statusStatementReview?.RequiresExplicitReview == true) { <div class="intake-field-row__state">@T["IntakeWorkspace_ReviewRequired"]</div> }
                    <div class="intake-field-row__input">
                        <textarea asp-for="Input.StatusStatement" class="form-control" rows="4"></textarea>
                    </div>
                </article>
            }

            if (Model.IsAttachmentScenario)
            {
                <article class="intake-field-row is-full-width">
                    <div class="intake-field-row__meta">
                        <div class="intake-field-row__label">@T["IntakeField_AttachmentNote"]</div>
                        @if (attachmentNoteReview is not null) { <bg-badge variant="@Model.ResolveReviewBadgeVariant(attachmentNoteReview)">@attachmentNoteReview.ConfidencePercent%</bg-badge> }
                    </div>
                    @if (attachmentNoteReview?.RequiresExplicitReview == true) { <div class="intake-field-row__state">@T["IntakeWorkspace_ReviewRequired"]</div> }
                    <div class="intake-field-row__input">
                        <textarea asp-for="Input.AttachmentNote" class="form-control" rows="4"></textarea>
                    </div>
                </article>
            }
        }
    </div>
</section>
