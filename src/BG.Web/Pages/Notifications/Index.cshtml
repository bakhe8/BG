@page
@model BG.Web.Pages.Notifications.IndexModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@{
    ViewData["Title"] = T["Notifications_InboxPageTitle"];
}

<section class="section-shell notifications-surface">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold text-dark mb-1">@T["Notifications_Title"]</h4>
            <p class="text-muted small mb-0">@T["Notifications_InboxSubtitle"]</p>
        </div>
        @if (Model.Notifications.Any())
        {
            <form method="post" asp-page-handler="MarkAllRead">
                <button type="submit" class="btn btn-sm btn-light border rounded-pill px-3 text-muted">
                    <i class="bi bi-check2-all me-1"></i>@T["Notifications_MarkAllRead"]
                </button>
            </form>
        }
    </div>

    @if (!Model.Notifications.Any())
    {
        <div class="text-center py-5 mt-4">
            <i class="bi bi-bell-slash text-muted opacity-25 d-block mb-3" style="font-size: 4rem;"></i>
            <p class="text-muted">@T["Notifications_EmptyState"]</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-2">
            @foreach (var n in Model.Notifications)
            {
                <div class="d-flex align-items-start gap-3 p-3 rounded-4 bg-white border shadow-sm @(n.IsRead ? "opacity-75" : "")">
                    <div class="mt-1 flex-shrink-0">
                        <span class="d-inline-block rounded-circle @(n.IsRead ? "bg-light" : "bg-success")"
                              style="width: 8px; height: 8px;"></span>
                    </div>
                    <div class="flex-grow-1">
                        @if (!string.IsNullOrWhiteSpace(n.Link))
                        {
                            <a href="@n.Link" class="fw-semibold text-dark text-decoration-none small d-block mb-1">@n.Message</a>
                        }
                        else
                        {
                            <span class="fw-semibold text-dark small d-block mb-1">@n.Message</span>
                        }
                        <span class="text-muted x-small">@n.CreatedAtUtc.ToLocalTime().ToString("g")</span>
                    </div>
                    @if (!n.IsRead)
                    {
                        <form method="post" asp-page-handler="MarkRead" class="flex-shrink-0">
                            <input type="hidden" name="id" value="@n.Id" />
                            <button type="submit" class="btn btn-sm btn-light border rounded-pill px-3 x-small text-muted">
                                @T["Notifications_MarkRead"]
                            </button>
                        </form>
                    }
                </div>
            }
        </div>
    }
</section>
