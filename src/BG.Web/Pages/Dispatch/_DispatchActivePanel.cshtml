@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Dispatch.WorkspaceModel
@{
    bool hasAnyDispatchAction = Model.Snapshot.ActiveActor is not null &&
                                (Model.Snapshot.ActiveActor.CanPrint || Model.Snapshot.ActiveActor.CanRecord || Model.Snapshot.ActiveActor.CanEmail);
}

@if (Model.ActiveReadyItem is null && Model.ActivePendingDeliveryItem is null)
{
    <article class="bg-card shadow-sm p-5 text-center">
        <div class="py-5">
            <i class="bi bi-send fs-1 text-muted opacity-25 d-block mb-3"></i>
            <h2 class="fw-bold text-dark">@T["DispatchWorkspace_Empty"]</h2>
            <p class="text-secondary">@T["DispatchWorkspace_ItemsTitle"]</p>
        </div>
    </article>
}
else if (Model.ActiveReadyItem is not null)
{
    var item = Model.ActiveReadyItem;

    <article class="dispatch-active-panel h-100 d-flex flex-column bg-white border rounded-4 overflow-hidden shadow-sm">
        @* 1. Institutional Header *@
        <div class="p-4 border-bottom bg-white">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="d-flex align-items-center gap-3">
                    <span class="badge bg-light text-dark border px-3 py-2 rounded-pill fw-bold">@item.GuaranteeNumber</span>
                    <bg-badge class="bg-badge-success">@T[item.StatusResourceKey]</bg-badge>
                </div>
                <button type="button" class="btn-close" aria-label="Close"></button>
            </div>
            <h3 class="fw-bold text-dark mb-2">@T["DispatchWorkspace_ReadyStateTitle"]</h3>
            <div class="d-flex align-items-center gap-2 text-muted x-small text-uppercase fw-bold">
                <i class="bi bi-person-circle"></i>
                <span>@item.RequesterDisplayName</span>
                <span class="mx-1">·</span>
                <i class="bi bi-calendar3"></i>
                <span>@item.ReadyAtUtc.ToLocalTime().ToString("g")</span>
            </div>
        </div>

        @* 2. Scrollable Work Surface *@
        <div class="flex-grow-1 overflow-auto p-4">
            
            @* Stats Grid *@
            <div class="row g-4 mb-5">
                <div class="col-6">
                    <div class="bg-light p-4 rounded-4 border-0">
                        <div class="bg-grid-label">@T["DispatchWorkspace_ReferenceLabel"]</div>
                        <div class="bg-grid-value fs-5 mt-1">@(string.IsNullOrWhiteSpace(item.OutgoingReferenceNumber) ? T["OperationsQueue_NotAvailable"].Value : item.OutgoingReferenceNumber)</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="bg-light p-4 rounded-4 border-0">
                        <div class="bg-grid-label">@T["DispatchWorkspace_PrintCountLabel"]</div>
                        <div class="bg-grid-value fs-5 mt-1">@item.PrintCount</div>
                    </div>
                </div>
            </div>

            @if (hasAnyDispatchAction)
            {
                <form method="post" id="dispatch-form" class="stack-form d-flex flex-column gap-4">
                    <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor!.Id" />
                    <input type="hidden" name="requestId" value="@item.RequestId" />
                    
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label x-small text-muted text-uppercase fw-bold" for="dispatch-reference">@T["DispatchWorkspace_ReferenceField"]</label>
                            <input id="dispatch-reference" name="referenceNumber" class="form-control rounded-3" maxlength="64" value="@item.OutgoingReferenceNumber" />
                        </div>
                        <div class="col-6">
                            <label class="form-label x-small text-muted text-uppercase fw-bold" for="dispatch-letter-date">@T["DispatchWorkspace_LetterDateField"]</label>
                            <input id="dispatch-letter-date" name="letterDate" class="form-control rounded-3" type="date" value="@(item.OutgoingLetterDate?.ToString("yyyy-MM-dd"))" />
                        </div>
                    </div>

                    <div>
                        <label class="form-label x-small text-muted text-uppercase fw-bold" for="dispatch-channel">@T["DispatchWorkspace_DispatchChannelField"]</label>
                        <select id="dispatch-channel" name="dispatchChannel" class="form-control rounded-3">
                            @foreach (var option in Model.GetAvailableDispatchChannelOptions())
                            {
                                <option value="@option.Channel">@T[option.ResourceKey]</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="form-label x-small text-muted text-uppercase fw-bold" for="dispatch-note">@T["DispatchWorkspace_NoteField"]</label>
                        <textarea id="dispatch-note" name="note" class="form-control rounded-3" rows="3"></textarea>
                    </div>
                </form>
            }
            else
            {
                <div class="alert alert-light border-0 shadow-none small italic">
                    <i class="bi bi-info-circle me-2"></i>@T[Model.ResolveNoActionReasonResourceKey(isPendingDelivery: false)]
                </div>
            }
        </div>

        @if (hasAnyDispatchAction)
        {
            @* 3. Institutional Action Bar *@
            <div class="bg-sticky-action-bar">
                <div class="d-flex gap-2">
                    <button type="submit" form="dispatch-form" formaction="/Dispatch/Workspace?handler=Dispatch" class="bg-btn bg-btn-primary px-4 py-3 shadow-none flex-grow-1">
                        <i class="bi bi-send-check-fill me-2 rotate-rtl"></i>@T["DispatchWorkspace_DispatchAction"]
                    </button>
                    @if (Model.Snapshot.ActiveActor!.CanPrint)
                    {
                        <button type="submit" form="dispatch-form" formaction="/Dispatch/Workspace?handler=Print" class="bg-btn bg-btn-secondary px-4 py-3 border flex-grow-1">
                            <i class="bi bi-printer me-2"></i>@T["DispatchWorkspace_PrintAction"]
                        </button>
                    }
                </div>
            </div>
        }
    </article>
}
else if (Model.ActivePendingDeliveryItem is not null)
{
    var item = Model.ActivePendingDeliveryItem;

    <article class="dispatch-active-panel h-100 d-flex flex-column bg-white border rounded-4 overflow-hidden shadow-sm">
        @* 1. Institutional Header *@
        <div class="p-4 border-bottom bg-white">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="d-flex align-items-center gap-3">
                    <span class="badge bg-light text-dark border px-3 py-2 rounded-pill fw-bold">@item.GuaranteeNumber</span>
                    <bg-badge class="bg-badge-info">@T["DispatchWorkspace_PendingDeliveryBadge"]</bg-badge>
                </div>
                <button type="button" class="btn-close" aria-label="Close"></button>
            </div>
            <h3 class="fw-bold text-dark mb-2">@T["DispatchWorkspace_PendingDeliveryTitle"]</h3>
            <div class="d-flex align-items-center gap-2 text-muted x-small text-uppercase fw-bold">
                <i class="bi bi-person-circle"></i>
                <span>@item.RequesterDisplayName</span>
                <span class="mx-1">·</span>
                <i class="bi bi-send"></i>
                <span>@item.DispatchedAtUtc.ToLocalTime().ToString("g")</span>
            </div>
        </div>

        @* 2. Scrollable Work Surface *@
        <div class="flex-grow-1 overflow-auto p-4">
            
            @* Stats Grid *@
            <div class="row g-4 mb-5">
                <div class="col-6">
                    <div class="bg-light p-4 rounded-4 border-0">
                        <div class="bg-grid-label">@T["DispatchWorkspace_ReferenceLabel"]</div>
                        <div class="bg-grid-value fs-5 mt-1">@item.ReferenceNumber</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="bg-light p-4 rounded-4 border-0">
                        <div class="bg-grid-label">@T["DispatchWorkspace_DispatchChannelLabel"]</div>
                        <div class="bg-grid-value fs-5 mt-1">@T[item.DispatchChannelResourceKey]</div>
                    </div>
                </div>
            </div>

            @if (hasAnyDispatchAction)
            {
                <form method="post" id="delivery-form" class="stack-form d-flex flex-column gap-4">
                    <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor!.Id" />
                    <input type="hidden" name="requestId" value="@item.RequestId" />
                    <input type="hidden" name="correspondenceId" value="@item.CorrespondenceId" />

                    <div>
                        <label class="form-label x-small text-muted text-uppercase fw-bold" for="delivery-reference">@T["DispatchWorkspace_DeliveryReferenceField"]</label>
                        <input id="delivery-reference" name="deliveryReference" class="form-control rounded-3" maxlength="128" />
                    </div>

                    <div>
                        <label class="form-label x-small text-muted text-uppercase fw-bold" for="delivery-note">@T["DispatchWorkspace_DeliveryNoteField"]</label>
                        <textarea id="delivery-note" name="deliveryNote" class="form-control rounded-3" rows="3"></textarea>
                    </div>
                </form>
            }
            else
            {
                <div class="alert alert-light border-0 shadow-none small italic">
                    <i class="bi bi-info-circle me-2"></i>@T[Model.ResolveNoActionReasonResourceKey(isPendingDelivery: true)]
                </div>
            }
        </div>

        @if (hasAnyDispatchAction)
        {
            @* 3. Institutional Action Bar *@
            <div class="bg-sticky-action-bar">
                <div class="d-flex gap-2">
                    <button type="submit" form="delivery-form" formaction="/Dispatch/Workspace?handler=ConfirmDelivery" class="bg-btn bg-btn-primary px-4 py-3 shadow-none flex-grow-1">
                        <i class="bi bi-check-circle-fill me-2"></i>@T["DispatchWorkspace_ConfirmDeliveryAction"]
                    </button>
                    <button type="submit" form="delivery-form" formaction="/Dispatch/Workspace?handler=ReopenDispatch" class="bg-btn bg-btn-secondary px-4 py-3 border flex-grow-1" style="background-color: #FEE2E2; color: #991B1B !important; border: 1px solid #FECACA;">
                        <i class="bi bi-arrow-counterclockwise me-2"></i>@T["DispatchWorkspace_ReopenAction"]
                    </button>
                </div>
            </div>
        }
    </article>
}
