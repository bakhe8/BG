@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Dispatch.WorkspaceModel

<aside class="bg_unified_stage_sidebar">
    <div class="bg_unified_stage_sidebar_header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h6 class="fw-bold text-dark mb-0">@T["DispatchWorkspace_ItemsTitle"]</h6>
                <div class="xx-small text-muted opacity-75">@T["DispatchWorkspace_ItemsSummary"]</div>
            </div>
            <div class="badge bg-light text-dark border rounded-pill">@(Model.Snapshot.Items.Count + Model.Snapshot.PendingDeliveryItems.Count)</div>
        </div>
    </div>

    <div class="bg_unified_stage_sidebar_list">
        @if (Model.Snapshot.Items.Count == 0 && Model.Snapshot.PendingDeliveryItems.Count == 0)
        {
            <div class="p-5 text-center opacity-50">
                <i class="bi bi-send fs-2 mb-3 d-block"></i>
                <p class="small fw-bold">@T["DispatchWorkspace_Empty"]</p>
            </div>
        }
        else
        {
            @if (Model.Snapshot.Items.Count > 0)
            {
                <div class="bg-light px-3 py-2 xx-small fw-bold text-uppercase border-bottom">@T["DispatchWorkspace_ReadyStateTitle"]</div>
                @foreach (var item in Model.Snapshot.Items)
                {
                    var isActive = Model.ActiveReadyItem?.RequestId == item.RequestId;
                    var itemModel = new SurfaceUnifiedLink(
                        "/Dispatch/Workspace",
                        new Dictionary<string, string>(Model.BuildSelectionRoute(item.RequestId)),
                        item.GuaranteeNumber,
                        T[item.RequestTypeResourceKey].Value,
                        item.RequesterDisplayName,
                        T[item.StatusResourceKey].Value,
                        item.ReadyAtUtc.ToLocalTime().ToString("MM/dd HH:mm"),
                        string.IsNullOrWhiteSpace(item.OutgoingReferenceNumber) ? null : item.OutgoingReferenceNumber,
                        isActive);
                    <partial name="/Pages/Shared/_SurfaceQueueItemLink.cshtml" model="itemModel" />
                }
            }

            @if (Model.Snapshot.PendingDeliveryItems.Count > 0)
            {
                <div class="bg-light px-3 py-2 xx-small fw-bold text-uppercase border-bottom border-top">@T["DispatchWorkspace_PendingDeliveryTitle"]</div>
                @foreach (var item in Model.Snapshot.PendingDeliveryItems)
                {
                    var isActive = Model.ActivePendingDeliveryItem?.RequestId == item.RequestId;
                    var itemModel = new SurfaceUnifiedLink(
                        "/Dispatch/Workspace",
                        new Dictionary<string, string>(Model.BuildSelectionRoute(item.RequestId)),
                        item.GuaranteeNumber,
                        T[item.RequestTypeResourceKey].Value,
                        item.RequesterDisplayName,
                        T["DispatchWorkspace_PendingDeliveryBadge"].Value,
                        item.DispatchedAtUtc.ToLocalTime().ToString("MM/dd HH:mm"),
                        T[item.DispatchChannelResourceKey].Value,
                        isActive);
                    <partial name="/Pages/Shared/_SurfaceQueueItemLink.cshtml" model="itemModel" />
                }
            }
        }
    </div>

    @if (Model.Snapshot.ItemsPage.TotalPageCount > 1)
    {
        <div class="p-2 border-top bg-white">
            @{
                var paginationModel = new SurfacePaginationModel(
                    "/Dispatch/Workspace",
                    Model.Snapshot.ItemsPage.HasPreviousPage ? new Dictionary<string, string>(Model.BuildPageRoute(Model.Snapshot.ItemsPage.PreviousPageNumber)) : null,
                    Model.Snapshot.ItemsPage.HasNextPage ? new Dictionary<string, string>(Model.BuildPageRoute(Model.Snapshot.ItemsPage.NextPageNumber)) : null,
                    T["Pagination_Previous"].Value,
                    T["Pagination_Next"].Value);
            }
            <partial name="/Pages/Shared/_SurfacePagination.cshtml" model="paginationModel" />
        </div>
    }
</aside>
