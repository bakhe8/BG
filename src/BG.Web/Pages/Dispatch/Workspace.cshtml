@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Dispatch.WorkspaceModel
@{
    ViewData["Title"] = T["DispatchWorkspace_PageTitle"];
    
    var hasDispatchItems = Model.Snapshot.Items.Count > 0 || Model.Snapshot.PendingDeliveryItems.Count > 0;
    var showQueueList = Model.Snapshot.Items.Count + Model.Snapshot.PendingDeliveryItems.Count > 1;

    ViewData["HideSupportRail"] = true;
    ViewData["HideDetailDrawer"] = true;
}

<section class="section-shell dispatch-surface py-0">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice-banner is-success">@Model.StatusMessage</div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <div class="canvas_stage">
        @if (showQueueList)
        {
            <partial name="_DispatchQueueList" model="Model" />
        }
        <partial name="_DispatchActivePanel" model="Model" />
    </div>
</section>
