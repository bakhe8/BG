@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Dispatch.WorkspaceModel
@{
    ViewData["Title"] = T["DispatchWorkspace_PageTitle"];
    var headerModel = new SurfaceHeaderModel(
        T["NavDispatch"].Value,
        T["DispatchWorkspace_Heading"].Value,
        null);
    var noEligibleActorModel = new SurfaceMessageCardModel(
        T["DispatchWorkspace_NoEligibleActor"].Value,
        T["DispatchWorkspace_NoEligibleActorBody"].Value);
    var emptyWorkspaceModel = new SurfaceMessageCardModel(
        T["DispatchWorkspace_ItemsTitle"].Value,
        T["DispatchWorkspace_Empty"].Value);
    var hasDispatchItems = Model.Snapshot.Items.Count > 0 || Model.Snapshot.PendingDeliveryItems.Count > 0;
    var showQueueList = Model.Snapshot.Items.Count + Model.Snapshot.PendingDeliveryItems.Count > 1;

    ViewData["HideSupportRail"] = true;
    ViewData["HideDetailDrawer"] = true;
}

<section class="section-shell dispatch-surface">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice-banner is-success">@Model.StatusMessage</div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <partial name="/Pages/Shared/_SurfaceHeader.cshtml" model="headerModel" />

    @if (!Model.Snapshot.HasEligibleActor || Model.Snapshot.ActiveActor is null)
    {
        <partial name="/Pages/Shared/_SurfaceMessageCard.cshtml" model="noEligibleActorModel" />
    }
    else if (!hasDispatchItems)
    {
        <partial name="/Pages/Shared/_SurfaceMessageCard.cshtml" model="emptyWorkspaceModel" />
    }
    else
    {
        @if (showQueueList)
        {
            <div class="dispatch-surface-grid">
                <partial name="_DispatchQueueList" model="Model" />
                <partial name="_DispatchActivePanel" model="Model" />
            </div>
        }
        else
        {
            <div class="dispatch-surface-solo">
                <partial name="_DispatchActivePanel" model="Model" />
            </div>
        }
    }
</section>
