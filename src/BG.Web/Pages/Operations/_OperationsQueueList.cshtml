@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Operations.QueueModel

<aside class="bg_unified_stage_sidebar">
    <div class="bg_unified_stage_sidebar_header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h6 class="fw-bold text-dark mb-0">@T["OperationsQueue_ItemsTitle"]</h6>
                <div class="xx-small text-muted opacity-75">@T["OperationsQueue_ItemsSummary"]</div>
            </div>
            <div class="badge bg-light text-dark border rounded-pill">@Model.Snapshot.Items.Count</div>
        </div>
    </div>

    <div class="bg_unified_stage_sidebar_list">
        @if (Model.Snapshot.Items.Count == 0)
        {
            <div class="p-5 text-center opacity-50">
                <i class="bi bi-inbox fs-2 mb-3 d-block"></i>
                <p class="small fw-bold">@T["OperationsQueue_Empty"]</p>
            </div>
        }
        else
        {
            @foreach (var item in Model.Snapshot.Items)
            {
                var isActive = Model.SelectedItemId == item.Id;
                var itemModel = new SurfaceUnifiedLink(
                    "/Operations/Queue",
                    new Dictionary<string, string>(Model.BuildSelectionRoute(item.Id)),
                    item.GuaranteeNumber,
                    T[item.ScenarioTitleResourceKey].Value,
                    item.CapturedByDisplayName ?? "System",
                    T[item.StatusResourceKey].Value,
                    item.CapturedAtUtc.ToLocalTime().ToString("MM/dd HH:mm"),
                    item.BankReference,
                    isActive);
                <partial name="/Pages/Shared/_SurfaceQueueItemLink.cshtml" model="itemModel" />
            }
        }
    </div>

    @if (Model.Snapshot.ItemsPage.TotalPageCount > 1)
    {
        <div class="p-2 border-top bg-white">
            @{
                var paginationModel = new SurfacePaginationModel(
                    "/Operations/Queue",
                    Model.Snapshot.ItemsPage.HasPreviousPage ? new Dictionary<string, string>(Model.BuildPageRoute(Model.Snapshot.ItemsPage.PreviousPageNumber)) : null,
                    Model.Snapshot.ItemsPage.HasNextPage ? new Dictionary<string, string>(Model.BuildPageRoute(Model.Snapshot.ItemsPage.NextPageNumber)) : null,
                    T["Pagination_Previous"].Value,
                    T["Pagination_Next"].Value);
            }
            <partial name="/Pages/Shared/_SurfacePagination.cshtml" model="paginationModel" />
        </div>
    }
</aside>
