@using System.Globalization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Operations.QueueModel

<article class="info-card operations-active-panel">
    @if (Model.ActiveItem is null)
    {
        <div class="request-active-empty">
            <span class="eyebrow">@T["OperationsQueue_OpenItemsTitle"]</span>
            <h2>@T["OperationsQueue_Empty"]</h2>
        </div>
    }
    else
    {
        var item = Model.ActiveItem;
        var primarySuggestion = item.MatchSuggestions.FirstOrDefault(suggestion => !suggestion.IsSelectionBlocked)
                                ?? item.MatchSuggestions.FirstOrDefault();
        var applyBlockedReasonResourceKey = Model.ResolveApplyBlockedReasonResourceKey(item);

        <div class="request-active-header">
            <div>
                <span class="eyebrow">@T["OperationsQueue_CompleteNowTitle"]</span>
                <h2>@item.GuaranteeNumber</h2>
                <p class="compact-copy">@T[item.ScenarioTitleResourceKey]</p>
            </div>
            <span class="status-badge is-active">@T[item.StatusResourceKey]</span>
        </div>

        <div class="request-active-facts">
            <section class="surface-stat">
                <span class="section-caption">@T["OperationsQueue_RecommendedLaneLabel"]</span>
                <strong>@T[item.RecommendedLaneResourceKey]</strong>
            </section>
            <section class="surface-stat">
                <span class="section-caption">@T["OperationsQueue_DocumentLabel"]</span>
                <strong>@item.FileName</strong>
            </section>
            <section class="surface-stat">
                <span class="section-caption">@T["OperationsQueue_CreatedAtLabel"]</span>
                <strong>@item.CapturedAtUtc.ToLocalTime().ToString("g", CultureInfo.CurrentCulture)</strong>
            </section>
            <section class="surface-stat">
                <span class="section-caption">@T["OperationsQueue_BankReferenceLabel"]</span>
                <strong>@(string.IsNullOrWhiteSpace(item.BankReference) ? T["OperationsQueue_NotAvailable"].Value : item.BankReference)</strong>
            </section>
            @if (item.CompletedAtUtc.HasValue)
            {
                <section class="surface-stat">
                    <span class="section-caption">@T["OperationsQueue_CompletedAtLabel"]</span>
                    <strong>@item.CompletedAtUtc.Value.ToLocalTime().ToString("g", CultureInfo.CurrentCulture)</strong>
                </section>
            }
        </div>

        <div class="surface-action-stack">
            @if (primarySuggestion is not null)
            {
                <section class="surface-action-zone is-secondary operations-evidence-card">
                    <div class="surface-action-header">
                        <span class="surface-action-kicker">@T["OperationsQueue_SystemMatchesTitle"]</span>
                        <h3 class="surface-action-title">@T[primarySuggestion.RequestTypeResourceKey]</h3>
                    </div>

                    <div class="pill-list">
                        <span class="pill">@T[primarySuggestion.StatusResourceKey]</span>
                        <span class="pill">@T[primarySuggestion.ConfidenceResourceKey]</span>
                        @if (primarySuggestion.SubmittedToBankAtUtc.HasValue)
                        {
                            <span class="pill">
                                @T["OperationsQueue_SubmittedToBankLabel"]:
                                @primarySuggestion.SubmittedToBankAtUtc.Value.ToLocalTime().ToString("d", CultureInfo.CurrentCulture)
                            </span>
                        }
                        @if (!string.IsNullOrWhiteSpace(primarySuggestion.OutgoingReferenceNumber))
                        {
                            <span class="pill">
                                @T["OperationsQueue_OutgoingReferenceLabel"]:
                                @primarySuggestion.OutgoingReferenceNumber
                            </span>
                        }
                        @if (primarySuggestion.RequestDocumentForm is not null)
                        {
                            <span class="pill">@T[primarySuggestion.RequestDocumentForm.TitleResourceKey]</span>
                            <span class="pill">@T[primarySuggestion.RequestDocumentForm.BankResourceKey]</span>
                        }
                        @if (primarySuggestion.IsSelectionBlocked && !string.IsNullOrWhiteSpace(primarySuggestion.BlockingReasonResourceKey))
                        {
                            <span class="pill is-warning">@T["OperationsQueue_BlockedSuggestionLabel"]</span>
                            <span class="pill is-warning">@T[primarySuggestion.BlockingReasonResourceKey]</span>
                        }
                        @foreach (var reason in primarySuggestion.ReasonResourceKeys)
                        {
                            <span class="pill">@T[reason]</span>
                        }
                    </div>
                </section>
            }

            @if (item.CompletedAtUtc.HasValue)
            {
                <form method="post" asp-page-handler="ReopenApplied" class="stack-form operations-apply-form surface-action-zone is-danger">
                    <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor!.Id" />
                    <input type="hidden" name="reviewItemId" value="@item.Id" />
                    <input type="hidden" name="item" value="@item.Id" />
                    <input type="hidden" name="page" value="@Model.Snapshot.ItemsPage.PageNumber" />

                    <div class="surface-action-header">
                        <span class="surface-action-kicker">@T["SurfaceAction_CurrentActionLabel"]</span>
                        <h3 class="surface-action-title">@T["OperationsQueue_ReopenAction"]</h3>
                    </div>

                    <label class="form-label" for="reopen-note-@item.Id">@T["OperationsQueue_ReopenNoteField"]</label>
                    <textarea id="reopen-note-@item.Id"
                              name="correctionNote"
                              class="form-control"
                              rows="3"></textarea>

                    <div class="action-row">
                        <button type="submit" class="btn btn-outline-danger action-button">
                            @T["OperationsQueue_ReopenAction"]
                        </button>
                    </div>
                </form>
            }
            else if (!item.SupportsRequestMatching)
            {
                <div class="surface-action-zone is-blocked">
                    <p class="surface-action-copy mb-0">@T["OperationsQueue_NoApplyActionSummary"]</p>
                </div>
            }
            else if (item.MatchSuggestions.Count == 0)
            {
                <div class="surface-action-zone is-blocked">
                    <p class="surface-action-copy mb-0">@T["OperationsQueue_NoMatchSuggestions"]</p>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(applyBlockedReasonResourceKey))
            {
                <div class="surface-action-zone is-blocked">
                    <p class="surface-action-copy mb-0">@T[applyBlockedReasonResourceKey]</p>
                </div>
            }
            else
            {
                <form method="post" asp-page-handler="Apply" class="stack-form operations-apply-form surface-action-zone is-primary">
                    <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor!.Id" />
                    <input type="hidden" name="reviewItemId" value="@item.Id" />
                    <input type="hidden" name="item" value="@item.Id" />
                    <input type="hidden" name="page" value="@Model.Snapshot.ItemsPage.PageNumber" />

                    <div class="surface-action-header">
                        <span class="surface-action-kicker">@T["SurfaceAction_CurrentActionLabel"]</span>
                        <h3 class="surface-action-title">@T["OperationsQueue_ApplyResponseAction"]</h3>
                    </div>

                    <label class="form-label" for="request-@item.Id">@T["OperationsQueue_RequestMatchField"]</label>
                    <select id="request-@item.Id" name="requestId" class="form-control">
                        @foreach (var suggestion in Model.GetSelectionSuggestions(item))
                        {
                            <option value="@suggestion.RequestId" disabled="@suggestion.IsSelectionBlocked">@Model.ResolveSuggestionOptionLabel(suggestion)</option>
                        }
                    </select>

                    @if (item.RequiresConfirmedExpiryDate)
                    {
                        <label class="form-label" for="expiry-@item.Id">@T["OperationsQueue_ConfirmedExpiryDateField"]</label>
                        <input id="expiry-@item.Id"
                               name="confirmedExpiryDate"
                               class="form-control"
                               type="date"
                               value="@item.SuggestedConfirmedExpiryDate" />
                    }

                    @if (item.RequiresConfirmedAmount)
                    {
                        <label class="form-label" for="amount-@item.Id">@T["OperationsQueue_ConfirmedAmountField"]</label>
                        <input id="amount-@item.Id"
                               name="confirmedAmount"
                               class="form-control"
                               inputmode="decimal"
                               value="@item.SuggestedConfirmedAmount" />
                    }

                    <label class="form-label" for="note-@item.Id">@T["OperationsQueue_ConfirmationNoteField"]</label>
                    <textarea id="note-@item.Id"
                              name="note"
                              class="form-control"
                              rows="3">@item.SuggestedStatusStatement</textarea>

                    <div class="action-row">
                        <button type="submit" class="btn btn-primary action-button">
                            @T["OperationsQueue_ApplyResponseAction"]
                        </button>
                    </div>
                </form>
            }
        </div>
    }
</article>
