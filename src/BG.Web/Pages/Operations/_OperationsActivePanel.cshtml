@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Operations.QueueModel

@{
    var item = Model.ActiveItem;
    var isApplyBlocked = item != null && item.SupportsRequestMatching && item.MatchSuggestions.Count > 0 && item.MatchSuggestions.All(s => s.IsSelectionBlocked);
    var blockReasonKey = item != null ? item.MatchSuggestions.Select(s => s.BlockingReasonResourceKey).FirstOrDefault(r => !string.IsNullOrWhiteSpace(r)) : null;
    
    decimal parsedAmt = 0;
    var hasValidAmount = item != null && decimal.TryParse(item.SuggestedConfirmedValue, out parsedAmt);
}

<div class="canvas_stage_main">
    @if (item is null)
    {
        <div class="d-flex flex-column align-items-center justify-content-center h-100 opacity-50 p-5 text-center">
            <div class="bg-light rounded-circle p-4 mb-4">
                <i class="bi bi-layout-text-sidebar-reverse fs-1 text-muted"></i>
            </div>
            <h5 class="fw-bold">@T["OperationsQueue_EmptySelectionTitle"]</h5>
            <p class="small text-muted" style="max-width: 320px;">@T["OperationsQueue_EmptySelectionBody"]</p>
        </div>
    }
    else
    {
        @* 1. Inline Toolbar with High-Density Actions *@
        <div class="inline_toolbar">
            <div class="inline_toolbar_title">
                <i class="bi bi-shield-check text-success fs-5"></i>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item text-muted">@T["NavOperationsQueue"]</li>
                        <li class="breadcrumb-item active fw-bold text-dark" aria-current="page">@item.GuaranteeNumber</li>
                    </ol>
                </nav>
            </div>

            @if (!item.CompletedAtUtc.HasValue)
            {
                <form method="post" id="decision-form" class="toolbar_actions">
                    <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor!.Id" />
                    <input type="hidden" name="reviewItemId" value="@item.Id" />

                    @if (!isApplyBlocked)
                    {
                        <button type="submit" formaction="@Url.Page("/Operations/Queue", pageHandler: "Apply")"
                                class="bg-btn bg-btn-primary shadow-green">
                            <i class="bi bi-check2-circle me-1"></i>
                            <span class="fw-bold">@T["OperationsQueue_ApplyResponseAction"]</span>
                        </button>
                    }

                    <button type="submit" formaction="@Url.Page("/Operations/Queue", pageHandler: "Return")"
                            class="bg-btn px-3" style="background-color: #FEF3C7; color: #92400E !important; border: 1px solid #FDE68A;">
                        <i class="bi bi-arrow-left-right me-1"></i>
                        <span class="fw-bold">@T["OperationsQueue_Action_Return"]</span>
                    </button>

                    <button type="submit" formaction="@Url.Page("/Operations/Queue", pageHandler: "Reject")"
                            class="bg-btn px-3" style="background-color: #FEE2E2; color: #991B1B !important; border: 1px solid #FECACA;">
                        <i class="bi bi-x-circle me-1"></i>
                        <span class="fw-bold">@T["OperationsQueue_Action_Reject"]</span>
                    </button>
                </form>
            }
            
            <a asp-page="/Operations/Queue" class="btn-close ms-3" aria-label="Close"></a>
        </div>

        @* 2. Operational Main Content *@
        <div class="flex-grow-1 overflow-auto">
            
            @* Summary: key facts at a glance *@
            <div class="canvas_stage_section">
                <div class="canvas_stage_section_title">@T["OperationsQueue_TabSummary"]</div>
                <div class="d-flex align-items-start gap-4 flex-wrap">
                    <div class="ops-fact-card">
                        <div class="xx-small text-muted text-uppercase fw-bold mb-1">@T["OperationsQueue_Header_Value"]</div>
                        <div class="fw-bold text-dark fs-4 lh-1">SAR @(hasValidAmount ? parsedAmt.ToString("N0") : (item?.SuggestedConfirmedValue ?? "—"))</div>
                    </div>
                    <div class="ops-fact-card">
                        <div class="xx-small text-muted text-uppercase fw-bold mb-1">@T["OperationsQueue_Header_Date"]</div>
                        <div class="fw-bold text-dark fs-5 lh-1">@(string.IsNullOrWhiteSpace(item.SuggestedConfirmedExpiryDate) ? "—" : item.SuggestedConfirmedExpiryDate)</div>
                    </div>
                    <div class="ops-fact-card ms-auto">
                        <div class="xx-small text-muted text-uppercase fw-bold mb-2">@T["OperationsQueue_Header_Status"]</div>
                        <bg-badge class="bg-badge-@(item.StatusResourceKey.Contains("Pending") || item.StatusResourceKey.Contains("Waiting") ? "pending" : "returned")">
                            @T[item.StatusResourceKey]
                        </bg-badge>
                    </div>
                </div>
            </div>

            @* Documents: file and routing *@
            <div class="canvas_stage_section">
                <div class="canvas_stage_section_title">@T["OperationsQueue_TabDocuments"]</div>
                <div class="d-flex gap-3 flex-wrap">
                    <div class="ops-doc-card">
                        <div class="xx-small text-muted text-uppercase fw-bold mb-2">@T["OperationsQueue_DocumentLabel"]</div>
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-file-earmark-pdf text-danger" style="font-size: 1.4rem;"></i>
                            <span class="fw-semibold small text-dark">@item.FileName</span>
                        </div>
                    </div>
                    <div class="ops-doc-card">
                        <div class="xx-small text-muted text-uppercase fw-bold mb-2">@T["OperationsQueue_RecommendedLaneLabel"]</div>
                        <bg-badge class="bg-badge-success py-1 px-3">@T[item.RecommendedLaneResourceKey]</bg-badge>
                    </div>
                </div>
            </div>

            @* Bank note *@
            @if (!string.IsNullOrWhiteSpace(item.SuggestedStatusStatement))
            {
                <div class="canvas_stage_section">
                    <div class="canvas_stage_section_title">@T["OperationsQueue_NotesTitle"]</div>
                    <div class="ops-note-block">
                        <i class="bi bi-chat-quote me-2 opacity-50"></i>
                        <span>@item.SuggestedStatusStatement</span>
                    </div>
                </div>
            }

            @* Visual Padding for Scrollable Content *@
            <div class="py-4"></div>
        </div>

        @* 3. Re-open Action (If Completed) *@
        @if (item.CompletedAtUtc.HasValue)
        {
            <div class="bg-sticky-action-bar border-top-0 pt-0">
                <form method="post" id="reopen-form" class="m-0 bg-light rounded-3 p-3 border">
                    <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor!.Id" />
                    <input type="hidden" name="reviewItemId" value="@item.Id" />
                    <div class="d-flex gap-3 align-items-end">
                        <div class="flex-grow-1">
                            <label class="xx-small fw-bold opacity-75 mb-1 text-uppercase">@T["OperationsQueue_ReopenNoteField"]</label>
                            <textarea name="correctionNote" class="form-control rounded-3" rows="1"></textarea>
                        </div>
                        <button type="submit" formaction="@Url.Page("/Operations/Queue", pageHandler: "ReopenApplied")"
                                class="bg-btn px-4 d-flex align-items-center justify-content-center" style="background-color: #FEF3C7; color: #92400E !important; border: 1px solid #FDE68A; height: 42px;">
                            <i class="bi bi-arrow-counterclockwise me-2"></i>
                            <span class="fw-bold">@T["OperationsQueue_ReopenAction"]</span>
                        </button>
                    </div>
                </form>
            </div>
        }
    }
</div>
