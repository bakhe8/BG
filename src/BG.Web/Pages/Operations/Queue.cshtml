@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Operations.QueueModel
@{
    ViewData["Title"] = T["OperationsQueue_PageTitle"];
}

<section class="section-shell">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice-banner is-success">@Model.StatusMessage</div>
    }

    @if (Model.Snapshot.HasEligibleActor && !string.IsNullOrWhiteSpace(Model.Snapshot.ContextNoticeResourceKey))
    {
        <div class="notice-banner is-success">@T[Model.Snapshot.ContextNoticeResourceKey]</div>
    }

    <div class="section-header">
        <span class="eyebrow">@T["NavOperationsQueue"]</span>
        <h1>@T["OperationsQueue_Heading"]</h1>
        <p class="compact-copy">@T["OperationsQueue_Summary"]</p>
    </div>

    @if (!Model.Snapshot.HasEligibleActor || Model.Snapshot.ActiveActor is null)
    {
        <article class="info-card">
            <h2>@T["OperationsQueue_NoEligibleActor"]</h2>
            <p class="compact-copy">@T["OperationsQueue_NoEligibleActorBody"]</p>
        </article>
    }
    else
    {
        <section class="hero-panel intake-hero">
            <div class="hero-copy">
                <span class="eyebrow">@T["OperationsQueue_PrimaryFlow"]</span>
                <h2>@Model.Snapshot.ActiveActor.DisplayName</h2>
                <p>@T["OperationsQueue_QueueSummary"]</p>
            </div>
            <div class="hero-metrics">
                <div class="metric-card">
                    <span>@T["OperationsQueue_MetricOpen"]</span>
                    <strong>@Model.Snapshot.OpenItemsCount</strong>
                </div>
                <div class="metric-card">
                    <span>@T["OperationsQueue_MetricPending"]</span>
                    <strong>@Model.Snapshot.PendingItemsCount</strong>
                </div>
                <div class="metric-card">
                    <span>@T["OperationsQueue_MetricTemplates"]</span>
                    <strong>@Model.Snapshot.WorkflowTemplates.Count</strong>
                </div>
            </div>
        </section>

        <article class="info-card full-span">
            <div class="card-header">
                <div>
                    <h2>@T["OperationsQueue_ActorContextTitle"]</h2>
                    <p class="compact-copy">@T["OperationsQueue_ActorContextSummary"]</p>
                </div>
            </div>

            @if (Model.IsActorContextLocked)
            {
                <div class="pill-list">
                    <span class="pill">@T["WorkspaceShell_CurrentUserScopeNotice"]</span>
                    <span class="pill">@Model.Snapshot.ActiveActor.DisplayName (@Model.Snapshot.ActiveActor.Username)</span>
                </div>
            }
            else
            {
                <form method="get" class="action-row">
                    <input type="hidden" name="page" value="@Model.Snapshot.ItemsPage.PageNumber" />
                    <div>
                        <label class="form-label" for="actor">@T["OperationsQueue_ActorField"]</label>
                        <select id="actor" name="actor" class="form-control">
                            @foreach (var actor in Model.Snapshot.AvailableActors)
                            {
                                <option value="@actor.Id" selected="@(actor.Id == Model.Snapshot.ActiveActor.Id ? "selected" : null)">
                                    @actor.DisplayName (@actor.Username)
                                </option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-outline-primary action-button">@T["OperationsQueue_LoadActorAction"]</button>
                </form>
            }
        </article>

        <div class="baseline-grid">
            <article class="info-card full-span">
                <div class="card-header">
                    <div>
                        <h2>@T["OperationsQueue_OpenItemsTitle"]</h2>
                        <p class="compact-copy">@T["OperationsQueue_OpenItemsSummary"]</p>
                    </div>
                </div>

                @if (Model.Snapshot.Items.Count == 0)
                {
                    <p class="compact-copy">@T["OperationsQueue_Empty"]</p>
                }
                else
                {
                    <div class="stack-list">
                        @foreach (var item in Model.Snapshot.Items)
                        {
                            <article class="entity-card">
                                <div class="entity-header">
                                    <div>
                                        <h3>@item.GuaranteeNumber</h3>
                                        <div class="entity-subtitle">@T[item.ScenarioTitleResourceKey]</div>
                                    </div>
                                    <span class="status-badge is-active">@T[item.StatusResourceKey]</span>
                                </div>

                                <dl class="data-pairs">
                                    <div>
                                        <dt>@T["OperationsQueue_CategoryLabel"]</dt>
                                        <dd>@T[item.CategoryResourceKey]</dd>
                                    </div>
                                    <div>
                                        <dt>@T["OperationsQueue_DocumentLabel"]</dt>
                                        <dd>@item.FileName</dd>
                                    </div>
                                    <div>
                                        <dt>@T["OperationsQueue_BankReferenceLabel"]</dt>
                                        <dd>@(string.IsNullOrWhiteSpace(item.BankReference) ? T["OperationsQueue_NotAvailable"] : item.BankReference)</dd>
                                    </div>
                                    <div>
                                        <dt>@T["OperationsQueue_CreatedAtLabel"]</dt>
                                        <dd>@item.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                                    </div>
                                    <div>
                                        <dt>@T["OperationsQueue_RecommendedLaneLabel"]</dt>
                                        <dd>@T[item.RecommendedLaneResourceKey]</dd>
                                    </div>
                                </dl>

                                <div class="pill-section">
                                    <span class="section-caption">@T["OperationsQueue_CaptureLedgerTitle"]</span>
                                    <div class="pill-list">
                                        <span class="pill">@T["OperationsQueue_CapturedAtLabel"]: @item.CapturedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                        <span class="pill">@T["OperationsQueue_CapturedByLabel"]: @(string.IsNullOrWhiteSpace(item.CapturedByDisplayName) ? T["RequestsWorkspace_LedgerSystemActor"].Value : item.CapturedByDisplayName)</span>
                                        <span class="pill">@T["OperationsQueue_CaptureChannelLabel"]: @T[item.CaptureChannelResourceKey]</span>
                                        @if (!string.IsNullOrWhiteSpace(item.SourceSystemName))
                                        {
                                            <span class="pill">@T["OperationsQueue_SourceSystemLabel"]: @item.SourceSystemName</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(item.SourceReference))
                                        {
                                            <span class="pill">@T["OperationsQueue_SourceReferenceLabel"]: @item.SourceReference</span>
                                        }
                                    </div>
                                </div>

                                @if (item.SupportsRequestMatching)
                                {
                                    <div class="pill-section">
                                        <span class="section-caption">@T["OperationsQueue_SystemMatchesTitle"]</span>

                                        @if (item.MatchSuggestions.Count == 0)
                                        {
                                            <p class="compact-copy">@T["OperationsQueue_NoMatchSuggestions"]</p>
                                        }
                                        else
                                        {
                                            <div class="workflow-stage-list">
                                                @foreach (var suggestion in item.MatchSuggestions)
                                                {
                                                    <section class="workflow-stage">
                                                        <span class="pipeline-index">@suggestion.Score</span>
                                                        <div>
                                                            <strong>@T[suggestion.RequestTypeResourceKey]</strong>
                                                            <p class="compact-copy">
                                                                @T[suggestion.StatusResourceKey] · @T[suggestion.ConfidenceResourceKey]
                                                            </p>
                                                            <div class="pill-list">
                                                                @if (suggestion.SubmittedToBankAtUtc.HasValue)
                                                                {
                                                                    <span class="pill">
                                                                        @T["OperationsQueue_SubmittedToBankLabel"]:
                                                                        @suggestion.SubmittedToBankAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd")
                                                                    </span>
                                                                }
                                                                @if (!string.IsNullOrWhiteSpace(suggestion.OutgoingReferenceNumber))
                                                                {
                                                                    <span class="pill">
                                                                        @T["OperationsQueue_OutgoingReferenceLabel"]:
                                                                        @suggestion.OutgoingReferenceNumber
                                                                    </span>
                                                                }
                                                                @foreach (var reason in suggestion.ReasonResourceKeys)
                                                                {
                                                                    <span class="pill">@T[reason]</span>
                                                                }
                                                            </div>
                                                        </div>
                                                    </section>
                                                }
                                            </div>
                                        }
                                    </div>

                                    @if (item.MatchSuggestions.Count > 0)
                                    {
                                        var requiresConfirmedExpiry = item.RequiresConfirmedExpiryDate;
                                        var requiresConfirmedAmount = item.RequiresConfirmedAmount;

                                        <form method="post" asp-page-handler="Apply" class="stack-form">
                                            <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor.Id" />
                                            <input type="hidden" name="reviewItemId" value="@item.Id" />
                                            <input type="hidden" name="page" value="@Model.Snapshot.ItemsPage.PageNumber" />

                                            <label class="form-label" for="request-@item.Id">@T["OperationsQueue_RequestMatchField"]</label>
                                            <select id="request-@item.Id" name="requestId" class="form-control">
                                                @foreach (var suggestion in item.MatchSuggestions)
                                                {
                                                    var optionText = $"{T[suggestion.RequestTypeResourceKey].Value} - {T[suggestion.StatusResourceKey].Value} ({suggestion.Score})";
                                                    <option value="@suggestion.RequestId">@optionText</option>
                                                }
                                            </select>

                                            @if (requiresConfirmedExpiry)
                                            {
                                                <label class="form-label" for="expiry-@item.Id">@T["OperationsQueue_ConfirmedExpiryDateField"]</label>
                                                <input id="expiry-@item.Id"
                                                       name="confirmedExpiryDate"
                                                       class="form-control"
                                                       type="date"
                                                       value="@item.SuggestedConfirmedExpiryDate" />
                                            }

                                            @if (requiresConfirmedAmount)
                                            {
                                                <label class="form-label" for="amount-@item.Id">@T["OperationsQueue_ConfirmedAmountField"]</label>
                                                <input id="amount-@item.Id"
                                                       name="confirmedAmount"
                                                       class="form-control"
                                                       inputmode="decimal"
                                                       value="@item.SuggestedConfirmedAmount" />
                                            }

                                            <label class="form-label" for="note-@item.Id">@T["OperationsQueue_ConfirmationNoteField"]</label>
                                            <textarea id="note-@item.Id"
                                                      name="note"
                                                      class="form-control"
                                                      rows="3">@item.SuggestedStatusStatement</textarea>

                                            <div class="action-row">
                                                <button type="submit" class="btn btn-primary action-button">
                                                    @T["OperationsQueue_ApplyResponseAction"]
                                                </button>
                                            </div>
                                        </form>
                                    }
                                }
                            </article>
                        }
                    </div>
                }
            </article>

            <article class="info-card full-span">
                <div class="card-header">
                    <div>
                        <h2>@T["OperationsQueue_WorkflowTemplatesTitle"]</h2>
                        <p class="compact-copy">@T["OperationsQueue_WorkflowTemplatesSummary"]</p>
                    </div>
                </div>

                <div class="workflow-grid">
                    @foreach (var template in Model.Snapshot.WorkflowTemplates)
                    {
                        <article class="workflow-card">
                            <div class="workflow-card-header">
                                <h3>@T[template.TitleResourceKey]</h3>
                                <span class="pill">@template.Stages.Count @T["OperationsQueue_LevelsSuffix"]</span>
                            </div>
                            <p class="compact-copy">@T[template.SummaryResourceKey]</p>
                            <div class="workflow-stage-list">
                                @foreach (var stage in template.Stages)
                                {
                                    var stageTitle = !string.IsNullOrWhiteSpace(stage.TitleText)
                                        ? stage.TitleText
                                        : T[stage.TitleResourceKey!].Value;
                                    var stageSummary = !string.IsNullOrWhiteSpace(stage.SummaryText)
                                        ? stage.SummaryText
                                        : string.IsNullOrWhiteSpace(stage.SummaryResourceKey)
                                            ? T["OperationsQueue_NotAvailable"].Value
                                            : T[stage.SummaryResourceKey].Value;
                                    <section class="workflow-stage">
                                        <span class="pipeline-index">@stage.Level</span>
                                        <div>
                                            <strong>@stageTitle</strong>
                                            <p class="compact-copy">@stageSummary</p>
                                            @if (!string.IsNullOrWhiteSpace(stage.AssignedRoleName))
                                            {
                                                <div class="workflow-signature-meta">
                                                    <span class="pill">@stage.AssignedRoleName</span>
                                                </div>
                                            }
                                        </div>
                                    </section>
                                }
                            </div>
                        </article>
                    }
                </div>

                @if (Model.Snapshot.ItemsPage.TotalPageCount > 1)
                {
                    var pageInfo = Model.Snapshot.ItemsPage;

                    <div class="action-row">
                        <span class="compact-copy">@T["Pagination_PageSummary", pageInfo.PageNumber, pageInfo.TotalPageCount, pageInfo.TotalItemCount]</span>
                        <div class="action-row">
                            @if (pageInfo.HasPreviousPage)
                            {
                                <a class="btn btn-outline-primary action-button"
                                   asp-page="/Operations/Queue"
                                   asp-all-route-data="Model.BuildPageRoute(pageInfo.PreviousPageNumber)">
                                    @T["Pagination_Previous"]
                                </a>
                            }

                            @if (pageInfo.HasNextPage)
                            {
                                <a class="btn btn-outline-primary action-button"
                                   asp-page="/Operations/Queue"
                                   asp-all-route-data="Model.BuildPageRoute(pageInfo.NextPageNumber)">
                                    @T["Pagination_Next"]
                                </a>
                            }
                        </div>
                    </div>
                }
            </article>
        </div>
    }
</section>
