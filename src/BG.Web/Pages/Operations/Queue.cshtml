@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Operations.QueueModel
@{
    ViewData["Title"] = T["OperationsQueue_PageTitle"];
    var headerPills = Model.Snapshot.HasEligibleActor && Model.Snapshot.ActiveActor is not null
        ? new[]
        {
            Model.Snapshot.ActiveActor.DisplayName,
            T["Pagination_PageSummary", Model.Snapshot.ItemsPage.PageNumber, Model.Snapshot.ItemsPage.TotalPageCount, Model.Snapshot.ItemsPage.TotalItemCount].Value
        }
        : Array.Empty<string>();
    var headerModel = new SurfaceHeaderModel(
        T["NavOperationsQueue"].Value,
        T["OperationsQueue_Heading"].Value,
        T["OperationsQueue_ActionSummary"].Value,
        headerPills,
        "is-split");
    var statStripModel = new SurfaceStatStripModel(
        new[]
        {
            new SurfaceStatItem(T["OperationsQueue_MetricOpen"].Value, Model.Snapshot.OpenItemsCount),
            new SurfaceStatItem(T["OperationsQueue_MetricPending"].Value, Model.Snapshot.PendingItemsCount),
            new SurfaceStatItem(T["OperationsReviewStatus_Routed"].Value, Model.Snapshot.RoutedItemsCount),
            new SurfaceStatItem(T["OperationsQueue_OpenItemsTitle"].Value, Model.Snapshot.ItemsPage.TotalItemCount)
        });
    var noEligibleActorModel = new SurfaceMessageCardModel(
        T["OperationsQueue_NoEligibleActor"].Value,
        T["OperationsQueue_NoEligibleActorBody"].Value);
}

<section class="section-shell operations-surface">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice-banner is-success">@Model.StatusMessage</div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    @if (Model.Snapshot.HasEligibleActor && !string.IsNullOrWhiteSpace(Model.Snapshot.ContextNoticeResourceKey))
    {
        <div class="notice-banner is-success">@T[Model.Snapshot.ContextNoticeResourceKey]</div>
    }

    <partial name="/Pages/Shared/_SurfaceHeader.cshtml" model="headerModel" />

    @if (!Model.Snapshot.HasEligibleActor || Model.Snapshot.ActiveActor is null)
    {
        <partial name="/Pages/Shared/_SurfaceMessageCard.cshtml" model="noEligibleActorModel" />
    }
    else
    {
        <partial name="/Pages/Shared/_SurfaceStatStrip.cshtml" model="statStripModel" />

        <div class="operations-surface-grid">
            <partial name="_OperationsQueueList" model="Model" />
            <partial name="_OperationsActivePanel" model="Model" />
        </div>
    }
</section>

@section SupportRail
{
    @if (Model.Snapshot.HasEligibleActor && Model.Snapshot.ActiveActor is not null)
    {
        <partial name="_OperationsSupportRail" model="Model" />
    }
}

@section DetailDrawer
{
    <partial name="_OperationsDetailDrawer" model="Model" />
}
