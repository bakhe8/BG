@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Approvals.QueueModel
@{
    string BuildInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "BG";
        }

        var initials = new List<char>(2);
        foreach (var part in value.Split(' ', StringSplitOptions.RemoveEmptyEntries))
        {
            initials.Add(char.ToUpperInvariant(part[0]));
            if (initials.Count == 2)
            {
                break;
            }
        }

        return initials.Count == 0 ? "BG" : new string(initials.ToArray());
    }
}

@if (Model.ActiveItem is null)
{
    <article class="bg-card shadow-sm p-5 text-center">
        <div class="py-5">
            <i class="bi bi-journal-text fs-1 text-muted opacity-25 d-block mb-3"></i>
            <h2 class="fw-bold text-dark">@T["ApprovalQueue_Empty"]</h2>
            <p class="text-secondary">@T["ApprovalQueue_ItemsSummary"]</p>
        </div>
    </article>
}
else
{
    var item = Model.ActiveItem;
    var stageTitle = Model.ResolveStageTitle(item);
    var requestedChange = Model.ResolveRequestedChange(item);
    var isBlocked = item.Governance.IsDecisionBlocked && !string.IsNullOrWhiteSpace(item.Governance.ReasonResourceKey);
    var guaranteeCategoryTitle = T[item.GuaranteeCategoryResourceKey].Value;
    var submittedAt = item.SubmittedAtUtc.ToLocalTime().ToString("g", System.Globalization.CultureInfo.CurrentCulture);
    var activeActorName = Model.Snapshot.ActiveActor?.DisplayName ?? T["ApprovalQueue_CurrentUserLabel"].Value;
    var activeActorInitials = BuildInitials(activeActorName);
    var dossierRoute = Model.BuildDossierRoute(item.RequestId);

    <article class="approvals-active-panel h-100 d-flex flex-column bg-white border rounded-4 overflow-hidden shadow-sm">
        @* 1. Institutional Header *@
        <div class="p-4 border-bottom bg-white">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="d-flex align-items-center gap-3">
                    <span class="badge bg-light text-dark border px-3 py-2 rounded-pill fw-bold">@item.GuaranteeNumber</span>
                    <bg-badge class="bg-badge-pending">@T[item.StatusResourceKey]</bg-badge>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <a asp-page="/Approvals/Dossier" asp-all-route-data="dossierRoute"
                       class="bg-btn x-small px-3 py-2">
                        <i class="bi bi-folder2-open me-1"></i>@T["ApprovalQueue_ViewDossierAction"]
                    </a>
                    <button type="button" class="btn-close" aria-label="Close"></button>
                </div>
            </div>
            <h3 class="fw-bold text-dark mb-2">@stageTitle</h3>
            <div class="d-flex align-items-center gap-2 text-muted x-small text-uppercase fw-bold">
                <i class="bi bi-person-circle"></i>
                <span>@item.RequesterDisplayName</span>
                <span class="mx-1">·</span>
                <i class="bi bi-calendar3"></i>
                <span>@submittedAt</span>
            </div>
        </div>

        @* 2. Scrollable Work Surface *@
        <div class="flex-grow-1 overflow-auto p-4">
            
            @* Primary Metrics Grid *@
            <div class="row g-4 mb-5">
                <div class="col-6">
                    <div class="bg-light p-4 rounded-4 border-0">
                        <div class="bg-grid-label mb-2">@T["ApprovalQueue_ApplicationSummaryTitle"]</div>
                        <div class="bg-grid-value fs-5">@T[item.RequestTypeResourceKey]</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="bg-light p-4 rounded-4 border-0">
                        <div class="bg-grid-label mb-2">@T["IntakeField_GuaranteeCategory"]</div>
                        <div class="bg-grid-value fs-5">@guaranteeCategoryTitle</div>
                    </div>
                </div>
            </div>

            @if (requestedChange != "-")
            {
                <div class="bg-light p-4 rounded-4 border-0 mb-5">
                    <div class="bg-grid-label mb-2">@T["RequestsWorkspace_RequestedChangeTitle"]</div>
                    <div class="bg-grid-value fs-4 text-brand-green">@requestedChange</div>
                </div>
            }

            <div class="mb-4">
                <label class="section-caption x-small mb-3">@T["ApprovalQueue_CommentsTitle"]</label>
                <div class="d-flex gap-3 align-items-start p-3 bg-light rounded-4">
                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-brand-green text-white fw-bold"
                            style="width: 32px; height: 32px;"
                            aria-hidden="true">
                        @activeActorInitials
                    </span>
                    <div class="flex-grow-1">
                        <div class="x-small fw-bold">@activeActorName</div>
                        <textarea id="decision-comment" name="note"
                                    class="form-control border-0 bg-transparent mt-2 p-0"
                                    rows="3"
                                    placeholder="@T["ApprovalQueue_CommentPlaceholder"]"
                                    disabled="@isBlocked"></textarea>
                    </div>
                </div>
            </div>
        </div>

        @* 3. Institutional Action Bar *@
        <div class="bg-sticky-action-bar">
            <form method="post" id="approval-decision-form" class="m-0">
                <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor!.Id" />
                <input type="hidden" name="requestId" value="@item.RequestId" />
                <input type="hidden" name="request" value="@item.RequestId" />
                
                @if (isBlocked)
                {
                    <div class="alert alert-danger x-small mb-3 py-2 border-0 opacity-75">
                        <i class="bi bi-exclamation-octagon me-2"></i>@T[item.Governance.ReasonResourceKey!]
                    </div>
                }

                <div class="d-flex gap-3">
                    <button type="submit" formaction="/Approvals/Queue?handler=Approve" 
                            class="bg-btn bg-btn-primary flex-grow-1 py-3 shadow-sm" disabled="@isBlocked">
                        <i class="bi bi-check2-circle fs-5"></i>
                        <span>@T["ApprovalQueue_ApproveAction"]</span>
                    </button>
                    
                    <button type="submit" formaction="/Approvals/Queue?handler=Return" 
                            class="bg-btn flex-grow-1 py-3" style="background-color: #FEF3C7; color: #92400E !important; border: 1px solid #FDE68A;" disabled="@isBlocked">
                        <i class="bi bi-arrow-left-right fs-5"></i>
                        <span>@T["ApprovalQueue_ReturnAction"]</span>
                    </button>

                    <button type="submit" formaction="/Approvals/Queue?handler=Reject" 
                            class="bg-btn flex-grow-1 py-3" style="background-color: #FEE2E2; color: #991B1B !important; border: 1px solid #FECACA;" disabled="@isBlocked">
                        <i class="bi bi-x-circle fs-5"></i>
                        <span>@T["ApprovalQueue_RejectAction"]</span>
                    </button>
                </div>
            </form>
        </div>
    </article>
}
