@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Approvals.QueueModel

@if (Model.ActiveItem is null)
{
    <article class="bg-card shadow-sm p-5 text-center">
        <div class="py-5">
            <i class="bi bi-journal-text fs-1 text-muted opacity-25 d-block mb-3"></i>
            <h2 class="fw-bold text-dark">@T["ApprovalQueue_Empty"]</h2>
            <p class="text-secondary">@T["ApprovalQueue_ItemsSummary"]</p>
        </div>
    </article>
}
else
{
    var item = Model.ActiveItem;
    var stageTitle = Model.ResolveStageTitle(item);
    var requestedChange = Model.ResolveRequestedChange(item);
    var isBlocked = item.Governance.IsDecisionBlocked && !string.IsNullOrWhiteSpace(item.Governance.ReasonResourceKey);

    <div class="mb-4">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h2 class="fw-bold text-dark m-0">Executive Dossier: #@item.GuaranteeNumber | @item.RequesterDisplayName | @T[item.GuaranteeCategoryResourceKey]</h2>
            <span class="text-brand-green fw-bold">ملف تنفيذي</span>
        </div>
        <bg-badge variant="warning" class="small">PENDING MY APPROVAL - @T[item.StatusResourceKey]</bg-badge>
        <span class="x-small text-muted ms-2">Metadata · @stageTitle · @item.SubmittedAtUtc.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</span>
    </div>

    <!-- 3-Column Dossier Layout -->
    <div class="bg-surface-grid-3">
        
        <!-- Column 1: Workflow Timeline -->
        <article class="bg-card-premium">
            <label class="section-caption x-small mb-4">Workflow Timeline</label>
            <div class="bg-timeline">
                @foreach (var signature in item.PriorSignatures)
                {
                    <div class="bg-timeline-item completed">
                        <div class="bg-timeline-icon"><i class="bi bi-check-lg"></i></div>
                        <div class="bg-timeline-content">
                            <div class="bg-timeline-title">@signature.StageTitle</div>
                            <div class="bg-timeline-meta">By: @signature.ActorDisplayName</div>
                            <div class="bg-timeline-meta">@signature.ActedAtUtc.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</div>
                        </div>
                    </div>
                }
                
                <div class="bg-timeline-item active">
                    <div class="bg-timeline-icon"></div>
                    <div class="bg-timeline-content">
                        <div class="bg-timeline-title">@stageTitle</div>
                        <div class="bg-timeline-meta">Active Step: Awaiting Your Review</div>
                        <div class="bg-timeline-meta"><i class="bi bi-person-circle me-1"></i>Current User</div>
                    </div>
                </div>
            </div>
        </article>

        <!-- Column 2: Dossier Details -->
        <article class="bg-card-premium">
            <label class="section-caption x-small mb-4">Dossier Details</label>
            
            <div class="mb-4">
                <div class="p-3 bg-light rounded-4 border-light mb-3">
                    <div class="small fw-bold text-dark mb-1">Application Summary</div>
                    <div class="x-small text-secondary">@T[item.RequestTypeResourceKey] | @requestedChange</div>
                </div>

                <div class="list-group list-group-flush border-top border-bottom">
                    <a href="#" class="list-group-item list-group-item-action border-0 px-0 d-flex justify-content-between align-items-center py-3">
                        <span class="small fw-bold">Endorsements <bg-badge variant="secondary" class="ms-1 x-small">2</bg-badge></span>
                        <i class="bi bi-chevron-right text-muted small"></i>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action border-0 px-0 d-flex justify-content-between align-items-center py-3">
                        <span class="small fw-bold">CV</span>
                        <i class="bi bi-chevron-right text-muted small"></i>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action border-0 px-0 d-flex justify-content-between align-items-center py-3">
                        <span class="small fw-bold">Publications</span>
                        <i class="bi bi-chevron-right text-muted small"></i>
                    </a>
                </div>
            </div>
            
            @if (isBlocked)
            {
                <div class="alert alert-danger rounded-4 border-0 p-3 mt-4">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-exclamation-octagon-fill fs-4 me-2"></i>
                        <strong class="small">Governance Block</strong>
                    </div>
                    <p class="x-small mb-0 opacity-75">@T[item.Governance.ReasonResourceKey!]</p>
                </div>
            }
        </article>

        <!-- Column 3: Actions & Checklist -->
        <article class="bg-card-premium">
            <form method="post" class="stack-form h-100 d-flex flex-column">
                <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor!.Id" />
                <input type="hidden" name="requestId" value="@item.RequestId" />
                <input type="hidden" name="request" value="@item.RequestId" />
                
                <div class="d-flex flex-column gap-2 mb-4">
                    <bg-button variant="success" class="w-100 py-3 rounded-4" formaction="/Approvals/Queue?handler=Approve" type="submit" disabled="@isBlocked">
                        <i class="bi bi-check-lg me-2"></i>APPROVE
                    </bg-button>
                    
                    <bg-button variant="warning" class="w-100 py-3 rounded-4" formaction="/Approvals/Queue?handler=Return" type="submit" disabled="@isBlocked">
                        <i class="bi bi-pencil-square me-2"></i>REQUEST REVISION
                    </bg-button>

                    <bg-button variant="light" class="w-100 py-3 rounded-4" formaction="/Approvals/Queue?handler=Reject" type="submit" disabled="@isBlocked">
                        <i class="bi bi-x-lg me-2"></i>REJECT
                    </bg-button>
                </div>

                <div class="mb-4">
                    <label class="section-caption x-small mb-3">Comments</label>
                    <div class="d-flex gap-3 mb-3">
                        <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-brand-green text-white fw-bold"
                              style="width: 32px; height: 32px;"
                              aria-hidden="true">
                            SA
                        </span>
                        <div class="flex-grow-1">
                            <div class="x-small fw-bold">Dr. Sarah Ahmed</div>
                            <div class="x-small text-muted">Chief Medical Officer</div>
                        </div>
                    </div>
                    <textarea name="note" class="form-control x-small" rows="2" placeholder="Add a comment..." disabled="@isBlocked"></textarea>
                </div>

                <div class="mt-auto">
                    <label class="section-caption x-small mb-3">Approval checklist</label>
                    <div class="d-flex flex-column gap-2">
                        <div class="form-check x-small">
                            <input class="form-check-input" type="checkbox" checked id="chk1">
                            <label class="form-check-label" for="chk1">Approval checklist</label>
                        </div>
                        <div class="form-check x-small">
                            <input class="form-check-input" type="checkbox" id="chk2">
                            <label class="form-check-label" for="chk2">Approval checklist</label>
                        </div>
                        <div class="form-check x-small">
                            <input class="form-check-input" type="checkbox" id="chk3">
                            <label class="form-check-label" for="chk3">Approval reammentd</label>
                        </div>
                    </div>
                </div>
            </form>
        </article>
    </div>
}
