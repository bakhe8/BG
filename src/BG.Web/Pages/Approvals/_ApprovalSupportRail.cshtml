@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Approvals.QueueModel
@{
    var actorContextModel = new ActorContextPanelModel(
        T["ApprovalQueue_ActorContextTitle"].Value,
        null,
        Model.IsActorContextLocked ? ActorContextPanelMode.LockedPills : ActorContextPanelMode.SelectorForm,
        "bg-card shadow-sm")
    {
        Pills = Model.IsActorContextLocked
            ? new[]
            {
                T["WorkspaceShell_CurrentUserScopeNotice"].Value,
                $"{Model.Snapshot.ActiveActor!.DisplayName} ({Model.Snapshot.ActiveActor.Username})"
            }
            : Array.Empty<string>(),
        FormAction = Url.Page("/Approvals/Queue"),
        ActorFieldLabel = T["ApprovalQueue_ActorField"].Value,
        SubmitLabel = T["ApprovalQueue_LoadActorAction"].Value,
        HiddenFields = new SurfaceHiddenFieldModel[]
        {
            new("page", Model.Snapshot.ItemsPage.PageNumber.ToString()),
            new("request", Model.ActiveItem?.RequestId.ToString())
        },
        Options = Model.Snapshot.AvailableActors
            .Select(actor => new ActorContextOptionModel(
                actor.Id.ToString(),
                $"{actor.DisplayName} ({actor.Username})",
                actor.Id == Model.Snapshot.ActiveActor!.Id))
            .ToArray()
    };
}

<partial name="/Pages/Shared/_ActorContextPanel.cshtml" model="actorContextModel" />

<details class="bg-card shadow-sm mt-3 p-0 overflow-hidden">
    <summary class="p-3 bg-brand-gold-soft border-bottom cursor-pointer d-flex justify-content-between align-items-center">
        <span class="fw-bold text-dark small"><i class="bi bi-info-circle me-2 text-brand-green"></i>@T["ApprovalQueue_NextAfterDecisionTitle"]</span>
        <i class="bi bi-chevron-down small text-muted"></i>
    </summary>
    <div class="p-4">
        <ul class="list-unstyled small d-flex flex-column gap-3 mb-0">
            <li class="d-flex align-items-start gap-3">
                <bg-badge variant="success" class="rounded-circle p-1" style="width: 20px; height: 20px;"></bg-badge>
                <span>@T["ApprovalQueue_NextAfterApprove"]</span>
            </li>
            <li class="d-flex align-items-start gap-3">
                <bg-badge variant="warning" class="rounded-circle p-1" style="width: 20px; height: 20px;"></bg-badge>
                <span>@T["ApprovalQueue_NextAfterReturn"]</span>
            </li>
            <li class="d-flex align-items-start gap-3">
                <bg-badge variant="error" class="rounded-circle p-1" style="width: 20px; height: 20px;"></bg-badge>
                <span>@T["ApprovalQueue_NextAfterReject"]</span>
            </li>
        </ul>
    </div>
</details>
