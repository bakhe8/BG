@page "{requestId:guid}"
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Approvals.DossierModel
@{
    ViewData["Title"] = T["ApprovalDossier_PageTitle"];

    string ResolveStageTitle(BG.Application.Models.Approvals.ApprovalQueueItemDto item)
    {
        return !string.IsNullOrWhiteSpace(item.CurrentStageTitle)
            ? item.CurrentStageTitle
            : string.IsNullOrWhiteSpace(item.CurrentStageTitleResourceKey)
                ? "-"
                : T[item.CurrentStageTitleResourceKey].Value;
    }

    string ResolveConflictingStageTitle(BG.Application.Models.Approvals.ApprovalQueueItemDto item)
    {
        return !string.IsNullOrWhiteSpace(item.Governance.ConflictingStageTitle)
            ? item.Governance.ConflictingStageTitle
            : string.IsNullOrWhiteSpace(item.Governance.ConflictingStageTitleResourceKey)
                ? item.Governance.ConflictingStageRoleName ?? "-"
                : T[item.Governance.ConflictingStageTitleResourceKey].Value;
    }

    var headerModel = new SurfaceHeaderModel(
        T["NavApprovals"].Value,
        T["ApprovalDossier_Heading"].Value,
        null);
    var noEligibleActorModel = new SurfaceMessageCardModel(
        T["ApprovalQueue_NoEligibleActor"].Value,
        T["ApprovalQueue_NoEligibleActorBody"].Value);
    var actorContextModel = new ActorContextPanelModel(
        T["ApprovalQueue_ActorContextTitle"].Value,
        null,
        Model.IsActorContextLocked ? ActorContextPanelMode.LockedPills : ActorContextPanelMode.SelectorForm,
        "full-span")
    {
        Pills = Model.IsActorContextLocked
            ? new[]
            {
                T["WorkspaceShell_CurrentUserScopeNotice"].Value,
                $"{Model.Snapshot.ActiveActor?.DisplayName} ({Model.Snapshot.ActiveActor?.Username})"
            }
            : Array.Empty<string>(),
        FormAction = Url.Page("/Approvals/Dossier", new { requestId = Model.RequestId }),
        ActorFieldLabel = T["ApprovalQueue_ActorField"].Value,
        SubmitLabel = T["ApprovalQueue_LoadActorAction"].Value,
        HiddenFields = new SurfaceHiddenFieldModel[]
        {
            new("page", (Model.PageNumber ?? 1).ToString())
        },
        Options = Model.Snapshot.AvailableActors
            .Select(actor => new ActorContextOptionModel(
                actor.Id.ToString(),
                $"{actor.DisplayName} ({actor.Username})",
                Model.Snapshot.ActiveActor is not null && actor.Id == Model.Snapshot.ActiveActor.Id))
            .ToArray()
    };
}

<section class="section-shell">
    @if (Model.Snapshot.HasEligibleActor && !string.IsNullOrWhiteSpace(Model.Snapshot.ContextNoticeResourceKey))
    {
        <div class="notice-banner is-success">@T[Model.Snapshot.ContextNoticeResourceKey]</div>
    }

    <partial name="/Pages/Shared/_SurfaceHeader.cshtml" model="headerModel" />

    @if (!Model.Snapshot.HasEligibleActor || Model.Snapshot.ActiveActor is null)
    {
        <partial name="/Pages/Shared/_SurfaceMessageCard.cshtml" model="noEligibleActorModel" />
    }
    else
    {
        <div class="action-row">
            <a class="btn btn-outline-primary action-button"
               asp-page="/Approvals/Queue"
               asp-all-route-data="Model.BuildQueueRoute()">
                @T["ApprovalDossier_BackToQueueAction"]
            </a>
        </div>

        <partial name="/Pages/Shared/_ActorContextPanel.cshtml" model="actorContextModel" />

        @if (Model.Snapshot.Item is null)
        {
            <article class="info-card">
                <h2>@T["ApprovalDossier_UnavailableTitle"]</h2>
                <p class="compact-copy">@T[Model.Snapshot.UnavailableResourceKey ?? "ApprovalDossier_RequestNotAvailable"]</p>
            </article>
        }
        else
        {
            var item = Model.Snapshot.Item;
            var stageTitle = ResolveStageTitle(item);

            <article class="info-card full-span">
                <div class="card-header">
                    <div>
                        <h2>@T["ApprovalDossier_RequestTitle"]</h2>
                    </div>
                </div>

                <div class="entity-header">
                    <div>
                        <h3>@item.GuaranteeNumber</h3>
                        <div class="entity-subtitle">@T[item.RequestTypeResourceKey] · @T[item.GuaranteeCategoryResourceKey]</div>
                    </div>
                    <span class="status-badge is-active">@T[item.StatusResourceKey]</span>
                </div>

                <dl class="data-pairs">
                    <div>
                        <dt>@T["ApprovalQueue_RequesterLabel"]</dt>
                        <dd>@item.RequesterDisplayName</dd>
                    </div>
                    <div>
                        <dt>@T["ApprovalQueue_RequestChannelLabel"]</dt>
                        <dd>@T[item.RequestChannelResourceKey]</dd>
                    </div>
                    <div>
                        <dt>@T["ApprovalQueue_SubmittedAtLabel"]</dt>
                        <dd>@item.SubmittedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                    </div>
                    <div>
                        <dt>@T["ApprovalQueue_CreatedAtLabel"]</dt>
                        <dd>@item.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                    </div>
                    <div>
                        <dt>@T["ApprovalQueue_CurrentStageLabel"]</dt>
                        <dd>@stageTitle</dd>
                    </div>
                    <div>
                        <dt>@T["ApprovalQueue_RoleLabel"]</dt>
                        <dd>@(string.IsNullOrWhiteSpace(item.CurrentStageRoleName) ? "-" : item.CurrentStageRoleName)</dd>
                    </div>
                    <div>
                        <dt>@T["ApprovalQueue_RequestedAmountLabel"]</dt>
                        <dd>@(string.IsNullOrWhiteSpace(item.RequestedAmount) ? "-" : item.RequestedAmount)</dd>
                    </div>
                    <div>
                        <dt>@T["ApprovalQueue_RequestedExpiryDateLabel"]</dt>
                        <dd>@(string.IsNullOrWhiteSpace(item.RequestedExpiryDate) ? "-" : item.RequestedExpiryDate)</dd>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(item.DelegatedByDisplayName))
                    {
                        <div>
                            <dt>@T["ApprovalQueue_DelegatedByLabel"]</dt>
                            <dd>@item.DelegatedByDisplayName</dd>
                        </div>
                    }
                    @if (item.DelegationEndsAtUtc.HasValue)
                    {
                        <div>
                            <dt>@T["ApprovalQueue_DelegationEndsAtLabel"]</dt>
                            <dd>@item.DelegationEndsAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                        </div>
                    }
                </dl>

                <div class="surface-stat-grid">
                    <section class="surface-stat">
                        <span class="section-caption">@T["ApprovalQueue_PriorSignaturesTitle"]</span>
                        <strong>@item.PriorSignatures.Count</strong>
                    </section>
                    <section class="surface-stat">
                        <span class="section-caption">@T["ApprovalQueue_AttachmentsTitle"]</span>
                        <strong>@item.Attachments.Count</strong>
                    </section>
                    <section class="surface-stat">
                        <span class="section-caption">@T["ApprovalQueue_TimelineTitle"]</span>
                        <strong>@item.TimelineEntries.Count</strong>
                    </section>
                </div>

                <div class="pill-section">
                    <span class="section-caption">@T["ApprovalQueue_RequestNotesTitle"]</span>
                    <p class="compact-copy">@(string.IsNullOrWhiteSpace(item.Notes) ? T["ApprovalQueue_NoNotes"].Value : item.Notes)</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(item.DelegationReason))
                {
                    <div class="pill-section">
                        <span class="section-caption">@T["ApprovalQueue_DelegationReasonLabel"]</span>
                        <p class="compact-copy">@item.DelegationReason</p>
                    </div>
                }

                <div class="pill-section">
                    <span class="section-caption">@T["ApprovalDossier_GovernanceTitle"]</span>
                    @if (item.Governance.IsDecisionBlocked && !string.IsNullOrWhiteSpace(item.Governance.ReasonResourceKey))
                    {
                        var conflictingStageTitle = ResolveConflictingStageTitle(item);

                        <div class="notice-banner is-warning">
                            <strong>@T["ApprovalQueue_GovernanceBlockedTitle"]</strong>
                            @if (!string.IsNullOrWhiteSpace(item.Governance.PolicyResourceKey))
                            {
                                <p class="compact-copy">@T["ApprovalQueue_GovernancePolicyLabel"]: @T[item.Governance.PolicyResourceKey]</p>
                            }
                            <p class="compact-copy">@T[item.Governance.ReasonResourceKey]</p>
                            <div class="pill-list">
                                @if (!string.IsNullOrWhiteSpace(conflictingStageTitle))
                                {
                                    <span class="pill">@T["ApprovalQueue_GovernanceBlockedStageLabel"]: @conflictingStageTitle</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.Governance.ConflictingActorDisplayName))
                                {
                                    <span class="pill">@T["ApprovalQueue_GovernanceBlockedActorLabel"]: @item.Governance.ConflictingActorDisplayName</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.Governance.ConflictingResponsibleSignerDisplayName))
                                {
                                    <span class="pill">@T["ApprovalQueue_GovernanceBlockedResponsibleSignerLabel"]: @item.Governance.ConflictingResponsibleSignerDisplayName</span>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="compact-copy">@T["ApprovalDossier_GovernanceClear"]</p>
                    }
                </div>

                <div class="pill-section">
                    <span class="section-caption">@T["ApprovalQueue_PriorSignaturesTitle"]</span>

                    @if (item.PriorSignatures.Count == 0)
                    {
                        <p class="compact-copy">@T["ApprovalQueue_PriorSignaturesEmpty"]</p>
                    }
                    else
                    {
                        <div class="workflow-stage-list">
                            @foreach (var signature in item.PriorSignatures)
                            {
                                var signatureStageTitle = !string.IsNullOrWhiteSpace(signature.StageTitle)
                                    ? signature.StageTitle
                                    : string.IsNullOrWhiteSpace(signature.StageTitleResourceKey)
                                        ? signature.StageRoleName ?? "-"
                                        : T[signature.StageTitleResourceKey].Value;

                                <section class="workflow-stage">
                                    <span class="pipeline-index">@signature.Sequence</span>
                                    <div>
                                        <strong>@signatureStageTitle</strong>
                                        <div class="pill-list">
                                            <span class="pill">@T["ApprovalQueue_PriorSignatureSignedAtLabel"]: @signature.ActedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                            <span class="pill">@T["ApprovalQueue_PriorSignatureActorLabel"]: @(string.IsNullOrWhiteSpace(signature.ActorDisplayName) ? T["RequestsWorkspace_LedgerSystemActor"].Value : signature.ActorDisplayName)</span>
                                            <span class="pill">@T["ApprovalQueue_PriorSignatureResponsibleSignerLabel"]: @(string.IsNullOrWhiteSpace(signature.ResponsibleSignerDisplayName) ? T["RequestsWorkspace_LedgerSystemActor"].Value : signature.ResponsibleSignerDisplayName)</span>
                                            @if (signature.WasDelegated)
                                            {
                                                <span class="pill">@T["ApprovalQueue_PriorSignatureDelegatedBadge"]</span>
                                            }
                                        </div>
                                    </div>
                                </section>
                            }
                        </div>
                    }
                </div>

                <div class="pill-section">
                    <span class="section-caption">@T["ApprovalQueue_AttachmentsTitle"]</span>

                    @if (item.Attachments.Count == 0)
                    {
                        <p class="compact-copy">@T["ApprovalQueue_AttachmentsEmpty"]</p>
                    }
                    else
                    {
                        <div class="workflow-stage-list">
                            @foreach (var attachment in item.Attachments)
                            {
                                <section class="workflow-stage">
                                    <span class="pipeline-index">#</span>
                                    <div>
                                        <strong>@attachment.FileName</strong>
                                        <p class="compact-copy">@T[attachment.DocumentTypeResourceKey]</p>
                                        <div class="pill-list">
                                            @if (attachment.DocumentForm is not null)
                                            {
                                                <span class="pill">@T[attachment.DocumentForm.TitleResourceKey]</span>
                                                <span class="pill">@T[attachment.DocumentForm.BankResourceKey]</span>
                                            }
                                            <span class="pill">@T["ApprovalQueue_AttachmentLinkedAtLabel"]: @attachment.LinkedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                            <span class="pill">@T["ApprovalQueue_AttachmentLinkedByLabel"]: @(string.IsNullOrWhiteSpace(attachment.LinkedByDisplayName) ? T["RequestsWorkspace_LedgerSystemActor"].Value : attachment.LinkedByDisplayName)</span>
                                            <span class="pill">@T["ApprovalQueue_AttachmentCapturedAtLabel"]: @attachment.CapturedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                            <span class="pill">@T["ApprovalQueue_AttachmentCapturedByLabel"]: @(string.IsNullOrWhiteSpace(attachment.CapturedByDisplayName) ? T["RequestsWorkspace_LedgerSystemActor"].Value : attachment.CapturedByDisplayName)</span>
                                            <span class="pill">@T["ApprovalQueue_AttachmentCaptureChannelLabel"]: @T[attachment.CaptureChannelResourceKey]</span>
                                            @if (!string.IsNullOrWhiteSpace(attachment.SourceSystemName))
                                            {
                                                <span class="pill">@T["ApprovalQueue_AttachmentSourceSystemLabel"]: @attachment.SourceSystemName</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(attachment.SourceReference))
                                            {
                                                <span class="pill">@T["ApprovalQueue_AttachmentSourceReferenceLabel"]: @attachment.SourceReference</span>
                                            }
                                        </div>
                                    </div>
                                </section>
                            }
                        </div>
                    }
                </div>

                <div class="pill-section">
                    <span class="section-caption">@T["ApprovalQueue_TimelineTitle"]</span>

                    @if (item.TimelineEntries.Count == 0)
                    {
                        <p class="compact-copy">@T["ApprovalQueue_TimelineEmpty"]</p>
                    }
                    else
                    {
                        <div class="workflow-stage-list">
                            @foreach (var entry in item.TimelineEntries)
                            {
                                <section class="workflow-stage">
                                    <span class="pipeline-index">#</span>
                                    <div>
                                        <strong>@entry.OccurredAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</strong>
                                        <p class="compact-copy">
                                            @T["RequestsWorkspace_LedgerActorLabel"]:
                                            @(string.IsNullOrWhiteSpace(entry.ActorDisplayName)
                                                ? T["RequestsWorkspace_LedgerSystemActor"].Value
                                                : entry.ActorDisplayName)
                                        </p>
                                        <p class="compact-copy">@entry.Summary</p>
                                        @if (!string.IsNullOrWhiteSpace(entry.ApprovalStageLabel) ||
                                             !string.IsNullOrWhiteSpace(entry.ApprovalPolicyResourceKey) ||
                                             !string.IsNullOrWhiteSpace(entry.ApprovalExecutionModeResourceKey) ||
                                             !string.IsNullOrWhiteSpace(entry.ApprovalResponsibleSignerDisplayName) ||
                                             !string.IsNullOrWhiteSpace(entry.DispatchStageResourceKey) ||
                                             !string.IsNullOrWhiteSpace(entry.DispatchMethodResourceKey) ||
                                             !string.IsNullOrWhiteSpace(entry.DispatchPolicyResourceKey) ||
                                             !string.IsNullOrWhiteSpace(entry.OperationsScenarioTitleResourceKey) ||
                                             !string.IsNullOrWhiteSpace(entry.OperationsLaneResourceKey) ||
                                             !string.IsNullOrWhiteSpace(entry.OperationsMatchConfidenceResourceKey) ||
                                             entry.OperationsMatchScore.HasValue ||
                                             !string.IsNullOrWhiteSpace(entry.OperationsPolicyResourceKey))
                                        {
                                            <div class="pill-list">
                                                @if (!string.IsNullOrWhiteSpace(entry.ApprovalStageLabel))
                                                {
                                                    <span class="pill">@T["RequestsWorkspace_LedgerStageLabel"]: @entry.ApprovalStageLabel</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(entry.ApprovalPolicyResourceKey))
                                                {
                                                    <span class="pill">@T["RequestsWorkspace_LedgerPolicyLabel"]: @T[entry.ApprovalPolicyResourceKey]</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(entry.ApprovalExecutionModeResourceKey))
                                                {
                                                    <span class="pill">@T["RequestsWorkspace_LedgerExecutionModeLabel"]: @T[entry.ApprovalExecutionModeResourceKey]</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(entry.ApprovalResponsibleSignerDisplayName))
                                                {
                                                    <span class="pill">@T["RequestsWorkspace_LedgerResponsibleSignerLabel"]: @entry.ApprovalResponsibleSignerDisplayName</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(entry.DispatchStageResourceKey))
                                                {
                                                    <span class="pill">@T["RequestsWorkspace_LedgerDispatchStageLabel"]: @T[entry.DispatchStageResourceKey]</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(entry.DispatchMethodResourceKey))
                                                {
                                                    <span class="pill">@T["RequestsWorkspace_LedgerDispatchMethodLabel"]: @T[entry.DispatchMethodResourceKey]</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(entry.DispatchPolicyResourceKey))
                                                {
                                                    <span class="pill">@T["RequestsWorkspace_LedgerDispatchPolicyLabel"]: @T[entry.DispatchPolicyResourceKey]</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(entry.OperationsScenarioTitleResourceKey))
                                                {
                                                    <span class="pill">@T["RequestsWorkspace_LedgerOperationsScenarioLabel"]: @T[entry.OperationsScenarioTitleResourceKey]</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(entry.OperationsLaneResourceKey))
                                                {
                                                    <span class="pill">@T["RequestsWorkspace_LedgerOperationsLaneLabel"]: @T[entry.OperationsLaneResourceKey]</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(entry.OperationsMatchConfidenceResourceKey))
                                                {
                                                    <span class="pill">
                                                        @T["RequestsWorkspace_LedgerOperationsConfidenceLabel"]:
                                                        @T[entry.OperationsMatchConfidenceResourceKey]
                                                        @if (entry.OperationsMatchScore.HasValue)
                                                        {
                                                            @($" ({entry.OperationsMatchScore.Value})")
                                                        }
                                                    </span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(entry.OperationsPolicyResourceKey))
                                                {
                                                    <span class="pill">@T["RequestsWorkspace_LedgerOperationsPolicyLabel"]: @T[entry.OperationsPolicyResourceKey]</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </section>
                            }
                        </div>
                    }
                </div>
            </article>
        }
    }
</section>
