@page "{requestId:guid}"
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Approvals.DossierModel
@{
    ViewData["Title"] = T["ApprovalDossier_PageTitle"];

    string BuildInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "BG";
        }

        var initials = new List<char>(2);
        foreach (var part in value.Split(' ', StringSplitOptions.RemoveEmptyEntries))
        {
            initials.Add(char.ToUpperInvariant(part[0]));
            if (initials.Count == 2)
            {
                break;
            }
        }

        return initials.Count == 0 ? "BG" : new string(initials.ToArray());
    }

    string ResolveStageTitle(BG.Application.Models.Approvals.ApprovalQueueItemDto item)
    {
        return !string.IsNullOrWhiteSpace(item.CurrentStageTitle)
            ? item.CurrentStageTitle
            : string.IsNullOrWhiteSpace(item.CurrentStageTitleResourceKey)
                ? "-"
                : T[item.CurrentStageTitleResourceKey].Value;
    }

    string ResolveRequestedChange(BG.Application.Models.Approvals.ApprovalQueueItemDto item)
    {
        var parts = new List<string>();

        if (!string.IsNullOrWhiteSpace(item.RequestedAmount))
        {
            parts.Add(item.RequestedAmount);
        }

        if (!string.IsNullOrWhiteSpace(item.RequestedExpiryDate))
        {
            parts.Add(item.RequestedExpiryDate);
        }

        return parts.Count == 0 ? "-" : string.Join(" · ", parts);
    }

    var headerModel = new SurfaceHeaderModel(
        T["NavApprovals"].Value,
        T["ApprovalDossier_Heading"].Value,
        null);
    var noEligibleActorModel = new SurfaceMessageCardModel(
        T["ApprovalQueue_NoEligibleActor"].Value,
        T["ApprovalQueue_NoEligibleActorBody"].Value);
    var actorContextModel = new ActorContextPanelModel(
        T["ApprovalQueue_ActorContextTitle"].Value,
        null,
        Model.IsActorContextLocked ? ActorContextPanelMode.LockedPills : ActorContextPanelMode.SelectorForm,
        "full-span")
    {
        Pills = Model.IsActorContextLocked
            ? new[]
            {
                T["WorkspaceShell_CurrentUserScopeNotice"].Value,
                $"{Model.Snapshot.ActiveActor?.DisplayName} ({Model.Snapshot.ActiveActor?.Username})"
            }
            : Array.Empty<string>(),
        FormAction = Url.Page("/Approvals/Dossier", new { requestId = Model.RequestId }),
        ActorFieldLabel = T["ApprovalQueue_ActorField"].Value,
        SubmitLabel = T["ApprovalQueue_LoadActorAction"].Value,
        HiddenFields = new SurfaceHiddenFieldModel[]
        {
            new("page", (Model.PageNumber ?? 1).ToString())
        },
        Options = Model.Snapshot.AvailableActors
            .Select(actor => new ActorContextOptionModel(
                actor.Id.ToString(),
                $"{actor.DisplayName} ({actor.Username})",
                Model.Snapshot.ActiveActor is not null && actor.Id == Model.Snapshot.ActiveActor.Id))
            .ToArray()
    };
}

<section class="section-shell">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice-banner is-success">@Model.StatusMessage</div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    @if (Model.Snapshot.HasEligibleActor && !string.IsNullOrWhiteSpace(Model.Snapshot.ContextNoticeResourceKey))
    {
        <div class="notice-banner is-success">@T[Model.Snapshot.ContextNoticeResourceKey]</div>
    }

    <partial name="/Pages/Shared/_SurfaceHeader.cshtml" model="headerModel" />

    @if (!Model.Snapshot.HasEligibleActor || Model.Snapshot.ActiveActor is null)
    {
        <partial name="/Pages/Shared/_SurfaceMessageCard.cshtml" model="noEligibleActorModel" />
    }
    else
    {
        <div class="action-row">
            <a class="btn btn-outline-primary action-button"
               asp-page="/Approvals/Queue"
               asp-all-route-data="Model.BuildQueueRoute()">
                @T["ApprovalDossier_BackToQueueAction"]
            </a>
        </div>

        <partial name="/Pages/Shared/_ActorContextPanel.cshtml" model="actorContextModel" />

        @if (Model.Snapshot.Item is null)
        {
            <article class="info-card">
                <h2>@T["ApprovalDossier_UnavailableTitle"]</h2>
                <p class="compact-copy">@T[Model.Snapshot.UnavailableResourceKey ?? "ApprovalDossier_RequestNotAvailable"]</p>
            </article>
        }
        else
        {
            var item = Model.Snapshot.Item;
            var stageTitle = ResolveStageTitle(item);
            var requestedChange = ResolveRequestedChange(item);
            var isBlocked = item.Governance.IsDecisionBlocked && !string.IsNullOrWhiteSpace(item.Governance.ReasonResourceKey);
            var guaranteeCategoryTitle = T[item.GuaranteeCategoryResourceKey].Value;
            var submittedAt = item.SubmittedAtUtc.ToLocalTime().ToString("g", System.Globalization.CultureInfo.CurrentCulture);
            var activeActorName = Model.Snapshot.ActiveActor.DisplayName;
            var activeActorInitials = BuildInitials(activeActorName);
            var approveAction = Url.Page("/Approvals/Dossier", pageHandler: "Approve", values: new { requestId = Model.RequestId });
            var returnAction = Url.Page("/Approvals/Dossier", pageHandler: "Return", values: new { requestId = Model.RequestId });
            var rejectAction = Url.Page("/Approvals/Dossier", pageHandler: "Reject", values: new { requestId = Model.RequestId });

            <div class="approval-dossier-grid">
                <main class="approval-main-column d-flex flex-column gap-4">
                    <article class="approval-decision-card bg-card-premium surface-action-zone @(isBlocked ? "is-blocked" : "is-primary")">
                        <div class="approval-active-header">
                            <div class="approval-active-heading">
                                <section-caption>@T["SurfaceAction_CurrentActionLabel"]</section-caption>
                                <h2 class="fw-bold text-dark m-0">@item.GuaranteeNumber</h2>
                                <p class="compact-copy mb-0">@T[item.RequestTypeResourceKey] · @guaranteeCategoryTitle</p>
                            </div>
                            <bg-badge variant="warning" class="small">@T[item.StatusResourceKey]</bg-badge>
                        </div>

                        <form method="post" class="stack-form d-flex flex-column gap-3">
                            <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor.Id" />
                            <input type="hidden" name="requestId" value="@item.RequestId" />
                            <input type="hidden" name="page" value="@(Model.PageNumber ?? 1)" />

                            <div class="surface-action-header">
                                <span class="surface-action-kicker">@T[isBlocked ? "SurfaceAction_BlockedLabel" : "SurfaceAction_CurrentActionLabel"]</span>
                                <h3 class="surface-action-title">@(isBlocked ? T["ApprovalQueue_GovernanceBlockedTitle"].Value : T["ApprovalQueue_ActiveStepAwaitingReview"].Value)</h3>
                                @if (isBlocked)
                                {
                                    <p class="surface-action-copy">@T[item.Governance.ReasonResourceKey!]</p>
                                }
                            </div>

                            <div class="approval-comments-card">
                                <label class="section-caption x-small mb-2">@T["ApprovalQueue_CommentsTitle"]</label>
                                <div class="d-flex gap-3 align-items-start">
                                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-brand-green text-white fw-bold"
                                          style="width: 32px; height: 32px;"
                                          aria-hidden="true">
                                        @activeActorInitials
                                    </span>
                                    <div class="flex-grow-1">
                                        <div class="x-small fw-bold">@activeActorName</div>
                                        <div class="x-small text-muted mb-2">@stageTitle</div>
                                        <textarea name="note"
                                                  class="form-control x-small"
                                                  rows="3"
                                                  placeholder="@T["ApprovalQueue_CommentPlaceholder"]"
                                                  disabled="@isBlocked"></textarea>
                                    </div>
                                </div>
                            </div>

                            <div class="approval-decision-actions d-flex flex-column gap-2">
                                <bg-button variant="success" class="w-100 py-3 rounded-4" formaction="@approveAction" type="submit" disabled="@isBlocked">
                                    <i class="bi bi-check-lg me-2"></i>@T["ApprovalQueue_ApproveAction"]
                                </bg-button>

                                <bg-button variant="warning" class="w-100 py-3 rounded-4" formaction="@returnAction" type="submit" disabled="@isBlocked">
                                    <i class="bi bi-pencil-square me-2"></i>@T["ApprovalQueue_ReturnAction"]
                                </bg-button>

                                <bg-button variant="light" class="w-100 py-3 rounded-4" formaction="@rejectAction" type="submit" disabled="@isBlocked">
                                    <i class="bi bi-x-lg me-2"></i>@T["ApprovalQueue_RejectAction"]
                                </bg-button>
                            </div>
                        </form>
                    </article>

                    <article class="info-card">
                        <div class="card-header pb-3 mb-3 border-bottom">
                            <h2 class="h5 fw-bold m-0">@T["ApprovalDossier_RequestTitle"]</h2>
                        </div>

                        <div class="entity-header mb-4">
                            <div>
                                <h3 class="h4 fw-bold">@item.GuaranteeNumber</h3>
                                <div class="text-muted small">@T[item.RequestTypeResourceKey] · @T[item.GuaranteeCategoryResourceKey]</div>
                            </div>
                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">@T[item.StatusResourceKey]</span>
                        </div>

                        <div class="pill-section mb-4">
                            <span class="section-caption d-block mb-3">@T["ApprovalQueue_AttachmentsTitle"]</span>

                            @if (item.Attachments.Count == 0)
                            {
                                <p class="compact-copy">@T["ApprovalQueue_AttachmentsEmpty"]</p>
                            }
                            else
                            {
                                <div class="workflow-stage-list">
                                    @foreach (var attachment in item.Attachments)
                                    {
                                        <section class="workflow-stage p-3 border rounded-4 mb-3 bg-white">
                                            <div class="d-flex justify-content-between align-items-start w-100">
                                                <div class="flex-grow-1">
                                                    <div class="fw-bold mb-1">@attachment.FileName</div>
                                                    <div class="x-small text-muted mb-2">@T[attachment.DocumentTypeResourceKey]</div>
                                                    <div class="pill-list d-flex flex-wrap gap-2">
                                                        @if (attachment.DocumentForm is not null)
                                                        {
                                                            <span class="badge bg-light text-dark fw-normal border">@T[attachment.DocumentForm.TitleResourceKey]</span>
                                                        }
                                                        <span class="badge bg-light text-muted fw-normal border">@attachment.CapturedAtUtc.ToLocalTime().ToString("g")</span>
                                                    </div>
                                                </div>
                                                <button type="button" 
                                                        class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                                        onclick="openDetailDrawer('@Url.Page("/Approvals/Dossier", "PreviewAttachment", new { requestId = Model.RequestId, attachmentId = attachment.DocumentId })', '@attachment.FileName')">
                                                    <i class="bi bi-eye me-1"></i> @T["IntakeWorkspace_OpenDocumentAction"]
                                                </button>
                                            </div>
                                        </section>
                                    }
                                </div>
                            }
                        </div>
                    </article>
                </main>

                <aside class="approval-support-rail">
                    <div class="rail-card">
                        <section-caption class="mb-3 d-block text-uppercase small fw-bold">@T["ApprovalQueue_ApplicationSummaryTitle"]</section-caption>
                        <div class="d-flex flex-column gap-3">
                            <div class="approval-summary-card shadow-none border-0 p-0">
                                <span class="section-caption x-small mb-1">@T["RequestsWorkspace_CurrentStageLabel"]</span>
                                <strong>@stageTitle</strong>
                            </div>
                            <div class="approval-summary-card shadow-none border-0 p-0">
                                <span class="section-caption x-small mb-1">@T["ApprovalQueue_SubmittedAtLabel"]</span>
                                <strong>@submittedAt</strong>
                            </div>
                            <div class="approval-summary-card shadow-none border-0 p-0">
                                <span class="section-caption x-small mb-1">@T["ApprovalQueue_RequesterLabel"]</span>
                                <strong>@item.RequesterDisplayName</strong>
                            </div>
                            @if (requestedChange != "-")
                            {
                                <div class="approval-summary-card shadow-none border-0 p-0">
                                    <span class="section-caption x-small mb-1">@T["RequestsWorkspace_RequestedChangeTitle"]</span>
                                    <strong>@requestedChange</strong>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="rail-card">
                        <section-caption class="mb-3 d-block text-uppercase small fw-bold">@T["ApprovalQueue_TimelineTitle"]</section-caption>
                        @if (item.TimelineEntries.Count == 0)
                        {
                            <p class="compact-copy">@T["ApprovalQueue_TimelineEmpty"]</p>
                        }
                        else
                        {
                            <div class="timeline-compact">
                                @foreach (var entry in item.TimelineEntries.OrderByDescending(e => e.OccurredAtUtc).Take(5))
                                {
                                    <div class="mb-3 pb-3 border-bottom last-child-no-border">
                                        <div class="x-small fw-bold text-primary">@entry.OccurredAtUtc.ToLocalTime().ToString("g")</div>
                                        <div class="small fw-semibold mt-1">@entry.Summary</div>
                                        <div class="x-small text-muted">@entry.ActorDisplayName</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </aside>
            </div>
        }
    }
</section>

@* Detail Drawer Components (C-SURF-04) *@
<div id="detailDrawerBackdrop" class="detail-drawer-backdrop" onclick="closeDetailDrawer()"></div>
<div id="detailDrawer" class="detail-drawer-overlay">
    <div class="detail-drawer-header">
        <h4 id="detailDrawerTitle" class="m-0 h5 fw-bold"></h4>
        <button type="button" class="btn-close" onclick="closeDetailDrawer()"></button>
    </div>
    <div class="detail-drawer-body">
        <iframe id="detailDrawerFrame" class="w-100 h-100 border-0" title="Detail Preview"></iframe>
    </div>
</div>

<script>
    function openDetailDrawer(url, title) {
        const drawer = document.getElementById('detailDrawer');
        const backdrop = document.getElementById('detailDrawerBackdrop');
        const frame = document.getElementById('detailDrawerFrame');
        const titleEl = document.getElementById('detailDrawerTitle');

        titleEl.innerText = title;
        frame.src = url;
        
        drawer.classList.add('is-active');
        backdrop.classList.add('is-active');
        document.body.style.overflow = 'hidden';
    }

    function closeDetailDrawer() {
        const drawer = document.getElementById('detailDrawer');
        const backdrop = document.getElementById('detailDrawerBackdrop');
        const frame = document.getElementById('detailDrawerFrame');
        
        drawer.classList.remove('is-active');
        backdrop.classList.remove('is-active');
        document.body.style.overflow = '';
        
        setTimeout(() => { frame.src = ''; }, 400);
    }
</script>
