@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model ErrorModel
@{
    ViewData["Title"] = T["Error_PageTitle"];
}

<h1 class="text-danger">@T["Error_Heading"]</h1>
<h2 class="text-danger">@T["Error_Summary"]</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>@T["Error_RequestIdLabel"]:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>@T["Error_DevelopmentModeTitle"]</h3>
<p>
    @T["Error_DevelopmentModeBody"]
</p>
<p>
    <strong>@T["Error_DevelopmentModeWarning"]</strong>
</p>
<p>
    @T["Error_DevelopmentModeInstruction"] <strong>ASPNETCORE_ENVIRONMENT</strong> = <strong>Development</strong>.
</p>
