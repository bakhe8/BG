@page
@using Microsoft.Extensions.Localization
@using System.Globalization
@inject IStringLocalizer<SharedResource> T
@model IndexModel
@{
    ViewData["Title"] = T["Home_PageTitle"];

    var workspaceCards = new List<(string Href, string TitleKey, string CountText, string SummaryText)>();

    if (Model.Dashboard.CanViewApprovals)
    {
        workspaceCards.Add((
            "/Approvals/Queue",
            "NavApprovals",
            Model.Dashboard.PendingApprovalsCount.ToString("N0", CultureInfo.CurrentUICulture),
            T["Home_MetricApprovals"].Value));
    }

    if (Model.Dashboard.CanViewRequests)
    {
        workspaceCards.Add((
            "/Requests/Workspace",
            "NavRequests",
            Model.Dashboard.MyOpenRequestsCount.ToString("N0", CultureInfo.CurrentUICulture),
            T["Home_MetricRequests"].Value));
    }

    if (Model.Dashboard.CanViewOperations)
    {
        workspaceCards.Add((
            "/Operations/Queue",
            "NavOperationsQueue",
            Model.Dashboard.OperationsBacklogCount.ToString("N0", CultureInfo.CurrentUICulture),
            T["Home_MetricOperations"].Value));
    }

    if (Model.Dashboard.CanViewDispatch)
    {
        workspaceCards.Add((
            "/Dispatch/Workspace",
            "NavDispatch",
            Model.Dashboard.ReadyForDispatchCount.ToString("N0", CultureInfo.CurrentUICulture),
            T["Home_MetricDispatchReady"].Value));
    }

    if (Model.Dashboard.CanViewIntake)
    {
        workspaceCards.Add((
            "/Intake/Workspace",
            "NavIntake",
            Model.Dashboard.RecentIntakeActivities.Count.ToString("N0", CultureInfo.CurrentUICulture),
            T["Home_RecentIntakeTitle"].Value));
    }

    var primaryPanel = Model.Dashboard.CanViewApprovals
        ? "approvals"
        : Model.Dashboard.CanViewRequests
            ? "requests"
            : (Model.Dashboard.CanViewOperations || Model.Dashboard.CanViewDispatch)
                ? "handoff"
                : Model.Dashboard.CanViewIntake
                    ? "intake"
                    : Model.Dashboard.CanViewExpiringGuarantees
                        ? "expiring"
                        : "none";

    var secondaryPanel = primaryPanel != "requests" && Model.Dashboard.CanViewRequests
        ? "requests"
        : primaryPanel != "expiring" && Model.Dashboard.CanViewExpiringGuarantees
            ? "expiring"
            : primaryPanel != "intake" && Model.Dashboard.CanViewIntake
                ? "intake"
                : primaryPanel != "handoff" && (Model.Dashboard.CanViewOperations || Model.Dashboard.CanViewDispatch)
                    ? "handoff"
                    : "none";
}

@if (!Model.Dashboard.IsAuthenticated)
{
    <section class="home-landing">
        <article class="home-start-card">
            <div class="home-start-copy">
                <span class="eyebrow">@T["Home_AnonymousEyebrow"]</span>
                <h1>@T["Home_AnonymousHeading"]</h1>
                <p>@T["Home_AnonymousSummary"]</p>
                <div class="home-start-actions">
                    <a class="btn btn-primary action-button" href="/SignIn?returnUrl=%2F">
                        @T["Home_AnonymousAction"]
                    </a>
                </div>
            </div>
        </article>
    </section>
}
else if (!Model.Dashboard.HasVisibleOperationalAreas)
{
    <section class="home-landing">
        <article class="home-start-card">
            <div class="home-start-copy">
                <span class="eyebrow">@T["Home_DashboardEyebrow"]</span>
                <h1>@T["Home_NoOperationalAccessTitle"]</h1>
                <p>@T["Home_NoOperationalAccessBody"]</p>
            </div>
        </article>
    </section>
}
else
{
    <section class="home-landing">
        <article class="home-start-card">
            <div class="home-start-copy">
                <span class="eyebrow">@T["Home_DashboardEyebrow"]</span>
                <h1>@string.Format(CultureInfo.CurrentUICulture, T["Home_DashboardHeading"], Model.Dashboard.DisplayName)</h1>
                <p>@T["Home_MinimalSummary"]</p>
            </div>
            <div class="home-start-metrics">
                @if (Model.Dashboard.CanViewApprovals)
                {
                    <div class="home-inline-stat">
                        <span>@T["Home_MetricApprovals"]</span>
                        <strong>@Model.Dashboard.PendingApprovalsCount.ToString("N0", CultureInfo.CurrentUICulture)</strong>
                    </div>
                }
                @if (Model.Dashboard.CanViewRequests)
                {
                    <div class="home-inline-stat">
                        <span>@T["Home_MetricRequests"]</span>
                        <strong>@Model.Dashboard.MyOpenRequestsCount.ToString("N0", CultureInfo.CurrentUICulture)</strong>
                    </div>
                }
                @if (Model.Dashboard.CanViewOperations)
                {
                    <div class="home-inline-stat">
                        <span>@T["Home_MetricOperations"]</span>
                        <strong>@Model.Dashboard.OperationsBacklogCount.ToString("N0", CultureInfo.CurrentUICulture)</strong>
                    </div>
                }
                @if (Model.Dashboard.CanViewExpiringGuarantees)
                {
                    <div class="home-inline-stat">
                        <span>@T["Home_MetricExpiring"]</span>
                        <strong>@Model.Dashboard.ExpiringGuaranteesCount.ToString("N0", CultureInfo.CurrentUICulture)</strong>
                    </div>
                }
            </div>
        </article>

        <section class="info-card">
            <div class="home-panel-header">
                <div>
                    <h2>@T["Home_WorkspacesTitle"]</h2>
                    <p class="compact-copy">@T["Home_WorkspacesSummary"]</p>
                </div>
            </div>
            <div class="home-workspace-grid">
                @foreach (var card in workspaceCards)
                {
                    <a class="home-workspace-card" href="@card.Href">
                        <span class="home-workspace-title">@T[card.TitleKey]</span>
                        <strong>@card.CountText</strong>
                        <span class="home-workspace-meta">@card.SummaryText</span>
                    </a>
                }
            </div>
        </section>

        <section class="home-focus-grid">
            @switch (primaryPanel)
            {
                case "approvals":
                    <article class="info-card home-panel">
                        <div class="home-panel-header">
                            <div>
                                <h2>@T["Home_PendingApprovalsTitle"]</h2>
                                <p class="compact-copy">@T["Home_FocusSummary"]</p>
                            </div>
                            <a class="btn btn-outline-primary action-button" href="/Approvals/Queue">@T["NavApprovals"]</a>
                        </div>
                        @if (Model.Dashboard.PendingApprovals.Count == 0)
                        {
                            <p class="dashboard-empty">@T["Home_EmptyApprovals"]</p>
                        }
                        else
                        {
                            <ul class="home-list">
                                @foreach (var item in Model.Dashboard.PendingApprovals.Take(4))
                                {
                                    <li class="home-list-item">
                                        <div>
                                            <strong>@item.GuaranteeNumber</strong>
                                            <p class="compact-copy">@T[$"RequestType_{item.RequestType}"]</p>
                                        </div>
                                        <div class="home-list-meta">
                                            <span>
                                                @(string.IsNullOrWhiteSpace(item.StageTitleText)
                                                    ? T[item.StageTitleResourceKey ?? "ApprovalQueue_CurrentStageLabel"]
                                                    : item.StageTitleText)
                                            </span>
                                            <small>@item.SubmittedAtUtc.ToLocalTime().ToString("g", CultureInfo.CurrentUICulture)</small>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </article>
                    break;

                case "requests":
                    <article class="info-card home-panel">
                        <div class="home-panel-header">
                            <div>
                                <h2>@T["Home_MyRequestsTitle"]</h2>
                                <p class="compact-copy">@T["Home_FocusSummary"]</p>
                            </div>
                            <a class="btn btn-outline-primary action-button" href="/Requests/Workspace">@T["NavRequests"]</a>
                        </div>
                        @if (Model.Dashboard.OpenRequests.Count == 0)
                        {
                            <p class="dashboard-empty">@T["Home_EmptyRequests"]</p>
                        }
                        else
                        {
                            <ul class="home-list">
                                @foreach (var item in Model.Dashboard.OpenRequests.Take(4))
                                {
                                    <li class="home-list-item">
                                        <div>
                                            <strong>@item.GuaranteeNumber</strong>
                                            <p class="compact-copy">@T[$"RequestType_{item.RequestType}"]</p>
                                        </div>
                                        <div class="home-list-meta">
                                            <span>@T[$"RequestStatus_{item.Status}"]</span>
                                            <small>@item.CreatedAtUtc.ToLocalTime().ToString("g", CultureInfo.CurrentUICulture)</small>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </article>
                    break;

                case "handoff":
                    <article class="info-card home-panel">
                        <div class="home-panel-header">
                            <div>
                                <h2>@T["Home_HandoffTitle"]</h2>
                                <p class="compact-copy">@T["Home_FocusSummary"]</p>
                            </div>
                        </div>
                        <div class="home-handoff-grid">
                            @if (Model.Dashboard.CanViewOperations)
                            {
                                <div class="home-handoff-card">
                                    <span>@T["Home_OperationsBacklogLabel"]</span>
                                    <strong>@Model.Dashboard.OperationsBacklogCount.ToString("N0", CultureInfo.CurrentUICulture)</strong>
                                </div>
                            }
                            @if (Model.Dashboard.CanViewDispatch)
                            {
                                <div class="home-handoff-card">
                                    <span>@T["Home_DispatchReadyLabel"]</span>
                                    <strong>@Model.Dashboard.ReadyForDispatchCount.ToString("N0", CultureInfo.CurrentUICulture)</strong>
                                </div>
                                <div class="home-handoff-card">
                                    <span>@T["Home_PendingDeliveryLabel"]</span>
                                    <strong>@Model.Dashboard.PendingDeliveryCount.ToString("N0", CultureInfo.CurrentUICulture)</strong>
                                </div>
                            }
                        </div>
                    </article>
                    break;

                case "intake":
                    <article class="info-card home-panel">
                        <div class="home-panel-header">
                            <div>
                                <h2>@T["Home_RecentIntakeTitle"]</h2>
                                <p class="compact-copy">@T["Home_FocusSummary"]</p>
                            </div>
                            <a class="btn btn-outline-primary action-button" href="/Intake/Workspace">@T["NavIntake"]</a>
                        </div>
                        @if (Model.Dashboard.RecentIntakeActivities.Count == 0)
                        {
                            <p class="dashboard-empty">@T["Home_EmptyIntake"]</p>
                        }
                        else
                        {
                            <ul class="home-list">
                                @foreach (var item in Model.Dashboard.RecentIntakeActivities.Take(4))
                                {
                                    <li class="home-list-item">
                                        <div>
                                            <strong>@item.GuaranteeNumber</strong>
                                            <p class="compact-copy">@T[item.ScenarioTitleResourceKey]</p>
                                        </div>
                                        <div class="home-list-meta">
                                            <span>@item.FileName</span>
                                            <small>@item.CapturedAtUtc.ToLocalTime().ToString("g", CultureInfo.CurrentUICulture)</small>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </article>
                    break;

                case "expiring":
                    <article class="info-card home-panel">
                        <div class="home-panel-header">
                            <div>
                                <h2>@T["Home_ExpiringTitle"]</h2>
                                <p class="compact-copy">@T["Home_FocusSummary"]</p>
                            </div>
                        </div>
                        @if (Model.Dashboard.ExpiringGuarantees.Count == 0)
                        {
                            <p class="dashboard-empty">@T["Home_EmptyExpiring"]</p>
                        }
                        else
                        {
                            <ul class="home-list">
                                @foreach (var item in Model.Dashboard.ExpiringGuarantees.Take(4))
                                {
                                    <li class="home-list-item">
                                        <div>
                                            <strong>@item.GuaranteeNumber</strong>
                                            <p class="compact-copy">@T[$"GuaranteeCategory_{item.Category}"]</p>
                                        </div>
                                        <div class="home-list-meta">
                                            <span>@item.DaysRemaining @T["Home_DaysRemainingSuffix"]</span>
                                            <small>@item.ExpiryDate.ToString("d", CultureInfo.CurrentUICulture)</small>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </article>
                    break;
            }

            @switch (secondaryPanel)
            {
                case "requests":
                    <article class="info-card home-panel">
                        <div class="home-panel-header">
                            <div>
                                <h2>@T["Home_MyRequestsTitle"]</h2>
                                <p class="compact-copy">@T["Home_SecondarySummary"]</p>
                            </div>
                        </div>
                        @if (Model.Dashboard.OpenRequests.Count == 0)
                        {
                            <p class="dashboard-empty">@T["Home_EmptyRequests"]</p>
                        }
                        else
                        {
                            <ul class="home-list">
                                @foreach (var item in Model.Dashboard.OpenRequests.Take(4))
                                {
                                    <li class="home-list-item">
                                        <div>
                                            <strong>@item.GuaranteeNumber</strong>
                                            <p class="compact-copy">@T[$"RequestType_{item.RequestType}"]</p>
                                        </div>
                                        <div class="home-list-meta">
                                            <span>@T[$"RequestStatus_{item.Status}"]</span>
                                            <small>@item.CreatedAtUtc.ToLocalTime().ToString("g", CultureInfo.CurrentUICulture)</small>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </article>
                    break;

                case "expiring":
                    <article class="info-card home-panel">
                        <div class="home-panel-header">
                            <div>
                                <h2>@T["Home_ExpiringTitle"]</h2>
                                <p class="compact-copy">@T["Home_SecondarySummary"]</p>
                            </div>
                        </div>
                        @if (Model.Dashboard.ExpiringGuarantees.Count == 0)
                        {
                            <p class="dashboard-empty">@T["Home_EmptyExpiring"]</p>
                        }
                        else
                        {
                            <ul class="home-list">
                                @foreach (var item in Model.Dashboard.ExpiringGuarantees.Take(4))
                                {
                                    <li class="home-list-item">
                                        <div>
                                            <strong>@item.GuaranteeNumber</strong>
                                            <p class="compact-copy">@T[$"GuaranteeCategory_{item.Category}"]</p>
                                        </div>
                                        <div class="home-list-meta">
                                            <span>@item.DaysRemaining @T["Home_DaysRemainingSuffix"]</span>
                                            <small>@item.ExpiryDate.ToString("d", CultureInfo.CurrentUICulture)</small>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </article>
                    break;

                case "intake":
                    <article class="info-card home-panel">
                        <div class="home-panel-header">
                            <div>
                                <h2>@T["Home_RecentIntakeTitle"]</h2>
                                <p class="compact-copy">@T["Home_SecondarySummary"]</p>
                            </div>
                        </div>
                        @if (Model.Dashboard.RecentIntakeActivities.Count == 0)
                        {
                            <p class="dashboard-empty">@T["Home_EmptyIntake"]</p>
                        }
                        else
                        {
                            <ul class="home-list">
                                @foreach (var item in Model.Dashboard.RecentIntakeActivities.Take(4))
                                {
                                    <li class="home-list-item">
                                        <div>
                                            <strong>@item.GuaranteeNumber</strong>
                                            <p class="compact-copy">@T[item.ScenarioTitleResourceKey]</p>
                                        </div>
                                        <div class="home-list-meta">
                                            <span>@item.FileName</span>
                                            <small>@item.CapturedAtUtc.ToLocalTime().ToString("g", CultureInfo.CurrentUICulture)</small>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </article>
                    break;

                case "handoff":
                    <article class="info-card home-panel">
                        <div class="home-panel-header">
                            <div>
                                <h2>@T["Home_HandoffTitle"]</h2>
                                <p class="compact-copy">@T["Home_SecondarySummary"]</p>
                            </div>
                        </div>
                        <div class="home-handoff-grid">
                            @if (Model.Dashboard.CanViewOperations)
                            {
                                <div class="home-handoff-card">
                                    <span>@T["Home_OperationsBacklogLabel"]</span>
                                    <strong>@Model.Dashboard.OperationsBacklogCount.ToString("N0", CultureInfo.CurrentUICulture)</strong>
                                </div>
                            }
                            @if (Model.Dashboard.CanViewDispatch)
                            {
                                <div class="home-handoff-card">
                                    <span>@T["Home_DispatchReadyLabel"]</span>
                                    <strong>@Model.Dashboard.ReadyForDispatchCount.ToString("N0", CultureInfo.CurrentUICulture)</strong>
                                </div>
                                <div class="home-handoff-card">
                                    <span>@T["Home_PendingDeliveryLabel"]</span>
                                    <strong>@Model.Dashboard.PendingDeliveryCount.ToString("N0", CultureInfo.CurrentUICulture)</strong>
                                </div>
                            }
                        </div>
                    </article>
                    break;
            }
        </section>
    </section>
}
