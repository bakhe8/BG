@page
@model IndexModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@{
    ViewData["Title"] = T["Dashboard_PageTitle"];
    var currentPath = HttpContext.Request.Path;
}

<div class="home-landing">
    @* Institutional Identity Banner (Shell) *@
    <div class="dashboard-header mb-5">
        <h1 class="display-4 fw-bold">@T["Dashboard_WelcomeHeading"]</h1>
        <p class="text-muted fs-5">@T["Dashboard_WelcomeSummary"]</p>
    </div>

    @* Decision-First Metrics (Workspace) *@
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="metric-card h-100">
                <span class="section-caption mb-2">@T["Dashboard_Metric_PendingTitle"]</span>
                <div class="d-flex align-items-baseline gap-2">
                    <strong class="fs-2 text-brand-green">12</strong>
                    <i class="bi bi-arrow-up-right text-success small"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card h-100">
                <span class="section-caption mb-2">@T["Dashboard_Metric_ActiveTitle"]</span>
                <div class="d-flex align-items-baseline gap-2">
                    <strong class="fs-2 text-dark">48</strong>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card h-100">
                <span class="section-caption mb-2">@T["Dashboard_Metric_NearingExpiryTitle"]</span>
                <div class="d-flex align-items-baseline gap-2">
                    <strong class="fs-2 text-danger">3</strong>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card h-100">
                <span class="section-caption mb-2">@T["Dashboard_Metric_CompletedTodayTitle"]</span>
                <div class="d-flex align-items-baseline gap-2">
                    <strong class="fs-2 text-muted">8</strong>
                </div>
            </div>
        </div>
    </div>

    @* Operational Workspaces (Minimalist Grid) *@
    <div class="row g-4">
        <div class="col-md-4">
            <a class="info-card d-flex flex-column h-100 text-decoration-none group" href="/Intake/Workspace">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="p-3 rounded-4 bg-light group-hover:bg-brand-green group-hover:text-white transition-all">
                        <i class="bi bi-box-arrow-in-right fs-4"></i>
                    </div>
                    <i class="bi bi-arrow-right text-muted opacity-0 group-hover:opacity-100 transition-all"></i>
                </div>
                <h5 class="fw-bold mb-2">@T["WorkspaceShell_NavIntake"]</h5>
                <p class="small text-muted mb-0">@T["Dashboard_WelcomeSummary"]</p>
            </a>
        </div>
        <div class="col-md-4">
            <a class="info-card d-flex flex-column h-100 text-decoration-none group" href="/Operations/Queue">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="p-3 rounded-4 bg-light group-hover:bg-brand-green group-hover:text-white transition-all">
                        <i class="bi bi-check2-circle fs-4"></i>
                    </div>
                    <i class="bi bi-arrow-right text-muted opacity-0 group-hover:opacity-100 transition-all"></i>
                </div>
                <h5 class="fw-bold mb-2">@T["WorkspaceShell_NavOperations"]</h5>
                <p class="small text-muted mb-0">@T["Dashboard_WelcomeSummary"]</p>
            </a>
        </div>
        <div class="col-md-4">
            <a class="info-card d-flex flex-column h-100 text-decoration-none group" href="/Dispatch/Workspace">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="p-3 rounded-4 bg-light group-hover:bg-brand-green group-hover:text-white transition-all">
                        <i class="bi bi-send fs-4"></i>
                    </div>
                    <i class="bi bi-arrow-right text-muted opacity-0 group-hover:opacity-100 transition-all"></i>
                </div>
                <h5 class="fw-bold mb-2">@T["WorkspaceShell_NavDispatch"]</h5>
                <p class="small text-muted mb-0">@T["Dashboard_WelcomeSummary"]</p>
            </a>
        </div>
    </div>
</div>

<style>
    .group:hover .bg-light {
        background-color: var(--kfshrc-green) !important;
        color: white !important;
    }
    .group:hover .text-muted {
        color: var(--kfshrc-green) !important;
    }
</style>
