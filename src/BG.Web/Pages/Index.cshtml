@page
@model IndexModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@{
    ViewData["Title"] = T["Dashboard_PageTitle"];
}

<div class="dashboard-container py-4">

@if (!Model.Dashboard.IsAuthenticated)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
        <div class="text-center" style="max-width: 480px;">
            <i class="bi bi-shield-lock" style="font-size: 5rem; color: #006847; opacity: 0.2;"></i>
            <h2 class="fw-bold text-dark mt-4 mb-2">@T["Dashboard_WelcomeHeading"]</h2>
            <p class="text-muted mb-5">@T["Dashboard_WelcomeSummary"]</p>
            <a href="/SignIn" hx-boost="false" class="btn btn-lg px-5 py-3 fw-bold text-white rounded-pill shadow-sm"
               style="background: linear-gradient(135deg, #006847, #004D35);">
                <i class="bi bi-person-lock me-2"></i>@T["SignIn_SubmitAction"]
            </a>
        </div>
    </div>
}
else
{

    @* --- Top Banner: Institutional Greeting & Hero Metrics --- *@
    <div class="welcome-hero mb-5 p-5 rounded-5 position-relative overflow-hidden shadow-sm">
        <div class="hero-glass-overlay"></div>
        <div class="position-relative z-1 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="display-5 fw-bold text-white mb-2">@T["Dashboard_WelcomeHeading"]</h1>
                <p class="text-white opacity-75 fs-5">@T["Dashboard_WelcomeSummary"]</p>
            </div>
            <div class="d-none d-lg-block">
                <i class="bi bi-shield-check text-white opacity-25" style="font-size: 8rem;"></i>
            </div>
        </div>

        @* Hero Quick Stats *@
        <div class="row g-4 mt-4 position-relative z-1">
            <div class="col-md-3">
                <div class="metric-glass p-3 rounded-4">
                    <span class="text-white opacity-50 small mb-1 d-block">@T["Dashboard_Metric_PendingTitle"]</span>
                    <div class="d-flex align-items-center gap-2">
                        <h2 class="text-white fw-bold mb-0">@Model.Dashboard.PendingApprovalsCount</h2>
                        <span class="badge bg-white bg-opacity-20 text-white small">@T["Dashboard_Metric_Approvals_Sub"]</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="metric-glass p-3 rounded-4">
                    <span class="text-white opacity-50 small mb-1 d-block">@T["Dashboard_Metric_ActiveTitle"]</span>
                    <div class="d-flex align-items-center gap-2">
                        <h2 class="text-white fw-bold mb-0">@Model.Dashboard.MyOpenRequestsCount</h2>
                        <span class="badge bg-white bg-opacity-20 text-white small">@T["Dashboard_Metric_Requests_Sub"]</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="metric-glass p-3 rounded-4">
                    <span class="text-white opacity-50 small mb-1 d-block">@T["Dashboard_Metric_CompletedTodayTitle"]</span>
                    <div class="d-flex align-items-center gap-2">
                        <h2 class="text-white fw-bold mb-0">@Model.Dashboard.OperationsBacklogCount</h2>
                        <span class="badge bg-white bg-opacity-20 text-white small">@T["Dashboard_Metric_Operations_Sub"]</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="metric-glass p-3 rounded-4 border-danger">
                    <span class="text-white opacity-50 small mb-1 d-block">@T["Dashboard_Metric_NearingExpiryTitle"]</span>
                    <div class="d-flex align-items-center gap-2">
                        <h2 class="text-white fw-bold mb-0">@Model.Dashboard.ExpiringGuaranteesCount</h2>
                        <span class="badge bg-danger bg-opacity-50 text-white small">@T["Dashboard_Metric_Expiring_Sub"]</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @* --- Left Side: Priority Action Feed --- *@
        <div class="col-lg-8">
            <div class="section-card h-100 p-4 rounded-5 bg-white shadow-sm border-0">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold text-dark mb-0 d-flex align-items-center gap-2">
                        <i class="bi bi-lightning-charge-fill text-warning"></i>
                        @T["Dashboard_Section_PriorityTasks"]
                    </h5>
                    <span class="badge bg-light text-muted rounded-pill fs-7 px-3">@(Model.Dashboard.PendingApprovalsCount + Model.Dashboard.MyOpenRequestsCount)</span>
                </div>

                @if (!Model.Dashboard.PendingApprovals.Any() && !Model.Dashboard.OpenRequests.Any())
                {
                    <div class="text-center py-5">
                        <div class="empty-state-icon mb-3">
                            <i class="bi bi-stack text-muted opacity-25" style="font-size: 4rem;"></i>
                        </div>
                        <p class="text-muted">@T["Dashboard_Empty_NoTasks"]</p>
                    </div>
                }
                else
                {
                    <div class="priority-feed">
                        @foreach (var approval in Model.Dashboard.PendingApprovals)
                        {
                            <a href="/Approvals/Queue?requestId=@approval.RequestId" class="task-item d-flex align-items-center p-3 rounded-4 mb-3 text-decoration-none group">
                                <div class="task-icon p-3 rounded-4 bg-light transition-all me-3">
                                    <i class="bi bi-check2-circle fs-5"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-baseline">
                                        <h6 class="fw-bold mb-1 text-dark">@approval.GuaranteeNumber</h6>
                                        <span class="small text-muted">@approval.SubmittedAtUtc.ToLocalTime().ToString("d")</span>
                                    </div>
                                    <p class="small text-muted mb-0">@(approval.StageTitleText ?? T[approval.StageTitleResourceKey ?? ""].Value)</p>
                                </div>
                                <i class="bi bi-chevron-right rtl-flip text-muted opacity-25 ms-3"></i>
                            </a>
                        }
                        @foreach (var req in Model.Dashboard.OpenRequests)
                        {
                            <a href="/Requests/Workspace?requestId=@req.RequestId" class="task-item d-flex align-items-center p-3 rounded-4 mb-3 text-decoration-none group">
                                <div class="task-icon p-3 rounded-4 bg-light transition-all me-3">
                                    <i class="bi bi-file-earmark-text fs-5"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-baseline">
                                        <h6 class="fw-bold mb-1 text-dark">@req.GuaranteeNumber</h6>
                                        <span class="small text-muted">@req.CreatedAtUtc.ToLocalTime().ToString("d")</span>
                                    </div>
                                    <p class="small text-muted mb-0">@T[$"RequestType_{req.RequestType}"]</p>
                                </div>
                                <i class="bi bi-chevron-right rtl-flip text-muted opacity-25 ms-3"></i>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

        @* --- Right Side: Recent Activity & Role Links --- *@
        <div class="col-lg-4">
            <div class="d-flex flex-column gap-4">
                @* Role Quick Navigation *@
                @if (Model.NavigationItems.Any())
                {
                    <div class="section-card p-4 rounded-5 bg-white shadow-sm border-0">
                        <h6 class="fw-bold text-dark mb-4 px-1">@T["Dashboard_Action_Navigate"]</h6>
                        <div class="row g-2">
                            @foreach (var navItem in Model.NavigationItems)
                            {
                                var navIcon = navItem.PagePath switch
                                {
                                    var p when p.StartsWith("/Intake", StringComparison.OrdinalIgnoreCase) => "bi-file-earmark-plus",
                                    var p when p.StartsWith("/Operations", StringComparison.OrdinalIgnoreCase) => "bi-shield-check",
                                    var p when p.Contains("Requests", StringComparison.OrdinalIgnoreCase) => "bi-journal-text",
                                    var p when p.StartsWith("/Approvals", StringComparison.OrdinalIgnoreCase) => "bi-check2-circle",
                                    var p when p.StartsWith("/Dispatch", StringComparison.OrdinalIgnoreCase) => "bi-send",
                                    var p when p.StartsWith("/Reports", StringComparison.OrdinalIgnoreCase) => "bi-bar-chart-line",
                                    var p when p.StartsWith("/Administration/Users", StringComparison.OrdinalIgnoreCase) => "bi-people",
                                    var p when p.StartsWith("/Administration/Delegations", StringComparison.OrdinalIgnoreCase) => "bi-person-badge",
                                    var p when p.StartsWith("/Administration/Roles", StringComparison.OrdinalIgnoreCase) => "bi-shield",
                                    var p when p.StartsWith("/Administration/Banks", StringComparison.OrdinalIgnoreCase) => "bi-bank",
                                    var p when p.StartsWith("/Administration", StringComparison.OrdinalIgnoreCase) => "bi-gear",
                                    _ => "bi-grid"
                                };
                                <div class="col-6">
                                    <a href="@navItem.PagePath" class="nav-tile p-3 rounded-4 text-center text-decoration-none group d-block border h-100">
                                        <i class="bi @navIcon d-block fs-3 mb-2 text-muted"></i>
                                        <span class="small fw-bold text-dark d-block">@T[navItem.ResourceKey]</span>
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                }

                @* System Activity Feed *@
                <div class="section-card p-4 rounded-5 bg-white shadow-sm border-0 flex-grow-1">
                    <h6 class="fw-bold text-dark mb-4 px-1">@T["Dashboard_Section_RecentActivity"]</h6>
                    @if (!Model.Dashboard.RecentIntakeActivities.Any())
                    {
                        <p class="small text-muted px-1">@T["Dashboard_Empty_NoActivity"]</p>
                    }
                    else
                    {
                        <div class="activity-timeline ps-2">
                            @foreach (var activity in Model.Dashboard.RecentIntakeActivities)
                            {
                                <div class="activity-item position-relative pb-4 ps-4">
                                    <div class="activity-dot"></div>
                                    <span class="activity-time d-block small text-muted mb-1">@activity.CapturedAtUtc.ToLocalTime().ToString("g")</span>
                                    <span class="activity-text small text-dark">@activity.GuaranteeNumber — @T[activity.ScenarioTitleResourceKey]</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
} @* end else (authenticated) *@
</div>

<style>
    :root {
        --brand-green: #006847;
        --brand-light: #F3FBF8;
    }

    /* Welcome Hero with Glassmorphism */
    .welcome-hero {
        background: linear-gradient(135deg, #006847 0%, #004D35 100%);
        border: 1px solid rgba(255,255,255,0.1);
    }
    .hero-glass-overlay {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: radial-gradient(circle at top right, rgba(255,255,255,0.1) 0%, transparent 70%);
        pointer-events: none;
    }
    .metric-glass {
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.15);
        transition: transform 0.3s ease;
    }
    .metric-glass:hover {
        transform: translateY(-3px);
        background: rgba(255,255,255,0.12);
    }

    /* Task Items */
    .task-item {
        background: var(--brand-light);
        border: 1px solid transparent;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .task-item:hover {
        background: white;
        border-color: var(--brand-green);
        box-shadow: 0 10px 20px -10px rgba(0, 104, 71, 0.15);
    }

    html[dir="ltr"] .task-item:hover { transform: translateX(8px); }
    html[dir="rtl"] .task-item:hover { transform: translateX(-8px); }
    .group-hover\:bg-brand-green:hover { background-color: var(--brand-green) !important; }
    .group-hover\:text-white:hover { color: white !important; }
    .group-hover\:text-brand-green:hover { color: var(--brand-green) !important; }

    /* Nav Tiles */
    .nav-tile {
        background: #fdfdfd;
        transition: all 0.2s ease;
    }
    .nav-tile:hover {
        background: white;
        border-color: var(--brand-green) !important;
        transform: translateY(-2px);
    }

    /* Activity Timeline */
    .activity-timeline {
        border-inline-start: 1px dashed #E5E7EB;
    }
    .activity-item::before {
        content: '';
        position: absolute;
        top: 4px;
        inset-inline-start: -5px;
        width: 9px;
        height: 9px;
        background: #D1D5DB;
        border-radius: 50%;
        border: 2px solid white;
    }
    .activity-item:first-child::before {
        background: var(--brand-green);
        box-shadow: 0 0 0 4px rgba(0, 104, 71, 0.1);
    }

    /* General Polish */
    .section-card {
        border: 1px solid #F3F4F6 !important;
    }
    .fs-7 { font-size: 0.85rem; }
    .transition-all { transition: all 0.3s ease; }
</style>
