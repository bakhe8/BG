@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Administration.RolesModel
@{
    ViewData["Title"] = T["RolesPageTitle"];
    var permissionCount = Model.PermissionGroups.Sum(group => group.Permissions.Count);
    var activeRole = Model.ActiveRole;
    var activeRolePermissionKeys = activeRole?.PermissionKeys.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var activeRoleGroups = activeRole is null
        ? Array.Empty<BG.Web.Pages.Administration.RolesModel.PermissionGroupViewModel>()
        : Model.PermissionGroups
            .Select(group => new BG.Web.Pages.Administration.RolesModel.PermissionGroupViewModel(
                group.Area,
                group.Permissions.Where(permission => activeRolePermissionKeys.Contains(permission.Key)).ToArray()))
            .Where(group => group.Permissions.Count > 0)
            .ToArray();
}

<section class="section-shell admin-roles-surface">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice-banner is-success">@Model.StatusMessage</div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <div class="mb-5 pb-4 border-bottom">
        <section-caption>@T["NavRoles"]</section-caption>
        <h1 class="fw-bold text-dark m-0">@T["RolesPageHeading"]</h1>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="bg-card shadow-sm p-4 text-center">
                <div class="section-caption x-small mb-1">@T["RolesListTitle"]</div>
                <div class="display-6 fw-bold text-dark">@Model.Roles.Count</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="bg-card shadow-sm p-4 text-center">
                <div class="section-caption x-small mb-1">@T["PermissionsField"]</div>
                <div class="display-6 fw-bold text-brand-green">@permissionCount</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="bg-card shadow-sm p-4 text-center">
                <div class="section-caption x-small mb-1">@T["PermissionGroup_Administration"]</div>
                <div class="display-6 fw-bold text-dark">@Model.PermissionGroups.Count</div>
            </div>
        </div>
    </div>

    <div class="admin-roles-layout">
        <div class="admin-roles-sidebar">
            <article class="admin-roles-directory bg-card shadow-sm">
                <div class="admin-users-card-header">
                    <div>
                        <h5 class="fw-bold text-dark m-0">@T["RolesListTitle"]</h5>
                        <p class="compact-copy mb-0">@T["RolesPage_DirectorySummary"]</p>
                    </div>
                    <bg-badge variant="light">@T["RolesPage_CountBadge", Model.Roles.Count]</bg-badge>
                </div>

                @if (Model.Roles.Count == 0)
                {
                    <div class="text-center py-5">
                        <i class="bi bi-shield-lock-fill display-1 text-light mb-4 d-block"></i>
                        <p class="text-secondary mb-0">@T["EmptyRoles"]</p>
                    </div>
                }
                else
                {
                    <div class="admin-roles-directory-list">
                        @foreach (var role in Model.Roles)
                        {
                            var isActive = activeRole?.Id == role.Id;
                            var permissionGroupCount = Model.PermissionGroups.Count(group => group.Permissions.Any(permission => role.PermissionKeys.Contains(permission.Key, StringComparer.OrdinalIgnoreCase)));

                            <a asp-page="/Administration/Roles"
                               asp-all-route-data="Model.BuildSelectionRoute(role.Id)"
                               class="request-queue-link admin-role-link @(isActive ? "active" : null)">
                                <div class="request-queue-copy">
                                    <strong>@role.Name</strong>
                                    <div class="entity-subtitle">@(string.IsNullOrWhiteSpace(role.Description) ? T["RolesPage_NoDescription"].Value : role.Description)</div>
                                </div>
                                <div class="request-queue-meta">
                                    @if (isActive)
                                    {
                                        <span class="surface-action-kicker">@T["SurfaceQueue_CurrentItemLabel"]</span>
                                    }
                                    <bg-badge variant="light">@role.PermissionKeys.Count @T["PermissionsField"]</bg-badge>
                                    <span class="section-caption">@permissionGroupCount @T["PermissionGroup_Administration"]</span>
                                </div>
                            </a>
                        }
                    </div>
                }
            </article>

            <article class="admin-roles-create bg-card shadow-sm">
                <div class="admin-users-card-header">
                    <div>
                        <h5 class="fw-bold text-dark m-0">@T["CreateRoleTitle"]</h5>
                        <p class="compact-copy mb-0">@T["RolesPage_CreateSummary"]</p>
                    </div>
                </div>

                <form method="post" class="d-flex flex-column gap-4">
                    <div>
                        <label class="form-label x-small fw-bold opacity-75" asp-for="Input.Name">@T["RoleNameField"]</label>
                        <input asp-for="Input.Name" class="form-control rounded-4 p-2 small" maxlength="64" />
                    </div>

                    <div>
                        <label class="form-label x-small fw-bold opacity-75" asp-for="Input.Description">@T["DescriptionField"]</label>
                        <textarea asp-for="Input.Description" class="form-control rounded-4 p-2 small" rows="2" maxlength="256"></textarea>
                    </div>

                    <div class="bg-light rounded-4 p-4">
                        <h6 class="fw-bold text-dark mb-4">@T["PermissionsField"]</h6>
                        @if (Model.PermissionGroups.Count == 0)
                        {
                            <p class="x-small text-muted italic mb-0">@T["NoPermissionsAvailable"]</p>
                        }
                        else
                        {
                            <div class="admin-role-picker">
                                @foreach (var group in Model.PermissionGroups)
                                {
                                    <div class="admin-role-picker-group">
                                        <div class="x-small fw-bold text-brand-green mb-2 opacity-75 text-uppercase letter-spacing-1">@T[$"PermissionGroup_{group.Area}"]</div>
                                        <div class="d-flex flex-column gap-2">
                                            @foreach (var permission in group.Permissions)
                                            {
                                                <label class="d-flex align-items-center gap-3 p-2 bg-white rounded-3 border cursor-pointer">
                                                    <input type="checkbox" name="Input.SelectedPermissionKeys" value="@permission.Key" class="form-check-input mt-0" />
                                                    <div>
                                                        <div class="x-small fw-bold text-dark">@T[$"Permission_{permission.Key}"]</div>
                                                        <div class="xx-small text-muted">@permission.Key</div>
                                                    </div>
                                                </label>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <bg-button type="submit" variant="primary" class="w-100">@T["SaveRoleAction"]</bg-button>
                </form>
            </article>
        </div>

        <article class="admin-roles-detail bg-card shadow-sm">
            @if (activeRole is null)
            {
                <div class="text-center py-5">
                    <i class="bi bi-shield-lock-fill fs-1 text-muted opacity-25 d-block mb-3"></i>
                    <h5 class="fw-bold text-dark">@T["RolesListTitle"]</h5>
                    <p class="compact-copy mb-0">@T["RolesPage_DirectorySummary"]</p>
                </div>
            }
            else
            {
                <div class="admin-users-card-header">
                    <div>
                        <h4 class="fw-bold text-dark m-0">@activeRole.Name</h4>
                        <div class="entity-subtitle">@(string.IsNullOrWhiteSpace(activeRole.Description) ? T["RolesPage_NoDescription"].Value : activeRole.Description)</div>
                    </div>
                    <bg-badge variant="light">@activeRole.PermissionKeys.Count @T["PermissionsField"]</bg-badge>
                </div>

                <p class="compact-copy mb-4">@T["RolesPage_SelectedRoleSummary"]</p>

                <div class="admin-role-facts-grid">
                    <section class="admin-role-fact-card">
                        <span class="section-caption x-small">@T["RoleNameField"]</span>
                        <strong>@activeRole.Name</strong>
                    </section>
                    <section class="admin-role-fact-card">
                        <span class="section-caption x-small">@T["DescriptionField"]</span>
                        <strong>@(string.IsNullOrWhiteSpace(activeRole.Description) ? T["RolesPage_NoDescription"].Value : activeRole.Description)</strong>
                    </section>
                    <section class="admin-role-fact-card">
                        <span class="section-caption x-small">@T["RolesPage_PermissionCoverageTitle"]</span>
                        <strong>@activeRoleGroups.Length @T["PermissionGroup_Administration"]</strong>
                    </section>
                </div>

                <section class="admin-role-permissions-panel">
                    <div class="admin-users-card-header">
                        <div>
                            <h5 class="fw-bold text-dark m-0">@T["RolesPage_AssignedPermissionsTitle"]</h5>
                            <p class="compact-copy mb-0">@T["RolesPage_DirectorySummary"]</p>
                        </div>
                    </div>

                    @if (activeRole.PermissionKeys.Count == 0)
                    {
                        <p class="x-small text-muted italic mb-0">@T["NoPermissionsAssigned"]</p>
                    }
                    else
                    {
                        <div class="admin-role-permission-groups">
                            @foreach (var group in activeRoleGroups)
                            {
                                <section class="admin-role-permission-group">
                                    <div class="section-caption x-small">@T[$"PermissionGroup_{group.Area}"]</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var permission in group.Permissions)
                                        {
                                            <bg-badge variant="light">@T[$"Permission_{permission.Key}"]</bg-badge>
                                        }
                                    </div>
                                </section>
                            }
                        </div>
                    }
                </section>
            }
        </article>
    </div>
</section>
