@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Administration.RolesModel
@{
    ViewData["Title"] = T["RolesPageTitle"];
    var permissionCount = Model.PermissionGroups.Sum(group => group.Permissions.Count);
    var activeRole = Model.ActiveRole;
    var activeRolePermissionKeys = activeRole?.PermissionKeys.ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var activeRoleGroups = activeRole is null
        ? Array.Empty<BG.Web.Pages.Administration.RolesModel.PermissionGroupViewModel>()
        : Model.PermissionGroups
            .Select(group => new BG.Web.Pages.Administration.RolesModel.PermissionGroupViewModel(
                group.Area,
                group.Permissions.Where(permission => activeRolePermissionKeys.Contains(permission.Key)).ToArray()))
            .Where(group => group.Permissions.Count > 0)
            .ToArray();
}

<div class="canvas_stage">
    <section class="section-shell admin-roles-surface w-100 d-flex flex-column">
        <div class="inline_toolbar sticky-top">
            <div class="inline_toolbartitle">
                <i class="bi bi-shield-lock text-kfshrc-green"></i>
                <span>@T["RolesPageHeading"]</span>
            </div>
            <div class="toolbar_actions">
                <a asp-page="/Administration/Roles" class="bg-btn bg-btn-white border d-flex align-items-center gap-2">
                    <i class="bi bi-plus-lg"></i>
                    <span>@T["SharedCreateAction"]</span>
                </a>
                <button type="submit" class="bg-btn bg-btn-primary ms-2 d-flex align-items-center gap-2">
                    <i class="bi bi-check2-circle"></i>
                    <span>@T["SharedSaveAction"]</span>
                </button>
            </div>
        </div>

        <div class="flex-grow-1 overflow-auto">
            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="notice-banner is-success mb-4">@Model.StatusMessage</div>
            }

            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <form method="post" class="admin-roles-layout-wrapper">
                <div class="bg-metric-grid mb-4">
                    <div class="bg-metric-card">
                        <span class="bg-metric-label">@T["RolesListTitle"]</span>
                        <span class="bg-metric-value">@Model.Roles.Count</span>
                    </div>
                    <div class="bg-metric-card is-important">
                        <span class="bg-metric-label">@T["PermissionsField"]</span>
                        <span class="bg-metric-value is-financial">@permissionCount</span>
                    </div>
                    <div class="bg-metric-card">
                        <span class="bg-metric-label">@T["PermissionGroup_Administration"]</span>
                        <span class="bg-metric-value text-info">@Model.PermissionGroups.Count</span>
                    </div>
                </div>

                <div class="bg-workspace-grid-3col">
            @* Column 1: Directory *@
            <aside class="admin-roles-sidebar">
                <article class="admin-roles-directory shadow-sm">
                    <header class="admin-workspace-column-header p-4 pb-0 border-0 d-none">
                        <div>
                            <h5 class="admin-column-title">@T["RolesListTitle"]</h5>
                            <p class="admin-column-summary">@T["RolesPage_DirectorySummary"]</p>
                        </div>
                        <div class="admin-column-meta">
                            <bg-badge variant="light">@Model.Roles.Count</bg-badge>
                        </div>
                    </header>

                    <div class="admin-roles-directory-list">
                        @foreach (var role in Model.Roles)
                        {
                            var isActive = activeRole?.Id == role.Id;
                            var permissionGroupCount = Model.PermissionGroups.Count(group => group.Permissions.Any(permission => role.PermissionKeys.Contains(permission.Key, StringComparer.OrdinalIgnoreCase)));

                            <a asp-page="/Administration/Roles"
                               asp-all-route-data="Model.BuildSelectionRoute(role.Id)"
                               class="admin-role-item @(isActive ? "active" : null)">
                                <div class="d-flex justify-content-between align-items-center w-100">
                                    <div>
                                        <div class="x-small text-muted text-uppercase fw-bold mb-1">@T["RolesListTitle"]</div>
                                        <strong class="d-block text-dark">@T[role.Name]</strong>
                                        <div class="xx-small text-muted mt-1">@(string.IsNullOrWhiteSpace(role.Description) ? T["RolesPage_NoDescription"].Value : T[role.Description].Value)</div>
                                    </div>
                                    <div class="text-end">
                                        <bg-badge variant="light">
                                            @role.PermissionKeys.Count @T["PermissionsField"]
                                        </bg-badge>
                                    </div>
                                </div>
                            </a>
                        }
                    </div>

                    <div class="d-none">
                        <a asp-page="/Administration/Roles" class="bg-button is-primary w-100 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-plus-lg"></i>
                            @T["CreateRoleTitle"]
                        </a>
                    </div>
                </article>
            </aside>

            @* Column 2: Identity *@
            <article class="admin-roles-identity">
                <header class="admin-workspace-column-header">
                    <div>
                        <h5 class="admin-column-title">
                            @(activeRole is null ? T["CreateRoleTitle"] : T["RolesPage_IdentityTitle"])
                        </h5>
                        <p class="admin-column-summary">@T["RolesPage_IdentitySummary"]</p>
                    </div>
                </header>

                <div class="d-flex flex-column gap-4">
                    <div>
                        <label class="form-label x-small fw-bold opacity-75" asp-for="Input.Name">@T["RoleNameField"]</label>
                        <input asp-for="Input.Name" class="form-control rounded-4 p-3 fs-5 fw-bold" maxlength="64" placeholder="@T["RoleNamePlaceholder"]" />
                        <span asp-validation-for="Input.Name" class="text-danger x-small"></span>
                    </div>

                    <div>
                        <label class="form-label x-small fw-bold opacity-75" asp-for="Input.Description">@T["DescriptionField"]</label>
                        <textarea asp-for="Input.Description" class="form-control rounded-4 p-3 small" rows="4" maxlength="256" placeholder="@T["DescriptionPlaceholder"]"></textarea>
                    </div>

                    <div class="mt-5 pt-5 border-top d-none">
                        <bg-button type="submit" variant="primary" class="w-100 py-3 shadow-green">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            @(activeRole is null ? T["CreateRoleAction"] : T["UpdateRoleAction"])
                        </bg-button>
                    </div>
                </div>
            </article>

            @* Column 3: Authority *@
            <article class="admin-roles-authority">
                <header class="admin-workspace-column-header">
                    <div>
                        <h5 class="admin-column-title">@T["RolesPage_AssignedPermissionsTitle"]</h5>
                        <p class="admin-column-summary">@T["RolesPage_AuthoritySummary"]</p>
                    </div>
                    <div class="admin-column-meta">
                        <bg-badge variant="light">@Model.PermissionGroups.Count @T["PermissionGroup_Administration"]</bg-badge>
                    </div>
                </header>

                <div class="admin-role-picker d-flex flex-column gap-5">
                    @foreach (var group in Model.PermissionGroups)
                    {
                        <div class="admin-role-picker-group">
                            <div class="x-small fw-bold text-brand-green mb-3 opacity-75 text-uppercase letter-spacing-1">@T[$"PermissionGroup_{group.Area}"]</div>
                            <div class="admin-permission-grid">
                                @foreach (var permission in group.Permissions)
                                {
                                    <label class="admin-role-checkbox-card d-flex align-items-center gap-3 p-3 bg-white rounded-3 border cursor-pointer h-100">
                                        <input type="checkbox" name="Input.SelectedPermissionKeys" value="@permission.Key" 
                                               class="form-check-input mt-0" @(Model.Input.SelectedPermissionKeys.Contains(permission.Key, StringComparer.OrdinalIgnoreCase) ? "checked" : null) />
                                        <div class="flex-grow-1">
                                            <div class="x-small fw-bold text-dark mb-1">@T[$"Permission_{permission.Key}"]</div>
                                            <div class="xx-small text-muted opacity-50 text-uppercase">@permission.Key</div>
                                        </div>
                                    </label>
                                }
                            </div>
                        </div>
                    }
                </div>
            </article>
        </div>
            </form>
        </div>
    </section>
</div>
