@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Administration.DelegationsModel
@{
    ViewData["Title"] = T["ApprovalDelegation_PageTitle"];
    var now = DateTimeOffset.UtcNow;
    var activeCount = Model.Snapshot.Delegations.Count(delegation => !delegation.RevokedAtUtc.HasValue && delegation.StartsAtUtc <= now && delegation.EndsAtUtc >= now);
    var futureCount = Model.Snapshot.Delegations.Count(delegation => !delegation.RevokedAtUtc.HasValue && delegation.StartsAtUtc > now);
    var revokedCount = Model.Snapshot.Delegations.Count(delegation => delegation.RevokedAtUtc.HasValue);
    var activeDelegation = Model.ActiveDelegation;
}

<section class="section-shell admin-delegations-surface">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice-banner is-success">@Model.StatusMessage</div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <div class="mb-5 pb-4 border-bottom">
        <section-caption>@T["NavDelegations"]</section-caption>
        <h1 class="fw-bold text-dark m-0">@T["ApprovalDelegation_Heading"]</h1>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="bg-card shadow-sm p-4 text-center">
                <div class="section-caption x-small mb-1">@T["ApprovalDelegation_ListTitle"]</div>
                <div class="display-6 fw-bold text-dark">@Model.Snapshot.Delegations.Count</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-card shadow-sm p-4 text-center">
                <div class="section-caption x-small mb-1">@T["ApprovalDelegation_StatusActive"]</div>
                <div class="display-6 fw-bold text-brand-green">@activeCount</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-card shadow-sm p-4 text-center">
                <div class="section-caption x-small mb-1">@T["Pending"]</div>
                <div class="display-6 fw-bold text-brand-gold">@futureCount</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-card shadow-sm p-4 text-center">
                <div class="section-caption x-small mb-1">@T["ApprovalDelegation_StatusRevoked"]</div>
                <div class="display-6 fw-bold text-danger">@revokedCount</div>
            </div>
        </div>
    </div>

    <div class="admin-delegations-layout">
        <div class="admin-delegations-sidebar">
            <article class="admin-delegations-directory bg-card shadow-sm">
                <div class="admin-users-card-header">
                    <div>
                        <h5 class="fw-bold text-dark m-0">@T["ApprovalDelegation_ListTitle"]</h5>
                        <p class="compact-copy mb-0">@T["ApprovalDelegation_ListSummary"]</p>
                    </div>
                    <bg-badge variant="light">@T["ApprovalDelegation_CountBadge", Model.Snapshot.Delegations.Count]</bg-badge>
                </div>

                @if (Model.Snapshot.Delegations.Count == 0)
                {
                    <div class="text-center py-5">
                        <i class="bi bi-person-badge-fill display-1 text-light mb-4 d-block"></i>
                        <p class="text-secondary mb-0">@T["ApprovalDelegation_Empty"]</p>
                    </div>
                }
                else
                {
                    <div class="admin-delegations-directory-list">
                        @foreach (var delegation in Model.Snapshot.Delegations)
                        {
                            var isActive = activeDelegation?.Id == delegation.Id;
                            var statusVariant = delegation.RevokedAtUtc.HasValue ? "danger" : (delegation.StartsAtUtc <= now && delegation.EndsAtUtc >= now ? "success" : "warning");
                            var periodText = $"{delegation.StartsAtUtc.ToLocalTime().ToString("g", System.Globalization.CultureInfo.CurrentCulture)} -> {delegation.EndsAtUtc.ToLocalTime().ToString("g", System.Globalization.CultureInfo.CurrentCulture)}";

                            <a asp-page="/Administration/Delegations"
                               asp-all-route-data="Model.BuildSelectionRoute(delegation.Id)"
                               class="request-queue-link admin-delegation-link @(isActive ? "active" : null)">
                                <div class="request-queue-copy">
                                    <strong>@delegation.DelegateDisplayName</strong>
                                    <div class="entity-subtitle">@T["ApprovalDelegation_DelegateForSummary", delegation.RoleName]</div>
                                    <p class="compact-copy mb-0">@delegation.DelegatorDisplayName</p>
                                </div>
                                <div class="request-queue-meta">
                                    @if (isActive)
                                    {
                                        <span class="surface-action-kicker">@T["SurfaceQueue_CurrentItemLabel"]</span>
                                    }
                                    <bg-badge variant="@statusVariant">@T[delegation.StatusResourceKey]</bg-badge>
                                    <span class="section-caption">@periodText</span>
                                </div>
                            </a>
                        }
                    </div>
                }
            </article>

            <article class="admin-delegations-create bg-card shadow-sm">
                <div class="admin-users-card-header">
                    <div>
                        <h5 class="fw-bold text-dark m-0">@T["ApprovalDelegation_CreateTitle"]</h5>
                        <p class="compact-copy mb-0">@T["ApprovalDelegation_CreateSummary"]</p>
                    </div>
                </div>

                <form method="post" asp-page-handler="Create" class="d-flex flex-column gap-4">
                    <div>
                        <label class="form-label x-small fw-bold opacity-75" for="delegator-user">@T["ApprovalDelegation_DelegatorField"]</label>
                        <select id="delegator-user" name="Input.DelegatorUserId" class="form-select rounded-4 p-2 small">
                            <option value="">@T["ApprovalDelegation_SelectUser"]</option>
                            @foreach (var user in Model.Snapshot.AvailableUsers)
                            {
                                <option value="@user.Id" selected="@(user.Id == Model.Input.DelegatorUserId ? "selected" : null)">
                                    @user.DisplayName (@user.Username)
                                </option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="form-label x-small fw-bold opacity-75" for="delegate-user">@T["ApprovalDelegation_DelegateField"]</label>
                        <select id="delegate-user" name="Input.DelegateUserId" class="form-select rounded-4 p-2 small">
                            <option value="">@T["ApprovalDelegation_SelectUser"]</option>
                            @foreach (var user in Model.Snapshot.AvailableUsers)
                            {
                                <option value="@user.Id" selected="@(user.Id == Model.Input.DelegateUserId ? "selected" : null)">
                                    @user.DisplayName (@user.Username)
                                </option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="form-label x-small fw-bold opacity-75" for="delegation-role">@T["ApprovalDelegation_RoleField"]</label>
                        <select id="delegation-role" name="Input.RoleId" class="form-select rounded-4 p-2 small">
                            <option value="">@T["ApprovalDelegation_SelectRole"]</option>
                            @foreach (var role in Model.Snapshot.AvailableRoles)
                            {
                                <option value="@role.Id" selected="@(role.Id == Model.Input.RoleId ? "selected" : null)">@role.Name</option>
                            }
                        </select>
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label x-small fw-bold opacity-75" for="delegation-start">@T["ApprovalDelegation_StartField"]</label>
                            <input id="delegation-start" name="Input.StartsAtUtc" type="datetime-local" class="form-control rounded-4 p-2 x-small" value="@(Model.Input.StartsAtUtc?.ToLocalTime().ToString("yyyy-MM-ddTHH:mm"))" />
                        </div>
                        <div class="col-6">
                            <label class="form-label x-small fw-bold opacity-75" for="delegation-end">@T["ApprovalDelegation_EndField"]</label>
                            <input id="delegation-end" name="Input.EndsAtUtc" type="datetime-local" class="form-control rounded-4 p-2 x-small" value="@(Model.Input.EndsAtUtc?.ToLocalTime().ToString("yyyy-MM-ddTHH:mm"))" />
                        </div>
                    </div>

                    <div>
                        <label class="form-label x-small fw-bold opacity-75" for="delegation-reason">@T["ApprovalDelegation_ReasonField"]</label>
                        <textarea id="delegation-reason" name="Input.Reason" class="form-control rounded-4 p-2 small" rows="2">@Model.Input.Reason</textarea>
                    </div>

                    <bg-button type="submit" variant="primary" class="w-100">@T["ApprovalDelegation_CreateAction"]</bg-button>
                </form>
            </article>
        </div>

        <article class="admin-delegations-detail bg-card shadow-sm">
            @if (activeDelegation is null)
            {
                <div class="text-center py-5">
                    <i class="bi bi-person-badge-fill fs-1 text-muted opacity-25 d-block mb-3"></i>
                    <h5 class="fw-bold text-dark">@T["ApprovalDelegation_ListTitle"]</h5>
                    <p class="compact-copy mb-0">@T["ApprovalDelegation_ListSummary"]</p>
                </div>
            }
            else
            {
                var createdAtText = activeDelegation.CreatedAtUtc.ToLocalTime().ToString("g", System.Globalization.CultureInfo.CurrentCulture);
                var revokedAtText = activeDelegation.RevokedAtUtc?.ToLocalTime().ToString("g", System.Globalization.CultureInfo.CurrentCulture);
                var startsAtText = activeDelegation.StartsAtUtc.ToLocalTime().ToString("g", System.Globalization.CultureInfo.CurrentCulture);
                var endsAtText = activeDelegation.EndsAtUtc.ToLocalTime().ToString("g", System.Globalization.CultureInfo.CurrentCulture);
                var statusVariant = activeDelegation.RevokedAtUtc.HasValue ? "danger" : (activeDelegation.StartsAtUtc <= now && activeDelegation.EndsAtUtc >= now ? "success" : "warning");

                <div class="admin-users-card-header">
                    <div>
                        <h4 class="fw-bold text-dark m-0">@activeDelegation.DelegateDisplayName</h4>
                        <div class="entity-subtitle">@T["ApprovalDelegation_DelegateForSummary", activeDelegation.RoleName]</div>
                    </div>
                    <bg-badge variant="@statusVariant">@T[activeDelegation.StatusResourceKey]</bg-badge>
                </div>

                <p class="compact-copy mb-4">@T["ApprovalDelegation_SelectedSummary"]</p>

                <div class="admin-delegation-facts-grid">
                    <section class="admin-role-fact-card">
                        <span class="section-caption x-small">@T["ApprovalDelegation_DelegatorLabel"]</span>
                        <strong>@activeDelegation.DelegatorDisplayName</strong>
                    </section>
                    <section class="admin-role-fact-card">
                        <span class="section-caption x-small">@T["ApprovalDelegation_RoleField"]</span>
                        <strong>@activeDelegation.RoleName</strong>
                    </section>
                    <section class="admin-role-fact-card">
                        <span class="section-caption x-small">@T["ApprovalDelegation_PeriodLabel"]</span>
                        <strong>@startsAtText</strong>
                        <div class="x-small text-muted">@endsAtText</div>
                    </section>
                    <section class="admin-role-fact-card">
                        <span class="section-caption x-small">@T["ApprovalDelegation_CreatedAtLabel"]</span>
                        <strong>@createdAtText</strong>
                    </section>
                </div>

                <section class="admin-role-permissions-panel">
                    <div class="admin-role-permission-groups">
                        <section class="admin-role-permission-group">
                            <div class="section-caption x-small">@T["ApprovalDelegation_ReasonNotesLabel"]</div>
                            <div class="compact-copy">@(string.IsNullOrWhiteSpace(activeDelegation.Reason) ? T["ApprovalDelegation_NoReason"].Value : activeDelegation.Reason)</div>
                        </section>

                        @if (activeDelegation.RevokedAtUtc.HasValue)
                        {
                            <section class="admin-role-permission-group">
                                <div class="section-caption x-small">@T["ApprovalDelegation_RevokedAtLabel"]</div>
                                <strong>@revokedAtText</strong>
                                <div class="compact-copy">@(string.IsNullOrWhiteSpace(activeDelegation.RevocationReason) ? T["ApprovalDelegation_NoReason"].Value : activeDelegation.RevocationReason)</div>
                            </section>
                        }
                    </div>
                </section>

                @if (!activeDelegation.RevokedAtUtc.HasValue)
                {
                    <section class="admin-user-password-panel">
                        <label class="section-caption x-small">@T["ApprovalDelegation_RevokeAction"]</label>
                        <form method="post" asp-page-handler="Revoke" class="admin-user-password-form">
                            <input type="hidden" name="delegationId" value="@activeDelegation.Id" />
                            <div class="flex-grow-1">
                                <label class="form-label x-small fw-bold opacity-75" for="revokeReason">@T["ApprovalDelegation_RevokeReasonField"]</label>
                                <input id="revokeReason" name="reason" class="form-control rounded-4 p-2 x-small border-danger" placeholder="@T["ApprovalDelegation_RevokeReasonField"]" />
                            </div>
                            <bg-button type="submit" variant="light" class="text-danger flex-shrink-0">@T["ApprovalDelegation_RevokeAction"]</bg-button>
                        </form>
                    </section>
                }
            }
        </article>
    </div>
</section>
