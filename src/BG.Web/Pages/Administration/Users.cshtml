@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Administration.UsersModel
@{
    string BuildInitials(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "BG";
        }

        var initials = new List<char>(2);
        foreach (var part in value.Split(' ', StringSplitOptions.RemoveEmptyEntries))
        {
            initials.Add(char.ToUpperInvariant(part[0]));
            if (initials.Count == 2)
            {
                break;
            }
        }

        return initials.Count == 0 ? "BG" : new string(initials.ToArray());
    }

    ViewData["Title"] = T["UsersPageTitle"];
    var activeUsers = Model.Users.Count(user => user.IsActive);
    var credentialReadyUsers = Model.Users.Count(user => user.HasLocalPassword);
    var assignedRoles = Model.Users.Sum(user => user.Roles.Count);
    var activeUser = Model.ActiveUser;
}

<div class="canvas_stage">
    <section class="section-shell admin-users-surface w-100 d-flex flex-column">
        <div class="inline_toolbar sticky-top">
            <div class="inline_toolbartitle">
                <i class="bi bi-people text-kfshrc-green"></i>
                <span>@T["UsersPageHeading"]</span>
                @if (activeUser != null)
                {
                    <span class="opacity-25 mx-2">/</span>
                    <span class="text-muted small">@activeUser.DisplayName</span>
                }
            </div>
            <div class="toolbar_actions">
                @if (activeUser != null)
                {
                    <button type="button" onclick="document.getElementById('userUpdateForm')?.submit()" class="bg-btn bg-btn-primary d-flex align-items-center gap-2">
                        <i class="bi bi-shield-check"></i>
                        <span>@T["SharedSaveAction"]</span>
                    </button>
                }
                else
                {
                    <button type="button" onclick="document.getElementById('createUserForm')?.submit()" class="bg-btn bg-btn-primary d-flex align-items-center gap-2">
                        <i class="bi bi-person-plus-fill"></i>
                        <span>@T["SharedSaveAction"]</span>
                    </button>
                }
            </div>
        </div>

        <div class="flex-grow-1 overflow-auto">
            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="notice-banner is-success mb-4">@Model.StatusMessage</div>
            }

            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <div class="bg-metric-grid mb-4">
        <div class="bg-metric-card">
            <span class="bg-metric-label">@T["UsersListTitle"]</span>
            <span class="bg-metric-value">@Model.Users.Count</span>
        </div>
        <div class="bg-metric-card is-important">
            <span class="bg-metric-label">@T["Status_Active"]</span>
            <span class="bg-metric-value is-financial">@activeUsers</span>
        </div>
        <div class="bg-metric-card">
            <span class="bg-metric-label">@T["Credentials_Ready"]</span>
            <span class="bg-metric-value text-info">@credentialReadyUsers</span>
        </div>
        <div class="bg-metric-card">
            <span class="bg-metric-label">@T["RolesField"]</span>
            <span class="bg-metric-value">@assignedRoles</span>
        </div>
    </div>

    <div class="bg-workspace-grid-3col">
        @* Column 1: Directory *@
        <aside class="admin-users-sidebar">
            <article class="admin-users-directory shadow-sm">
                <header class="admin-workspace-column-header p-4 pb-0 border-0">
                    <div>
                        <h5 class="admin-column-title">@T["UsersListTitle"]</h5>
                        <p class="admin-column-summary">@Model.Users.Count @T["UsersListTitle"]</p>
                    </div>
                    <div class="admin-column-meta">
                        <bg-badge variant="light">@activeUsers @T["Status_Active"]</bg-badge>
                    </div>
                </header>

                <div class="admin-users-directory-list">
                    @foreach (var user in Model.Users)
                    {
                        var isActive = activeUser?.Id == user.Id;

                        <a asp-page="/Administration/Users"
                           asp-all-route-data="Model.BuildSelectionRoute(user.Id)"
                           class="admin-role-item @(isActive ? "active" : null)">
                            <div class="d-flex justify-content-between align-items-center w-100">
                                <div class="pe-3">
                                    <div class="x-small text-muted text-uppercase fw-bold mb-1">@T[$"SourceType_{user.SourceType}"]</div>
                                    <strong class="d-block text-dark">@user.DisplayName</strong>
                                    <div class="xx-small text-muted mt-1">@@@user.Username</div>
                                </div>
                                <div class="text-end">
                                    <div class="mb-1">
                                        <bg-badge variant="@(user.IsActive ? "success" : "light")" class="xx-small">
                                            @T[user.IsActive ? "Status_Active" : "Status_Inactive"]
                                        </bg-badge>
                                    </div>
                                    @if(user.HasLocalPassword) {
                                        <i class="bi bi-shield-check text-info xx-small" title="@T["Credentials_Ready"]"></i>
                                    }
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </article>
        </aside>

        @* Column 2: Profile & Governance *@
        <article class="admin-users-profile">
            @if (activeUser is null)
            {
                <header class="admin-workspace-column-header p-4 pb-0 border-0 d-none">
                    <div>
                        <h5 class="admin-column-title">@T["CreateUserTitle"]</h5>
                        <p class="admin-column-summary">@T["UsersPage_CreateSummary"]</p>
                    </div>
                </header>

                <form method="post" id="createUserForm" class="d-flex flex-column gap-4 p-4">
                    <div>
                        <label class="form-label x-small fw-bold opacity-75" asp-for="Input.Username">@T["UsernameField"]</label>
                        <input asp-for="Input.Username" class="form-control rounded-4 p-3 fs-6" maxlength="64" />
                    </div>
                    <div>
                        <label class="form-label x-small fw-bold opacity-75" asp-for="Input.DisplayName">@T["DisplayNameField"]</label>
                        <input asp-for="Input.DisplayName" class="form-control rounded-4 p-3 fs-6" maxlength="128" />
                    </div>
                    <div>
                        <label class="form-label x-small fw-bold opacity-75" asp-for="Input.Email">@T["EmailField"]</label>
                        <input asp-for="Input.Email" class="form-control rounded-4 p-3 fs-6" maxlength="256" />
                    </div>
                    <div>
                        <label class="form-label x-small fw-bold opacity-75" asp-for="Input.InitialPassword">@T["PasswordField"]</label>
                        <input asp-for="Input.InitialPassword" class="form-control rounded-4 p-3 fs-6" type="password" maxlength="128" />
                    </div>

                    <div class="mt-4 pt-4 border-top d-none">
                        <bg-button type="submit" variant="primary" class="w-100 py-3 shadow-green">
                            <i class="bi bi-person-plus-fill me-2"></i>@T["SaveUserAction"]
                        </bg-button>
                    </div>
                </form>
            }
            else
            {
                var activeUserInitials = BuildInitials(activeUser.DisplayName);
                var createdAtText = activeUser.CreatedAtUtc.ToLocalTime().ToString("d", System.Globalization.CultureInfo.CurrentCulture);

                <header class="admin-workspace-column-header">
                    <div>
                        <h5 class="admin-column-title">@T["UsersPage_IdentityTitle"]</h5>
                        <p class="admin-column-summary">@activeUser.DisplayName</p>
                    </div>
                    <div class="admin-column-meta">
                        <span class="admin-user-avatar">@activeUserInitials</span>
                    </div>
                </header>

                <div class="d-flex flex-column gap-4">
                    <div class="admin-role-facts-grid" style="grid-template-columns: 1fr;">
                        <section class="admin-user-fact-card">
                            <span>@T["UsernameField"]</span>
                            <strong>@@@activeUser.Username</strong>
                        </section>
                        <section class="admin-user-fact-card">
                            <span>@T["EmailField"]</span>
                            <strong>@(string.IsNullOrWhiteSpace(activeUser.Email) ? "-" : activeUser.Email)</strong>
                        </section>
                        <section class="admin-user-fact-card">
                            <span>@T["SourceField"]</span>
                            <strong>@T[$"SourceType_{activeUser.SourceType}"]</strong>
                        </section>
                        <section class="admin-user-fact-card">
                            <span>@T["UsersPage_OnboardedTitle"]</span>
                            <strong>@createdAtText</strong>
                        </section>
                    </div>

                    <div class="mt-4 pt-4 border-top">
                        <h6 class="x-small fw-bold text-dark mb-4 text-uppercase">@T["UsersPage_ResetPasswordTitle"]</h6>
                        <form method="post" asp-page-handler="SetPassword" class="d-flex flex-column gap-3">
                            <input type="hidden" name="userId" value="@activeUser.Id" />
                            <div>
                                <label class="form-label xx-small fw-bold opacity-50 mb-1">@T["ResetPasswordField"]</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-key"></i></span>
                                    <input name="newPassword" class="form-control xx-small p-2" type="password" placeholder="@T["UsersPage_NewPasswordPlaceholder"]" autocomplete="new-password" />
                                </div>
                            </div>
                            <bg-button type="submit" variant="light" class="w-100 py-2 border">
                                @T["SavePasswordAction"]
                            </bg-button>
                        </form>
                    </div>
                </div>
            }
        </article>

        @* Column 3: Access & Roles *@
        <article class="admin-users-access">
            <header class="admin-workspace-column-header p-4 pb-0 border-0 d-none">

            @if (activeUser is null)
            {
                <div class="text-center py-5 opacity-25">
                    <i class="bi bi-shield-lock display-4 d-block mb-3"></i>
                    <p class="small fw-bold text-muted">@T["WorkspaceShell_SelectUser"]</p>
                </div>
            }
            else
            {
                <form method="post" id="userUpdateForm" class="h-100 d-flex flex-column">
                    <input type="hidden" asp-for="Input.Username" value="@activeUser.Username" />
                    <input type="hidden" asp-for="Input.DisplayName" value="@activeUser.DisplayName" />
                    <input type="hidden" asp-for="Input.Email" value="@activeUser.Email" />

                    <div class="flex-grow-1 overflow-y-auto pe-2">
                        <div class="d-flex flex-column gap-3">
                            @foreach (var role in Model.Roles)
                            {
                                var isAssigned = activeUser.Roles.Contains(role.Name);
                                <label class="admin-role-item rounded-4 border p-3 cursor-pointer d-flex align-items-center gap-3 transition-all @(isAssigned ? "bg-light border-brand-green" : "")">
                                    <input type="checkbox" name="Input.SelectedRoleIds" value="@role.Id" class="form-check-input mt-0" checked="@(isAssigned ? "checked" : null)" />
                                    <div>
                                        <strong class="d-block text-dark small">@role.Name</strong>
                                        @if (!string.IsNullOrWhiteSpace(role.Description))
                                        {
                                            <div class="xx-small text-muted line-clamp-1">@role.Description</div>
                                        }
                                    </div>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="mt-4 pt-4 border-top d-none">
                        <bg-button type="submit" id="userUpdateFormSubmit" variant="brand" class="w-100 py-3 shadow-green">
                            <i class="bi bi-shield-check me-2"></i>@T["UpdateRoleAction"]
                        </bg-button>
                    </div>
                </form>
            }
        </article>
    </div>
        </div>
    </section>
</div>
