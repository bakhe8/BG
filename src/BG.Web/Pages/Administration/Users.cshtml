@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Administration.UsersModel
@{
    string BuildInitials(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "BG";
        }

        var initials = new List<char>(2);
        foreach (var part in value.Split(' ', StringSplitOptions.RemoveEmptyEntries))
        {
            initials.Add(char.ToUpperInvariant(part[0]));
            if (initials.Count == 2)
            {
                break;
            }
        }

        return initials.Count == 0 ? "BG" : new string(initials.ToArray());
    }

    ViewData["Title"] = T["UsersPageTitle"];
    var activeUsers = Model.Users.Count(user => user.IsActive);
    var credentialReadyUsers = Model.Users.Count(user => user.HasLocalPassword);
    var assignedRoles = Model.Users.Sum(user => user.Roles.Count);
    var activeUser = Model.ActiveUser;
}

<section class="section-shell admin-users-surface">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice-banner is-success">@Model.StatusMessage</div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <div class="mb-5 pb-4 border-bottom">
        <section-caption>@T["NavUsers"]</section-caption>
        <h1 class="fw-bold text-dark m-0">@T["UsersPageHeading"]</h1>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="bg-card shadow-sm p-4 text-center">
                <div class="section-caption x-small mb-1">@T["UsersListTitle"]</div>
                <div class="display-6 fw-bold text-dark">@Model.Users.Count</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-card shadow-sm p-4 text-center">
                <div class="section-caption x-small mb-1">@T["Status_Active"]</div>
                <div class="display-6 fw-bold text-brand-green">@activeUsers</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-card shadow-sm p-4 text-center">
                <div class="section-caption x-small mb-1">@T["Credentials_Ready"]</div>
                <div class="display-6 fw-bold text-brand-gold">@credentialReadyUsers</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-card shadow-sm p-4 text-center">
                <div class="section-caption x-small mb-1">@T["RolesField"]</div>
                <div class="display-6 fw-bold text-dark">@assignedRoles</div>
            </div>
        </div>
    </div>

    <div class="admin-users-layout">
        <div class="admin-users-sidebar">
            <article class="admin-users-directory bg-card shadow-sm">
                <div class="admin-users-card-header">
                    <div>
                        <h5 class="fw-bold text-dark m-0">@T["UsersListTitle"]</h5>
                        <p class="compact-copy mb-0">@T["UsersPage_DirectorySummary"]</p>
                    </div>
                    <bg-badge variant="light">@T["UsersPage_CountBadge", Model.Users.Count]</bg-badge>
                </div>

                @if (Model.Users.Count == 0)
                {
                    <div class="text-center py-5">
                        <i class="bi bi-people-fill display-1 text-light mb-4 d-block"></i>
                        <p class="text-secondary mb-0">@T["EmptyUsers"]</p>
                    </div>
                }
                else
                {
                    <div class="admin-users-directory-list">
                        @foreach (var user in Model.Users)
                        {
                            var isActive = activeUser?.Id == user.Id;
                            var userInitials = BuildInitials(user.DisplayName);

                            <a asp-page="/Administration/Users"
                               asp-all-route-data="Model.BuildSelectionRoute(user.Id)"
                               class="request-queue-link admin-user-link @(isActive ? "active" : null)">
                                <div class="request-queue-copy">
                                    <div class="admin-user-link-header">
                                        <span class="admin-user-avatar">@userInitials</span>
                                        <div>
                                            <strong>@user.DisplayName</strong>
                                            <div class="entity-subtitle">@@@user.Username</div>
                                        </div>
                                    </div>
                                    <p class="compact-copy mb-0">
                                        @T[$"SourceType_{user.SourceType}"]
                                        @if (user.Roles.Count > 0)
                                        {
                                            <span> · @string.Join(" · ", user.Roles.Take(2))</span>
                                        }
                                    </p>
                                </div>
                                <div class="request-queue-meta">
                                    @if (isActive)
                                    {
                                        <span class="surface-action-kicker">@T["SurfaceQueue_CurrentItemLabel"]</span>
                                    }
                                    <bg-badge variant="@(user.IsActive ? "success" : "danger")">
                                        @T[user.IsActive ? "Status_Active" : "Status_Inactive"]
                                    </bg-badge>
                                    <span class="section-caption">@T[user.HasLocalPassword ? "Credentials_Ready" : "Credentials_Missing"]</span>
                                </div>
                            </a>
                        }
                    </div>
                }
            </article>

            <article class="admin-users-create bg-card shadow-sm">
                <div class="admin-users-card-header">
                    <div>
                        <h5 class="fw-bold text-dark m-0">@T["CreateUserTitle"]</h5>
                        <p class="compact-copy mb-0">@T["UsersPage_CreateSummary"]</p>
                    </div>
                </div>

                <form method="post" class="d-flex flex-column gap-4">
                    <div>
                        <label class="form-label x-small fw-bold opacity-75" asp-for="Input.Username">@T["UsernameField"]</label>
                        <input asp-for="Input.Username" class="form-control rounded-4 p-2 small" maxlength="64" />
                    </div>

                    <div>
                        <label class="form-label x-small fw-bold opacity-75" asp-for="Input.DisplayName">@T["DisplayNameField"]</label>
                        <input asp-for="Input.DisplayName" class="form-control rounded-4 p-2 small" maxlength="128" />
                    </div>

                    <div>
                        <label class="form-label x-small fw-bold opacity-75" asp-for="Input.Email">@T["EmailField"]</label>
                        <input asp-for="Input.Email" class="form-control rounded-4 p-2 small" maxlength="256" />
                    </div>

                    <div>
                        <label class="form-label x-small fw-bold opacity-75" asp-for="Input.InitialPassword">@T["PasswordField"]</label>
                        <input asp-for="Input.InitialPassword" class="form-control rounded-4 p-2 small" type="password" maxlength="128" autocomplete="new-password" />
                    </div>

                    <div class="bg-light rounded-4 p-3">
                        <div class="x-small fw-bold text-dark mb-3">@T["RolesField"]</div>
                        @if (Model.Roles.Count == 0)
                        {
                            <p class="x-small text-muted italic mb-0">@T["NoRolesAvailable"]</p>
                        }
                        else
                        {
                            <div class="admin-users-role-picker">
                                @foreach (var role in Model.Roles)
                                {
                                    <label class="d-flex align-items-center gap-3 p-2 bg-white rounded-3 border cursor-pointer">
                                        <input type="checkbox" name="Input.SelectedRoleIds" value="@role.Id" class="form-check-input mt-0" />
                                        <div>
                                            <div class="x-small fw-bold text-dark">@role.Name</div>
                                            @if (!string.IsNullOrWhiteSpace(role.Description))
                                            {
                                                <div class="xx-small text-muted line-clamp-1">@role.Description</div>
                                            }
                                        </div>
                                    </label>
                                }
                            </div>
                        }
                    </div>

                    <bg-button type="submit" variant="primary" class="w-100">@T["SaveUserAction"]</bg-button>
                </form>
            </article>
        </div>

        <article class="admin-users-detail bg-card shadow-sm">
            @if (activeUser is null)
            {
                <div class="text-center py-5">
                    <i class="bi bi-person-lines-fill fs-1 text-muted opacity-25 d-block mb-3"></i>
                    <h5 class="fw-bold text-dark">@T["WorkspaceShell_SelectUser"]</h5>
                    <p class="compact-copy mb-0">@T["UsersPage_DirectorySummary"]</p>
                </div>
            }
            else
            {
                var activeUserInitials = BuildInitials(activeUser.DisplayName);
                var createdAtText = activeUser.CreatedAtUtc.ToLocalTime().ToString("d", System.Globalization.CultureInfo.CurrentCulture);
                var passwordUpdatedText = activeUser.PasswordChangedAtUtc?.ToLocalTime().ToString("d", System.Globalization.CultureInfo.CurrentCulture);

                <div class="admin-users-card-header">
                    <div class="admin-user-detail-header">
                        <span class="admin-user-avatar is-large">@activeUserInitials</span>
                        <div>
                            <h4 class="fw-bold text-dark m-0">@activeUser.DisplayName</h4>
                            <div class="entity-subtitle">@@@activeUser.Username</div>
                        </div>
                    </div>
                    <bg-badge variant="@(activeUser.IsActive ? "success" : "danger")">
                        @T[activeUser.IsActive ? "Status_Active" : "Status_Inactive"]
                    </bg-badge>
                </div>

                <p class="compact-copy mb-4">@T["UsersPage_SelectedUserSummary"]</p>

                <div class="admin-user-detail-grid">
                    <section class="admin-user-detail-section">
                        <label class="section-caption x-small">@T["UsersPage_IdentityTitle"]</label>
                        <div class="admin-user-facts">
                            <div class="admin-user-fact">
                                <span>@T["UsernameField"]</span>
                                <strong>@activeUser.Username</strong>
                            </div>
                            <div class="admin-user-fact">
                                <span>@T["DisplayNameField"]</span>
                                <strong>@activeUser.DisplayName</strong>
                            </div>
                            <div class="admin-user-fact">
                                <span>@T["SourceField"]</span>
                                <strong>@T[$"SourceType_{activeUser.SourceType}"]</strong>
                            </div>
                        </div>
                    </section>

                    <section class="admin-user-detail-section">
                        <label class="section-caption x-small">@T["UsersPage_ContactTitle"]</label>
                        <div class="admin-user-facts">
                            <div class="admin-user-fact">
                                <span>@T["EmailField"]</span>
                                <strong>@(string.IsNullOrWhiteSpace(activeUser.Email) ? T["UsersPage_NoEmailValue"].Value : activeUser.Email)</strong>
                            </div>
                            <div class="admin-user-fact">
                                <span>@T["UsersPage_OnboardedTitle"]</span>
                                <strong>@createdAtText</strong>
                            </div>
                        </div>
                    </section>

                    <section class="admin-user-detail-section">
                        <label class="section-caption x-small">@T["UsersPage_SecurityTitle"]</label>
                        <div class="admin-user-facts">
                            <div class="admin-user-fact">
                                <span>@T["CredentialsField"]</span>
                                <strong>@T[activeUser.HasLocalPassword ? "Credentials_Ready" : "Credentials_Missing"]</strong>
                            </div>
                            <div class="admin-user-fact">
                                <span>@T["PasswordUpdatedAtField"]</span>
                                <strong>@(string.IsNullOrWhiteSpace(passwordUpdatedText) ? "-" : passwordUpdatedText)</strong>
                            </div>
                        </div>
                    </section>

                    <section class="admin-user-detail-section">
                        <label class="section-caption x-small">@T["RolesField"]</label>
                        @if (activeUser.Roles.Count == 0)
                        {
                            <p class="x-small text-muted italic mb-0">@T["NoRolesAssigned"]</p>
                        }
                        else
                        {
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var roleName in activeUser.Roles)
                                {
                                    <bg-badge variant="light">@roleName</bg-badge>
                                }
                            </div>
                        }
                    </section>
                </div>

                <section class="admin-user-password-panel">
                    <label class="section-caption x-small">@T["UsersPage_ResetPasswordTitle"]</label>
                    <form method="post" asp-page-handler="SetPassword" class="admin-user-password-form">
                        <input type="hidden" name="userId" value="@activeUser.Id" />
                        <div class="flex-grow-1">
                            <label class="form-label x-small fw-bold opacity-75" for="newPassword">@T["ResetPasswordField"]</label>
                            <input id="newPassword" name="newPassword" class="form-control rounded-4 p-2 x-small" type="password" placeholder="@T["UsersPage_NewPasswordPlaceholder"]" autocomplete="new-password" />
                        </div>
                        <bg-button type="submit" variant="light" class="text-primary flex-shrink-0">
                            @T["SavePasswordAction"]
                        </bg-button>
                    </form>
                </section>
            }
        </article>
    </div>
</section>
