@page
@using System.Globalization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Administration.WorkflowModel
@{
    ViewData["Title"] = T["WorkflowAdmin_PageTitle"];
    var definitionCount = Model.Snapshot.Definitions.Count;
    var readyCount = Model.Snapshot.Definitions.Count(definition => definition.IsActive);
    var issueCount = Model.Snapshot.Definitions.Count(definition => definition.IntegrityIssueResourceKeys.Count > 0);
    var stageCount = Model.Snapshot.Definitions.Sum(definition => definition.Stages.Count);
    var activeDefinition = Model.ActiveDefinition;
}

<section class="section-shell admin-workflow-surface">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice-banner is-success">@Model.StatusMessage</div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <div class="mb-5 pb-4 border-bottom">
        <section-caption>@T["NavWorkflowAdmin"]</section-caption>
        <h1 class="fw-bold text-dark m-0">@T["WorkflowAdmin_Heading"]</h1>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="bg-light p-4 rounded-4 border-0 h-100 position-relative overflow-hidden">
                <div class="position-absolute top-0 start-0 h-100 bg-brand-green opacity-10" style="width: 4px;"></div>
                <span class="bg-grid-label">@T["WorkflowAdmin_DirectoryTitle"]</span>
                <div class="bg-grid-value fs-2 mt-2">@definitionCount</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-light p-4 rounded-4 border-0 h-100 position-relative overflow-hidden">
                <div class="position-absolute top-0 start-0 h-100 bg-brand-green opacity-25" style="width: 4px;"></div>
                <span class="bg-grid-label">@T["WorkflowAdmin_StatusReady"]</span>
                <div class="bg-grid-value fs-2 mt-2 text-brand-green">@readyCount</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-light p-4 rounded-4 border-0 h-100 position-relative overflow-hidden">
                <div class="position-absolute top-0 start-0 h-100 bg-danger opacity-10" style="width: 4px;"></div>
                <span class="bg-grid-label">@T["WorkflowAdmin_StatusNeedsConfiguration"]</span>
                <div class="bg-grid-value fs-2 mt-2 text-danger">@issueCount</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-light p-4 rounded-4 border-0 h-100 position-relative overflow-hidden">
                <div class="position-absolute top-0 start-0 h-100 bg-secondary opacity-10" style="width: 4px;"></div>
                <span class="bg-grid-label">@T["WorkflowAdmin_CurrentStagesTitle"]</span>
                <div class="bg-grid-value fs-2 mt-2">@stageCount</div>
            </div>
        </div>
    </div>

    @if (Model.Snapshot.Definitions.Count == 0)
    {
        <div class="bg-card shadow-sm p-5 text-center">
            <i class="bi bi-diagram-3-fill display-1 text-light mb-4 d-block"></i>
            <h2 class="fw-bold text-dark">@T["WorkflowAdmin_NoDefinitionsTitle"]</h2>
            <p class="text-secondary">@T["WorkflowAdmin_NoDefinitionsBody"]</p>
        </div>
    }
    else
    {
        <div class="admin-workflow-layout">
            <div class="admin-workflow-sidebar">
                <article class="admin-workflow-directory bg-card shadow-sm">
                    <div class="admin-users-card-header">
                        <div>
                            <h5 class="fw-bold text-dark m-0">@T["WorkflowAdmin_DirectoryTitle"]</h5>
                            <p class="compact-copy mb-0">@T["WorkflowAdmin_DirectorySummary"]</p>
                        </div>
                        <bg-badge variant="light">@T["WorkflowAdmin_DefinitionCountBadge", Model.Snapshot.Definitions.Count]</bg-badge>
                    </div>

                    <div class="admin-workflow-directory-list">
                        @foreach (var definition in Model.Snapshot.Definitions)
                        {
                            var isActive = activeDefinition?.Id == definition.Id;
                            var statusVariant = definition.IsActive ? "success" : "warning";

                            <a asp-page="/Administration/Workflow"
                               asp-all-route-data="Model.BuildSelectionRoute(definition.Id)"
                               class="request-queue-link border-bottom py-3 px-1 @(isActive ? "active" : null)">
                                <div class="d-flex justify-content-between align-items-center w-100">
                                    <div class="request-queue-copy">
                                        <div class="entity-subtitle x-small text-muted text-uppercase fw-bold mb-1">@T[$"RequestType_{definition.RequestType}"]</div>
                                        <strong class="d-block text-dark">@T[definition.TitleResourceKey]</strong>
                                        <div class="x-small text-muted">@T[definition.SummaryResourceKey]</div>
                                    </div>
                                    <div class="request-queue-meta text-end">
                                        <div class="mb-2">
                                            <bg-badge class="bg-badge-@(definition.IsActive ? "success" : "returned")">
                                                @T[definition.IsActive ? "WorkflowAdmin_StatusReady" : "WorkflowAdmin_StatusNeedsConfiguration"]
                                            </bg-badge>
                                        </div>
                                        <span class="x-small text-muted">@T["WorkflowAdmin_StageCountBadge", definition.Stages.Count]</span>
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                </article>
            </div>

            <article class="admin-workflow-detail bg-card shadow-sm">
                @if (activeDefinition is null)
                {
                    <div class="text-center py-5">
                        <i class="bi bi-diagram-3-fill fs-1 text-muted opacity-25 d-block mb-3"></i>
                        <h5 class="fw-bold text-dark">@T["WorkflowAdmin_DirectoryTitle"]</h5>
                        <p class="compact-copy mb-0">@T["WorkflowAdmin_DirectorySummary"]</p>
                    </div>
                }
                else
                {
                    var thresholdInput = activeDefinition.DelegationAmountThreshold?.ToString("0.##", CultureInfo.CurrentCulture);
                    var thresholdSummary = activeDefinition.DelegationAmountThreshold?.ToString("N2", CultureInfo.CurrentCulture) ?? T["WorkflowAdmin_NoAmountThreshold"].Value;
                    var requestTypeText = T[$"RequestType_{activeDefinition.RequestType}"].Value;
                    var categoryText = !string.IsNullOrWhiteSpace(activeDefinition.GuaranteeCategoryResourceKey)
                        ? T[activeDefinition.GuaranteeCategoryResourceKey].Value
                        : T["WorkflowAdmin_NoCategory"].Value;

                    <div class="admin-users-card-header">
                        <div>
                            <h4 class="fw-bold text-dark m-0">@T[activeDefinition.TitleResourceKey]</h4>
                            <div class="entity-subtitle">@requestTypeText</div>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <bg-badge variant="light">@T["WorkflowAdmin_StageCountBadge", activeDefinition.Stages.Count]</bg-badge>
                            <bg-badge variant="@(activeDefinition.IsActive ? "success" : "warning")">
                                @T[activeDefinition.IsActive ? "WorkflowAdmin_StatusReady" : "WorkflowAdmin_StatusNeedsConfiguration"]
                            </bg-badge>
                            @if (!string.IsNullOrWhiteSpace(activeDefinition.GuaranteeCategoryResourceKey))
                            {
                                <bg-badge variant="brand">@T[activeDefinition.GuaranteeCategoryResourceKey]</bg-badge>
                            }
                        </div>
                    </div>

                    <p class="compact-copy mb-4">@T["WorkflowAdmin_SelectedSummary"]</p>

                    <div class="admin-workflow-detail-grid">
                        <section class="admin-role-fact-card">
                            <span class="section-caption x-small">@T["WorkflowAdmin_RequestTypeLabel"]</span>
                            <strong>@requestTypeText</strong>
                        </section>
                        <section class="admin-role-fact-card">
                            <span class="section-caption x-small">@T["WorkflowAdmin_CategoryLabel"]</span>
                            <strong>@categoryText</strong>
                        </section>
                        <section class="admin-role-fact-card">
                            <span class="section-caption x-small">@T["WorkflowAdmin_DefinitionKeyLabel"]</span>
                            <strong class="text-break">@activeDefinition.Key</strong>
                        </section>
                        <section class="admin-role-fact-card">
                            <span class="section-caption x-small">@T["WorkflowAdmin_FinalSignaturePolicyLabel"]</span>
                            <strong>@T[$"WorkflowDelegationPolicy_{activeDefinition.FinalSignatureDelegationPolicy}"]</strong>
                        </section>
                    </div>

                    @if (activeDefinition.IntegrityIssueResourceKeys.Count > 0)
                    {
                        <section class="admin-role-permissions-panel mb-4">
                            <div class="admin-users-card-header">
                                <div>
                                    <h5 class="fw-bold text-dark m-0">@T["WorkflowAdmin_IntegrityTitle"]</h5>
                                    <p class="compact-copy mb-0">@T["WorkflowAdmin_StatusNeedsConfiguration"]</p>
                                </div>
                            </div>

                            <div class="admin-role-permission-groups">
                                @foreach (var issueResourceKey in activeDefinition.IntegrityIssueResourceKeys)
                                {
                                    <section class="admin-role-permission-group">
                                        <div class="compact-copy text-danger mb-0">@T[issueResourceKey]</div>
                                    </section>
                                }
                            </div>
                        </section>
                    }

                    <section class="admin-role-permissions-panel mb-4">
                        <div class="admin-users-card-header">
                            <div>
                                <h5 class="fw-bold text-dark m-0">@T["WorkflowAdmin_GovernanceTitle"]</h5>
                                <p class="compact-copy mb-0">@T["WorkflowAdmin_GovernanceSummary"]</p>
                            </div>
                        </div>

                        <div class="admin-workflow-governance-grid">
                            <form method="post" asp-page-handler="UpdateGovernance" class="row g-3">
                                <input type="hidden" name="definitionId" value="@activeDefinition.Id" />

                                <div class="col-md-6">
                                    <label class="form-label x-small fw-bold opacity-75" for="final-signature-policy-@activeDefinition.Id">@T["WorkflowAdmin_FinalSignaturePolicyField"]</label>
                                    <select id="final-signature-policy-@activeDefinition.Id" name="finalSignatureDelegationPolicy" class="form-select rounded-4 border-1.5 p-2 px-3 small">
                                        @foreach (var policy in Model.DelegationPolicies)
                                        {
                                            <option value="@policy.Value" selected="@(policy.Value == activeDefinition.FinalSignatureDelegationPolicy ? "selected" : null)">@T[policy.ResourceKey]</option>
                                        }
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label x-small fw-bold opacity-75" for="amount-threshold-@activeDefinition.Id">@T["WorkflowAdmin_AmountThresholdField"]</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white x-small fw-bold">SAR</span>
                                        <input id="amount-threshold-@activeDefinition.Id" name="delegationAmountThreshold" class="form-control" inputmode="decimal" value="@thresholdInput" />
                                    </div>
                                </div>

                                <div class="col-12 d-flex justify-content-end mt-4">
                                    <button type="submit" class="bg-btn bg-btn-primary px-5 py-3 shadow-none">
                                        <i class="bi bi-shield-check me-2"></i>@T["WorkflowAdmin_SaveGovernanceAction"]
                                    </button>
                                </div>
                            </form>

                            <section class="admin-role-permission-group">
                                <div class="section-caption x-small">@T["WorkflowAdmin_CurrentSettingsTitle"]</div>
                                <div class="compact-copy mb-0">
                                    <strong>@T["WorkflowAdmin_PolicySummaryLabel"]:</strong>
                                    @T[$"WorkflowDelegationPolicy_{activeDefinition.FinalSignatureDelegationPolicy}"]
                                </div>
                                <div class="compact-copy mb-0">
                                    <strong>@T["WorkflowAdmin_ThresholdSummaryLabel"]:</strong>
                                    @thresholdSummary
                                </div>
                            </section>
                        </div>
                    </section>

                    <section class="admin-role-permissions-panel mb-4">
                        <div class="admin-users-card-header">
                            <div>
                                <h5 class="fw-bold text-dark m-0">@T["WorkflowAdmin_CurrentStagesTitle"]</h5>
                                <p class="compact-copy mb-0">@T[activeDefinition.SummaryResourceKey]</p>
                            </div>
                            <bg-badge variant="light">@T["WorkflowAdmin_StageCountBadge", activeDefinition.Stages.Count]</bg-badge>
                        </div>

                        @if (activeDefinition.Stages.Count == 0)
                        {
                            <div class="text-center py-5 border rounded-4 border-dashed">
                                <p class="small text-muted m-0">@T["WorkflowAdmin_NoStages"]</p>
                            </div>
                        }
                        else
                        {
                            <div class="admin-workflow-stage-list">
                                @foreach (var stage in activeDefinition.Stages)
                                {
                                    var stageTitle = !string.IsNullOrWhiteSpace(stage.CustomTitle)
                                        ? stage.CustomTitle
                                        : !string.IsNullOrWhiteSpace(stage.TitleResourceKey)
                                            ? T[stage.TitleResourceKey].Value
                                            : stage.RoleName ?? T["WorkflowAdmin_UnassignedRole"].Value;
                                    var stageSummary = !string.IsNullOrWhiteSpace(stage.CustomSummary)
                                        ? stage.CustomSummary
                                        : !string.IsNullOrWhiteSpace(stage.SummaryResourceKey)
                                            ? T[stage.SummaryResourceKey].Value
                                            : T["WorkflowAdmin_NoStageSummary"].Value;
                                    var canMoveUp = stage.Sequence > 1;
                                    var canMoveDown = stage.Sequence < activeDefinition.Stages.Count;

                                    <article class="admin-workflow-stage-card">
                                        <div class="admin-users-card-header">
                                            <div class="admin-user-link-header">
                                                <span class="admin-user-avatar">@stage.Sequence</span>
                                                <div>
                                                    <h6 class="fw-bold text-dark m-0">@stageTitle</h6>
                                                    <p class="compact-copy mb-0">@stageSummary</p>
                                                </div>
                                            </div>
                                            <div class="d-flex flex-wrap gap-2 justify-content-end">
                                                @if (!string.IsNullOrWhiteSpace(stage.RoleName))
                                                {
                                                    <bg-badge variant="light">@stage.RoleName</bg-badge>
                                                }
                                                <bg-badge variant="light">@T[$"WorkflowDelegationPolicy_{stage.DelegationPolicy}"]</bg-badge>
                                                @if (stage.RequiresLetterSignature)
                                                {
                                                    <bg-badge variant="warning">@T["WorkflowAdmin_StageSignatureRequiredBadge"]</bg-badge>
                                                }
                                            </div>
                                        </div>

                                        <form method="post" asp-page-handler="UpdateStage" class="row g-3">
                                            <input type="hidden" name="definitionId" value="@activeDefinition.Id" />
                                            <input type="hidden" name="stageId" value="@stage.Id" />

                                            <div class="col-lg-4">
                                                <label class="form-label x-small fw-bold opacity-75" for="role-@stage.Id">@T["WorkflowAdmin_RoleField"]</label>
                                                <select id="role-@stage.Id" name="roleId" class="form-select rounded-4 p-2 small">
                                                    <option value="">@T["WorkflowAdmin_UnassignedRole"]</option>
                                                    @foreach (var role in Model.Snapshot.AvailableRoles)
                                                    {
                                                        <option value="@role.Id" selected="@(role.Id == stage.RoleId ? "selected" : null)">@role.Name</option>
                                                    }
                                                </select>
                                            </div>

                                            <div class="col-lg-4">
                                                <label class="form-label x-small fw-bold opacity-75" for="custom-title-@stage.Id">@T["WorkflowAdmin_CustomTitleField"]</label>
                                                <input id="custom-title-@stage.Id" name="customTitle" class="form-control rounded-4 p-2 small" value="@stage.CustomTitle" maxlength="128" />
                                            </div>

                                            <div class="col-lg-4">
                                                <label class="form-label x-small fw-bold opacity-75" for="delegation-policy-@stage.Id">@T["WorkflowAdmin_DelegationPolicyField"]</label>
                                                <select id="delegation-policy-@stage.Id" name="delegationPolicy" class="form-select rounded-4 p-2 small">
                                                    @foreach (var policy in Model.DelegationPolicies)
                                                    {
                                                        <option value="@policy.Value" selected="@(policy.Value == stage.DelegationPolicy ? "selected" : null)">@T[policy.ResourceKey]</option>
                                                    }
                                                </select>
                                            </div>

                                            <div class="col-lg-8">
                                                <label class="form-label x-small fw-bold opacity-75" for="custom-summary-@stage.Id">@T["WorkflowAdmin_CustomSummaryField"]</label>
                                                <textarea id="custom-summary-@stage.Id" name="customSummary" class="form-control rounded-4 p-2 small" rows="2" maxlength="256">@stage.CustomSummary</textarea>
                                            </div>

                                            <div class="col-lg-4 d-flex flex-column justify-content-end gap-3">
                                                <div class="form-check">
                                                    <input type="hidden" name="requiresLetterSignature" value="false" />
                                                    <input id="requires-signature-@stage.Id" class="form-check-input" type="checkbox" name="requiresLetterSignature" value="true" checked="@(stage.RequiresLetterSignature ? "checked" : null)" />
                                                    <label class="form-check-label x-small fw-bold" for="requires-signature-@stage.Id">@T["WorkflowAdmin_RequiresSignatureField"]</label>
                                                </div>
                                                <button type="submit" class="bg-btn bg-btn-primary w-100 py-3 shadow-none">
                                                    <i class="bi bi-save2 me-2"></i>@T["WorkflowAdmin_SaveStageAction"]
                                                </button>
                                            </div>
                                        </form>

                                        <div class="admin-workflow-stage-actions">
                                            <form method="post" asp-page-handler="MoveUp">
                                                <input type="hidden" name="definitionId" value="@activeDefinition.Id" />
                                                <input type="hidden" name="stageId" value="@stage.Id" />
                                                <bg-button type="submit" variant="light" size="sm" disabled="@(!canMoveUp)">@T["WorkflowAdmin_MoveUpAction"]</bg-button>
                                            </form>
                                            <form method="post" asp-page-handler="MoveDown">
                                                <input type="hidden" name="definitionId" value="@activeDefinition.Id" />
                                                <input type="hidden" name="stageId" value="@stage.Id" />
                                                <bg-button type="submit" variant="light" size="sm" disabled="@(!canMoveDown)">@T["WorkflowAdmin_MoveDownAction"]</bg-button>
                                            </form>
                                            <form method="post" asp-page-handler="RemoveStage">
                                                <input type="hidden" name="definitionId" value="@activeDefinition.Id" />
                                                <input type="hidden" name="stageId" value="@stage.Id" />
                                                <bg-button type="submit" variant="light" size="sm" class="text-danger" disabled="@(activeDefinition.Stages.Count <= 1)">@T["WorkflowAdmin_RemoveStageAction"]</bg-button>
                                            </form>
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                    </section>

                    <section class="admin-role-permissions-panel">
                        <div class="admin-users-card-header">
                            <div>
                                <h5 class="fw-bold text-dark m-0">@T["WorkflowAdmin_AddStageTitle"]</h5>
                                <p class="compact-copy mb-0">@T["WorkflowAdmin_AddStageSummary"]</p>
                            </div>
                        </div>

                        <form method="post" asp-page-handler="AddStage" class="row g-3">
                            <input type="hidden" name="definitionId" value="@activeDefinition.Id" />

                            <div class="col-lg-4">
                                <label class="form-label x-small fw-bold opacity-75" for="add-role-@activeDefinition.Id">@T["WorkflowAdmin_RoleField"]</label>
                                <select id="add-role-@activeDefinition.Id" name="roleId" class="form-select rounded-4 p-2 small" required>
                                    <option value="">@T["WorkflowAdmin_SelectRole"]</option>
                                    @foreach (var role in Model.Snapshot.AvailableRoles)
                                    {
                                        <option value="@role.Id">@role.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="col-lg-4">
                                <label class="form-label x-small fw-bold opacity-75" for="add-title-@activeDefinition.Id">@T["WorkflowAdmin_CustomTitleField"]</label>
                                <input id="add-title-@activeDefinition.Id" name="customTitle" class="form-control rounded-4 p-2 small" maxlength="128" placeholder="@T["WorkflowAdmin_TitleOverridePlaceholder"]" />
                            </div>

                            <div class="col-lg-4">
                                <label class="form-label x-small fw-bold opacity-75" for="add-delegation-policy-@activeDefinition.Id">@T["WorkflowAdmin_DelegationPolicyField"]</label>
                                <select id="add-delegation-policy-@activeDefinition.Id" name="delegationPolicy" class="form-select rounded-4 p-2 small">
                                    @foreach (var policy in Model.DelegationPolicies)
                                    {
                                        <option value="@policy.Value">@T[policy.ResourceKey]</option>
                                    }
                                </select>
                            </div>

                            <div class="col-lg-8">
                                <label class="form-label x-small fw-bold opacity-75" for="add-summary-@activeDefinition.Id">@T["WorkflowAdmin_CustomSummaryField"]</label>
                                <textarea id="add-summary-@activeDefinition.Id" name="customSummary" class="form-control rounded-4 p-2 small" rows="2" maxlength="256"></textarea>
                            </div>

                            <div class="col-lg-4 d-flex flex-column justify-content-end gap-3">
                                <div class="form-check">
                                    <input type="hidden" name="requiresLetterSignature" value="false" />
                                    <input id="add-requires-signature-@activeDefinition.Id" class="form-check-input" type="checkbox" name="requiresLetterSignature" value="true" checked="checked" />
                                    <label class="form-check-label x-small fw-bold" for="add-requires-signature-@activeDefinition.Id">@T["WorkflowAdmin_RequiresSignatureField"]</label>
                                </div>
                                <button type="submit" class="bg-btn bg-btn-primary w-100 py-3 shadow-none">
                                    <i class="bi bi-plus-circle me-2"></i>@T["WorkflowAdmin_AddStageAction"]
                                </button>
                            </div>
                        </form>
                    </section>
                }
            </article>
        </div>
    }
</section>
