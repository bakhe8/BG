@page
@using System.Globalization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Administration.WorkflowModel
@{
    ViewData["Title"] = T["WorkflowAdmin_PageTitle"];
    var definitionCount = Model.Snapshot.Definitions.Count;
    var readyCount = Model.Snapshot.Definitions.Count(definition => definition.IsActive);
    var issueCount = Model.Snapshot.Definitions.Count(definition => definition.IntegrityIssueResourceKeys.Count > 0);
    var stageCount = Model.Snapshot.Definitions.Sum(definition => definition.Stages.Count);
    var headerModel = new SurfaceHeaderModel(
        T["NavWorkflowAdmin"].Value,
        T["WorkflowAdmin_Heading"].Value,
        T["WorkflowAdmin_Summary"].Value,
        CssClass: "is-split");
    var statStripModel = new SurfaceStatStripModel(
        new[]
        {
            new SurfaceStatItem(T["WorkflowAdmin_CurrentStagesTitle"].Value, definitionCount),
            new SurfaceStatItem(T["WorkflowAdmin_StatusReady"].Value, readyCount),
            new SurfaceStatItem(T["WorkflowAdmin_StatusNeedsConfiguration"].Value, issueCount),
            new SurfaceStatItem(T["OperationsQueue_LevelsSuffix"].Value, stageCount)
        });
    var taskNoticeModel = new InlineNoticeModel(
        T["AdminWorkflow_TaskModelTitle"].Value,
        T["AdminWorkflow_TaskModelSummary"].Value);
}

<section class="bg-shell-content">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success border-0 rounded-4 shadow-sm mb-4">@Model.StatusMessage</div>
    }

    <div class="mb-5 pb-4 border-bottom">
        <section-caption>@T["NavWorkflowAdmin"]</section-caption>
        <h1 class="fw-bold text-dark m-0">@T["WorkflowAdmin_Heading"]</h1>
        <p class="text-secondary mt-1">@T["WorkflowAdmin_Summary"]</p>
    </div>

    <div class="bg-card-premium shadow-sm p-4 mb-5 border-start border-brand-gold border-4">
        <div class="d-flex align-items-center gap-3">
            <i class="bi bi-info-circle text-brand-gold fs-4"></i>
            <div>
                <div class="fw-bold text-dark">@T["AdminWorkflow_TaskModelTitle"]</div>
                <div class="small text-muted">@T["AdminWorkflow_TaskModelSummary"]</div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="bg-card shadow-sm p-4 text-center">
                <div class="section-caption x-small mb-1">@T["WorkflowAdmin_CurrentStagesTitle"]</div>
                <div class="display-6 fw-bold text-dark">@definitionCount</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-card shadow-sm p-4 text-center">
                <div class="section-caption x-small mb-1">@T["WorkflowAdmin_StatusReady"]</div>
                <div class="display-6 fw-bold text-brand-green">@readyCount</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-card shadow-sm p-4 text-center">
                <div class="section-caption x-small mb-1">@T["WorkflowAdmin_StatusNeedsConfiguration"]</div>
                <div class="display-6 fw-bold text-danger">@issueCount</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="bg-card shadow-sm p-4 text-center">
                <div class="section-caption x-small mb-1">@T["OperationsQueue_LevelsSuffix"]</div>
                <div class="display-6 fw-bold text-dark">@stageCount</div>
            </div>
        </div>
    </div>

    @if (Model.Snapshot.Definitions.Count == 0)
    {
        <div class="bg-card shadow-sm p-5 text-center">
            <i class="bi bi-diagram-3-fill display-1 text-light mb-4 d-block"></i>
            <h2 class="fw-bold text-dark">@T["WorkflowAdmin_NoDefinitionsTitle"]</h2>
            <p class="text-secondary">@T["WorkflowAdmin_NoDefinitionsBody"]</p>
            <bg-button variant="primary" class="mt-4">@T["WorkflowAdmin_AddFirstAction"]</bg-button>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-5">
            @foreach (var definition in Model.Snapshot.Definitions)
            {
                <div class="bg-card shadow-sm p-4">
                    <div class="d-flex justify-content-between align-items-start mb-4 pb-3 border-bottom">
                        <div>
                            <h3 class="fw-bold text-dark m-0">@T[definition.TitleResourceKey]</h3>
                            <p class="small text-muted m-0">@T[definition.SummaryResourceKey]</p>
                        </div>
                        <div class="d-flex gap-2">
                            <bg-badge variant="light">@definition.Stages.Count @T["OperationsQueue_LevelsSuffix"]</bg-badge>
                            <bg-badge variant="@(definition.IsActive ? "success" : "warning")">
                                @T[definition.IsActive ? "WorkflowAdmin_StatusReady" : "WorkflowAdmin_StatusNeedsConfiguration"]
                            </bg-badge>
                            @if (!string.IsNullOrWhiteSpace(definition.GuaranteeCategoryResourceKey))
                            {
                                <bg-badge variant="brand">@T[definition.GuaranteeCategoryResourceKey]</bg-badge>
                            }
                        </div>
                    </div>

                    @if (definition.IntegrityIssueResourceKeys.Count > 0)
                    {
                        <div class="alert alert-warning border-0 rounded-4 p-3 mb-4 d-flex align-items-center gap-3">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <div class="small fw-bold">@string.Join(" ", definition.IntegrityIssueResourceKeys.Select(resourceKey => T[resourceKey].Value))</div>
                        </div>
                    }

                    <div class="bg-light rounded-4 p-4 mb-4">
                        <h6 class="fw-bold text-dark mb-3">@T["WorkflowAdmin_GovernanceTitle"]</h6>
                        
                        <div class="row g-4">
                            <div class="col-md-6">
                                <form method="post" asp-page-handler="UpdateGovernance" class="d-flex flex-column gap-3">
                                    <input type="hidden" name="definitionId" value="@definition.Id" />

                                    <div>
                                        <label class="form-label x-small fw-bold opacity-75" for="final-signature-policy-@definition.Id">@T["WorkflowAdmin_FinalSignaturePolicyField"]</label>
                                        <select id="final-signature-policy-@definition.Id" name="finalSignatureDelegationPolicy" class="form-select rounded-4 border-1.5 p-2 px-3 small">
                                            @foreach (var policy in Model.DelegationPolicies)
                                            {
                                                <option value="@policy.Value" selected="@(policy.Value == definition.FinalSignatureDelegationPolicy ? "selected" : null)">@T[policy.ResourceKey]</option>
                                            }
                                        </select>
                                    </div>

                                    <div>
                                        <label class="form-label x-small fw-bold opacity-75" for="amount-threshold-@definition.Id">@T["WorkflowAdmin_AmountThresholdField"]</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-white x-small fw-bold">SAR</span>
                                            <input id="amount-threshold-@definition.Id" name="delegationAmountThreshold" class="form-control" inputmode="decimal" value="@(definition.DelegationAmountThreshold?.ToString("0.##", CultureInfo.InvariantCulture))" />
                                        </div>
                                    </div>

                                    <bg-button type="submit" variant="secondary" size="md">@T["WorkflowAdmin_SaveGovernanceAction"]</bg-button>
                                </form>
                            </div>
                            <div class="col-md-6 border-start d-flex flex-column gap-2 justify-content-center ps-5">
                                <div class="x-small text-muted fw-bold">CURRENT SETTINGS</div>
                                <div class="small"><span class="text-secondary">Policy:</span> @T[$"WorkflowDelegationPolicy_{definition.FinalSignatureDelegationPolicy}"]</div>
                                <div class="small">
                                    <span class="text-secondary">Threshold:</span> 
                                    @(definition.DelegationAmountThreshold?.ToString("N2", CultureInfo.InvariantCulture) ?? T["WorkflowAdmin_NoAmountThreshold"].Value)
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="fw-bold text-dark m-0">@T["WorkflowAdmin_CurrentStagesTitle"]</h5>
                            <bg-badge variant="light">@definition.Stages.Count Stages</bg-badge>
                        </div>
                        
                        @if (definition.Stages.Count == 0)
                        {
                            <div class="text-center py-5 border rounded-4 border-dashed">
                                <p class="small text-muted m-0">@T["WorkflowAdmin_NoStages"]</p>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-3">
                                @foreach (var stage in definition.Stages)
                                {
                                    var stageTitle = !string.IsNullOrWhiteSpace(stage.CustomTitle) ? stage.CustomTitle : !string.IsNullOrWhiteSpace(stage.TitleResourceKey) ? T[stage.TitleResourceKey].Value : stage.RoleName ?? T["WorkflowAdmin_UnassignedRole"].Value;
                                    var stageSummary = !string.IsNullOrWhiteSpace(stage.CustomSummary) ? stage.CustomSummary : !string.IsNullOrWhiteSpace(stage.SummaryResourceKey) ? T[stage.SummaryResourceKey].Value : T["WorkflowAdmin_NoStageSummary"].Value;

                                    <div class="bg-white border rounded-4 p-4 shadow-sm hover-shadow-md transition-all">
                                        <div class="d-flex justify-content-between align-items-start mb-4">
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="bg-brand-green text-white rounded-circle width-32 height-32 d-flex align-items-center justify-content-center fw-bold x-small">@stage.Sequence</div>
                                                <div>
                                                    <h6 class="fw-bold text-dark m-0">@stageTitle</h6>
                                                    <p class="x-small text-muted m-0">@stageSummary</p>
                                                </div>
                                            </div>
                                            <div class="d-flex gap-2">
                                                @if (!string.IsNullOrWhiteSpace(stage.RoleName))
                                                {
                                                    <bg-badge variant="light">@stage.RoleName</bg-badge>
                                                }
                                                <bg-badge variant="light">@T[$"WorkflowDelegationPolicy_{stage.DelegationPolicy}"]</bg-badge>
                                                @if (stage.RequiresLetterSignature)
                                                {
                                                    <bg-badge variant="warning">@T["WorkflowAdmin_StageSignatureRequiredBadge"]</bg-badge>
                                                }
                                            </div>
                                        </div>

                                        <form method="post" asp-page-handler="UpdateStage" class="row g-3 admin-stage-form">
                                            <input type="hidden" name="definitionId" value="@definition.Id" />
                                            <input type="hidden" name="stageId" value="@stage.Id" />

                                            <div class="col-md-3">
                                                <label class="form-label x-small fw-bold opacity-75" for="role-@stage.Id">@T["WorkflowAdmin_RoleField"]</label>
                                                <select id="role-@stage.Id" name="roleId" class="form-select rounded-4 p-2 small">
                                                    <option value="">@T["WorkflowAdmin_UnassignedRole"]</option>
                                                    @foreach (var role in Model.Snapshot.AvailableRoles)
                                                    {
                                                        <option value="@role.Id" selected="@(role.Id == stage.RoleId ? "selected" : null)">@role.Name</option>
                                                    }
                                                </select>
                                            </div>

                                            <div class="col-md-3">
                                                <label class="form-label x-small fw-bold opacity-75" for="custom-title-@stage.Id">@T["WorkflowAdmin_CustomTitleField"]</label>
                                                <input id="custom-title-@stage.Id" name="customTitle" class="form-control rounded-4 p-2 small" value="@stage.CustomTitle" maxlength="128" />
                                            </div>

                                            <div class="col-md-3">
                                                <label class="form-label x-small fw-bold opacity-75" for="delegation-policy-@stage.Id">@T["WorkflowAdmin_DelegationPolicyField"]</label>
                                                <select id="delegation-policy-@stage.Id" name="delegationPolicy" class="form-select rounded-4 p-2 small">
                                                    @foreach (var policy in Model.DelegationPolicies)
                                                    {
                                                        <option value="@policy.Value" selected="@(policy.Value == stage.DelegationPolicy ? "selected" : null)">@T[policy.ResourceKey]</option>
                                                    }
                                                </select>
                                            </div>

                                            <div class="col-md-3 d-flex align-items-end gap-2">
                                                <div class="form-check mb-2">
                                                    <input type="hidden" name="requiresLetterSignature" value="false" />
                                                    <input id="requires-signature-@stage.Id" class="form-check-input" type="checkbox" name="requiresLetterSignature" value="true" checked="@(stage.RequiresLetterSignature ? "checked" : null)" />
                                                    <label class="form-check-label x-small fw-bold" for="requires-signature-@stage.Id">@T["WorkflowAdmin_RequiresSignatureField"]</label>
                                                </div>
                                                <bg-button type="submit" variant="primary" class="ms-auto">Save</bg-button>
                                            </div>
                                        </form>

                                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                                            <form method="post" asp-page-handler="MoveUp">
                                                <input type="hidden" name="definitionId" value="@definition.Id" />
                                                <input type="hidden" name="stageId" value="@stage.Id" />
                                                <bg-button type="submit" variant="light" size="sm"><i class="bi bi-arrow-up me-1"></i> @T["WorkflowAdmin_MoveUpAction"]</bg-button>
                                            </form>
                                            <form method="post" asp-page-handler="MoveDown">
                                                <input type="hidden" name="definitionId" value="@definition.Id" />
                                                <input type="hidden" name="stageId" value="@stage.Id" />
                                                <bg-button type="submit" variant="light" size="sm"><i class="bi bi-arrow-down me-1"></i> @T["WorkflowAdmin_MoveDownAction"]</bg-button>
                                            </form>
                                            <form method="post" asp-page-handler="RemoveStage">
                                                <input type="hidden" name="definitionId" value="@definition.Id" />
                                                <input type="hidden" name="stageId" value="@stage.Id" />
                                                <bg-button type="submit" variant="light" size="sm" class="text-danger"><i class="bi bi-trash me-1"></i> @T["WorkflowAdmin_RemoveStageAction"]</bg-button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="mt-5 bg-white border border-dashed rounded-4 p-4">
                        <h6 class="fw-bold text-dark mb-4">@T["WorkflowAdmin_AddStageTitle"] <span class="text-muted fw-normal x-small ms-2">@T["WorkflowAdmin_AddStageSummary"]</span></h6>
                        
                        <form method="post" asp-page-handler="AddStage" class="row g-3">
                            <input type="hidden" name="definitionId" value="@definition.Id" />

                            <div class="col-md-3">
                                <label class="form-label x-small fw-bold opacity-75" for="add-role-@definition.Id">@T["WorkflowAdmin_RoleField"]</label>
                                <select id="add-role-@definition.Id" name="roleId" class="form-select rounded-4 p-2 small" required>
                                    <option value="">@T["WorkflowAdmin_SelectRole"]</option>
                                    @foreach (var role in Model.Snapshot.AvailableRoles)
                                    {
                                        <option value="@role.Id">@role.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label x-small fw-bold opacity-75" for="add-title-@definition.Id">@T["WorkflowAdmin_CustomTitleField"]</label>
                                <input id="add-title-@definition.Id" name="customTitle" class="form-control rounded-4 p-2 small" maxlength="128" placeholder="Title Override" />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label x-small fw-bold opacity-75" for="add-delegation-policy-@definition.Id">@T["WorkflowAdmin_DelegationPolicyField"]</label>
                                <select id="add-delegation-policy-@definition.Id" name="delegationPolicy" class="form-select rounded-4 p-2 small">
                                    @foreach (var policy in Model.DelegationPolicies)
                                    {
                                        <option value="@policy.Value">@T[policy.ResourceKey]</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-3 d-flex align-items-end gap-2">
                                <div class="form-check mb-2">
                                    <input type="hidden" name="requiresLetterSignature" value="false" />
                                    <input id="add-requires-signature-@definition.Id" class="form-check-input" type="checkbox" name="requiresLetterSignature" value="true" checked="checked" />
                                    <label class="form-check-label x-small fw-bold" for="add-requires-signature-@definition.Id">@T["WorkflowAdmin_RequiresSignatureField"]</label>
                                </div>
                                <bg-button type="submit" variant="primary" class="ms-auto">Add Stage</bg-button>
                            </div>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</section>
