@page
@using System.Globalization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Administration.WorkflowModel
@{
    ViewData["Title"] = T["WorkflowAdmin_PageTitle"];
    var definitionCount = Model.Snapshot.Definitions.Count;
    var readyCount = Model.Snapshot.Definitions.Count(definition => definition.IsActive);
    var issueCount = Model.Snapshot.Definitions.Count(definition => definition.IntegrityIssueResourceKeys.Count > 0);
    var stageCount = Model.Snapshot.Definitions.Sum(definition => definition.Stages.Count);
    var activeDefinition = Model.ActiveDefinition;
}

<section class="section-shell admin-workflow-surface">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice-banner is-success">@Model.StatusMessage</div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <div class="mb-5 pb-4 border-bottom">
        <section-caption>@T["NavWorkflowAdmin"]</section-caption>
        <h1 class="fw-bold text-dark m-0">@T["WorkflowAdmin_Heading"]</h1>
    </div>


    <div class="bg-metric-grid">
        <div class="bg-metric-card">
            <span class="bg-metric-label">@T["WorkflowAdmin_DirectoryTitle"]</span>
            <span class="bg-metric-value">@definitionCount</span>
        </div>
        <div class="bg-metric-card is-important">
            <span class="bg-metric-label">@T["WorkflowAdmin_StatusReady"]</span>
            <span class="bg-metric-value is-financial">@readyCount</span>
        </div>
        <div class="bg-metric-card">
            <span class="bg-metric-label">@T["WorkflowAdmin_StatusNeedsConfiguration"]</span>
            <span class="bg-metric-value text-danger">@issueCount</span>
        </div>
        <div class="bg-metric-card">
            <span class="bg-metric-label">@T["WorkflowAdmin_CurrentStagesTitle"]</span>
            <span class="bg-metric-value">@stageCount</span>
        </div>
    </div>

    @if (Model.Snapshot.Definitions.Count == 0)
    {
        <div class="bg-card shadow-sm p-5 text-center">
            <i class="bi bi-diagram-3-fill display-1 text-light mb-4 d-block"></i>
            <h2 class="fw-bold text-dark">@T["WorkflowAdmin_NoDefinitionsTitle"]</h2>
            <p class="text-secondary">@T["WorkflowAdmin_NoDefinitionsBody"]</p>
        </div>
    }
    else
    {
    <div class="bg-workspace-grid-3col">
        @* Column 1: Directory *@
        <aside class="admin-workflow-sidebar">
            <article class="admin-workflow-directory shadow-sm">
                <header class="admin-workspace-column-header p-4 pb-0 border-0">
                    <div>
                        <h5 class="admin-column-title">@T["WorkflowAdmin_DirectoryTitle"]</h5>
                        <p class="admin-column-summary">@definitionCount @T["WorkflowAdmin_DefinitionsWord"]</p>
                    </div>
                </header>

                <div class="admin-workflow-directory-list">
                    @foreach (var definition in Model.Snapshot.Definitions)
                    {
                        var isActive = activeDefinition?.Id == definition.Id;

                        <a asp-page="/Administration/Workflow"
                           asp-all-route-data="Model.BuildSelectionRoute(definition.Id)"
                           class="admin-role-item @(isActive ? "active" : null)">
                            <div class="d-flex justify-content-between align-items-center w-100">
                                <div>
                                    <div class="x-small text-muted text-uppercase fw-bold mb-1">@T[$"RequestType_{definition.RequestType}"]</div>
                                    <strong class="d-block text-dark">@T[definition.TitleResourceKey]</strong>
                                    <div class="xx-small text-muted mt-1 opacity-75">@definition.Stages.Count @T["WorkflowAdmin_StagesWord"]</div>
                                </div>
                                <div class="text-end">
                                    @if(definition.IsActive) {
                                        <i class="bi bi-check-circle-fill text-brand-green fs-5"></i>
                                    } else {
                                        <i class="bi bi-exclamation-circle-fill text-warning fs-5"></i>
                                    }
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </article>
        </aside>

        @if (activeDefinition != null)
        {
            var thresholdInput = activeDefinition.DelegationAmountThreshold?.ToString("0.##", CultureInfo.CurrentCulture);
            var requestTypeText = T[$"RequestType_{activeDefinition.RequestType}"].Value;
            var categoryText = !string.IsNullOrWhiteSpace(activeDefinition.GuaranteeCategoryResourceKey)
                ? T[activeDefinition.GuaranteeCategoryResourceKey].Value
                : T["WorkflowAdmin_NoCategory"].Value;

            @* Column 2: Governance *@
            <article class="admin-workflow-governance p-4">
                <header class="admin-workspace-column-header">
                    <div>
                        <h5 class="admin-column-title">@T["WorkflowAdmin_GovernanceTitle"]</h5>
                        <p class="admin-column-summary">@T[activeDefinition.TitleResourceKey]</p>
                    </div>
                </header>

                <div class="d-flex flex-column gap-4">
                    <div class="admin-role-facts-grid" style="grid-template-columns: 1fr;">
                        <section class="admin-role-fact-card">
                            <span class="section-caption x-small">@T["WorkflowAdmin_RequestTypeLabel"]</span>
                            <strong>@requestTypeText</strong>
                        </section>
                        <section class="admin-role-fact-card">
                            <span class="section-caption x-small">@T["WorkflowAdmin_CategoryLabel"]</span>
                            <strong>@categoryText</strong>
                        </section>
                    </div>

                    @if (activeDefinition.IntegrityIssueResourceKeys.Count > 0)
                    {
                        <div class="bg-danger bg-opacity-10 p-4 rounded-4 border border-danger border-opacity-25 mb-2">
                            <h6 class="xx-small fw-bold text-danger mb-2 text-uppercase">@T["WorkflowAdmin_IntegrityTitle"]</h6>
                            <div class="d-flex flex-column gap-2 text-danger fw-bold xx-small">
                                @foreach (var issue in activeDefinition.IntegrityIssueResourceKeys)
                                {
                                    <div class="d-flex align-items-start gap-2">
                                        <i class="bi bi-info-circle"></i>
                                        <span>@T[issue]</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="pt-4 border-top">
                        <form method="post" asp-page-handler="UpdateGovernance" class="d-flex flex-column gap-4">
                            <input type="hidden" name="definitionId" value="@activeDefinition.Id" />

                            <div>
                                <label class="form-label x-small fw-bold opacity-75 mb-2">@T["WorkflowAdmin_FinalSignaturePolicyField"]</label>
                                <select name="finalSignatureDelegationPolicy" class="form-select rounded-4 p-3 fs-6">
                                    @foreach (var policy in Model.DelegationPolicies)
                                    {
                                        <option value="@policy.Value" selected="@(policy.Value == activeDefinition.FinalSignatureDelegationPolicy ? "selected" : null)">@T[policy.ResourceKey]</option>
                                    }
                                </select>
                            </div>

                            <div>
                                <label class="form-label x-small fw-bold opacity-75 mb-2">@T["WorkflowAdmin_AmountThresholdField"]</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white opacity-50 fw-bold border-end-0">SAR</span>
                                    <input name="delegationAmountThreshold" class="form-control rounded-start-0 p-3 fs-5 fw-bold" inputmode="decimal" value="@thresholdInput" />
                                </div>
                            </div>

                            <bg-button type="submit" variant="primary" class="w-100 py-3 mt-2 shadow-green">
                                <i class="bi bi-shield-check me-2"></i>@T["WorkflowAdmin_SaveGovernanceAction"]
                            </bg-button>
                        </form>
                    </div>
                </div>
            </article>

            @* Column 3: Architecture *@
            <article class="admin-workflow-architecture p-4">
                <header class="admin-workspace-column-header">
                    <div>
                        <h5 class="admin-column-title">@T["WorkflowAdmin_CurrentStagesTitle"]</h5>
                        <p class="admin-column-summary">@activeDefinition.Stages.Count @T["WorkflowAdmin_StagesWord"]</p>
                    </div>
                    <div class="admin-column-meta">
                        <bg-badge variant="light">@activeDefinition.RequestType</bg-badge>
                    </div>
                </header>

                <div class="admin-workflow-stage-list">
                    @foreach (var stage in activeDefinition.Stages.OrderBy(s => s.Sequence))
                    {
                        var stageTitle = !string.IsNullOrWhiteSpace(stage.CustomTitle) ? stage.CustomTitle : (stage.TitleResourceKey != null ? T[stage.TitleResourceKey].Value : (stage.RoleName ?? "---"));
                        var canMoveUp = stage.Sequence > 1;
                        var canMoveDown = stage.Sequence < activeDefinition.Stages.Count;

                        <article class="admin-workflow-stage-card">
                            <form method="post" asp-page-handler="UpdateStage" class="d-flex flex-column gap-3">
                                <input type="hidden" name="definitionId" value="@activeDefinition.Id" />
                                <input type="hidden" name="stageId" value="@stage.Id" />

                                <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-2">
                                    <div class="d-flex align-items-center gap-3">
                                        <span class="bg-brand-green text-white rounded-circle d-flex align-items-center justify-content-center fw-bold fs-6" style="width: 32px; height: 32px;">@stage.Sequence</span>
                                        <div>
                                            <h6 class="fw-bold text-dark m-0">@stageTitle</h6>
                                            <div class="xx-small text-muted opacity-75">@T[$"WorkflowDelegationPolicy_{stage.DelegationPolicy}"]</div>
                                        </div>
                                    </div>
                                    @if(stage.RequiresLetterSignature) {
                                        <bg-badge variant="warning" class="xx-small">@T["WorkflowAdmin_SignatureRequiredShort"]</bg-badge>
                                    }
                                </div>

                                <div class="row g-2">
                                    <div class="col-12">
                                        <label class="xx-small fw-bold opacity-50 mb-1">@T["WorkflowAdmin_RoleField"]</label>
                                        <select name="roleId" class="form-select xx-small p-2">
                                            <option value="">@T["WorkflowAdmin_UnassignedRole"]</option>
                                            @foreach (var role in Model.Snapshot.AvailableRoles)
                                            {
                                                <option value="@role.Id" selected="@(role.Id == stage.RoleId ? "selected" : null)">@role.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <label class="xx-small fw-bold opacity-50 mb-1">@T["WorkflowAdmin_CustomTitleField"]</label>
                                        <input name="customTitle" class="form-control xx-small p-2" value="@stage.CustomTitle" placeholder="@T["OptionalLabel"]" />
                                    </div>
                                    <div class="col-6">
                                        <label class="xx-small fw-bold opacity-50 mb-1">@T["WorkflowAdmin_DelegationPolicyField"]</label>
                                        <select name="delegationPolicy" class="form-select xx-small p-2">
                                            @foreach (var policy in Model.DelegationPolicies)
                                            {
                                                <option value="@policy.Value" selected="@(policy.Value == stage.DelegationPolicy ? "selected" : null)">@T[policy.ResourceKey]</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-12">
                                        <div class="form-check mt-1">
                                            <input type="hidden" name="requiresLetterSignature" value="false" />
                                            <input class="form-check-input" type="checkbox" name="requiresLetterSignature" value="true" checked="@(stage.RequiresLetterSignature ? "checked" : null)" id="chk-@stage.Id" />
                                            <label class="form-check-label xx-small fw-bold" for="chk-@stage.Id">@T["WorkflowAdmin_RequiresSignatureField"]</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="admin-workflow-stage-actions">
                                    <button type="submit" asp-page-handler="UpdateStage" class="bg-button is-primary is-small border-0 px-3 opacity-75">
                                        <i class="bi bi-save2"></i>
                                    </button>
                                    <button type="submit" asp-page-handler="MoveUp" class="bg-button is-light is-small border-0 px-2" disabled="@(!canMoveUp)">
                                        <i class="bi bi-arrow-up"></i>
                                    </button>
                                    <button type="submit" asp-page-handler="MoveDown" class="bg-button is-light is-small border-0 px-2" disabled="@(!canMoveDown)">
                                        <i class="bi bi-arrow-down"></i>
                                    </button>
                                    <button type="submit" asp-page-handler="RemoveStage" class="bg-button is-light is-small border-0 px-2 text-danger" disabled="@(activeDefinition.Stages.Count <= 1)">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            </form>
                        </article>
                    }
                </div>

                @* Add Stage Section *@
                <section class="mt-5 pt-5 border-top">
                    <h6 class="fw-bold text-dark mb-4">@T["WorkflowAdmin_AddStageTitle"]</h6>
                    <form method="post" asp-page-handler="AddStage" class="bg-light p-4 rounded-4 d-flex flex-column gap-3 shadow-sm border">
                        <input type="hidden" name="definitionId" value="@activeDefinition.Id" />
                        
                        <div>
                            <label class="xx-small fw-bold opacity-50 mb-1">@T["WorkflowAdmin_RoleField"]</label>
                            <select name="roleId" class="form-select small p-2" required>
                                <option value="">@T["WorkflowAdmin_SelectRole"]</option>
                                @foreach (var role in Model.Snapshot.AvailableRoles)
                                {
                                    <option value="@role.Id">@role.Name</option>
                                }
                            </select>
                        </div>

                        <div class="row g-2">
                            <div class="col-6">
                                <label class="xx-small fw-bold opacity-50 mb-1">@T["WorkflowAdmin_CustomTitleField"]</label>
                                <input name="customTitle" class="form-control small p-2" />
                            </div>
                            <div class="col-6">
                                <label class="xx-small fw-bold opacity-50 mb-1">@T["WorkflowAdmin_DelegationPolicyField"]</label>
                                <select name="delegationPolicy" class="form-select small p-2">
                                    @foreach (var policy in Model.DelegationPolicies)
                                    {
                                        <option value="@policy.Value">@T[policy.ResourceKey]</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <bg-button type="submit" variant="brand" class="w-100 py-3 mt-2 shadow-green">
                            <i class="bi bi-plus-circle me-2"></i>@T["WorkflowAdmin_AddStageAction"]
                        </bg-button>
                    </form>
                </section>
            </article>
        }
    </div>
    }
</section>
