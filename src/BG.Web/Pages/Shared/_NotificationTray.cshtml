@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T

<div class="dropdown me-3 border-end pe-4 h-100 d-flex align-items-center">
    <button class="btn rounded-circle p-2 position-relative"
            style="background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.2);"
            type="button"
            id="notificationDropdown"
            data-bs-toggle="dropdown"
            aria-expanded="false">
        <i class="bi bi-bell-fill fs-5 text-white"></i>
        <span id="notification-badge" class="notification-badge d-none">
            @* Value is managed via JS; visual dot only to match Image 1 *@
        </span>
    </button>
    <div class="dropdown-menu dropdown-menu-end p-0 shadow-lg border-0 rounded-4" 
         aria-labelledby="notificationDropdown" 
         style="width: 320px; overflow: hidden;">
        <div class="p-3 bg-brand-green text-white d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold">@T["Notifications_Title"]</h6>
            <span class="x-small opacity-75">@DateTimeOffset.UtcNow.ToString("d MMM")</span>
        </div>
        <div id="notification-list" class="overflow-auto" style="max-height: 400px;">
            <div class="text-center text-muted p-4">
                <i class="bi bi-bell-slash fs-1 opacity-25 d-block mb-2"></i>
                <span class="small">@T["Notifications_EmptyState"]</span>
            </div>
        </div>
        <div class="p-2 border-top text-center">
            <a href="#" class="btn btn-link btn-sm x-small text-decoration-none text-brand-green fw-bold">@T["Notifications_ViewAll"]</a>
        </div>
    </div>
</div>
