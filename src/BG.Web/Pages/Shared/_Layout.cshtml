@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@inject IUiConfigurationService UiConfiguration
@inject IWorkspaceShellService WorkspaceShell
@{
    string GetSidebarIcon(string? path)
    {
        if (string.IsNullOrWhiteSpace(path)) return "bi-circle";
        if (path.Equals("/Index", StringComparison.OrdinalIgnoreCase)) return "bi-house-door";
        if (path.StartsWith("/Intake", StringComparison.OrdinalIgnoreCase)) return "bi-file-earmark-plus";
        if (path.StartsWith("/Inventory", StringComparison.OrdinalIgnoreCase) || path.Contains("Requests")) return "bi-journal-text";
        if (path.StartsWith("/Operations", StringComparison.OrdinalIgnoreCase)) return "bi-shield-check";
        if (path.StartsWith("/Dispatch", StringComparison.OrdinalIgnoreCase)) return "bi-send";
        if (path.StartsWith("/Reports", StringComparison.OrdinalIgnoreCase)) return "bi-bar-chart-line";
        if (path.StartsWith("/Administration", StringComparison.OrdinalIgnoreCase)) return "bi-gear";
        return "bi-circle";
    }

    string BuildInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "BG";
        }

        var initials = new List<char>(2);
        foreach (var part in value.Split(' ', StringSplitOptions.RemoveEmptyEntries))
        {
            initials.Add(char.ToUpperInvariant(part[0]));
            if (initials.Count == 2)
            {
                break;
            }
        }

        return initials.Count == 0 ? "BG" : new string(initials.ToArray());
    }

    var currentCulture = UiConfiguration.GetCurrentCulture();
    var currentDirection = UiConfiguration.GetDirection(currentCulture);
    var currentTheme = UiConfiguration.GetCurrentTheme();
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var shell = await WorkspaceShell.GetSnapshotAsync(Context.RequestAborted);
    var shellMessageKey = Context.Request.Query["shellMessage"].ToString();
    var currentPath = Context.Request.Path.Value ?? "/";
    var operationalItems = shell.NavigationItems
        .Where(item =>
            !string.Equals(item.PagePath, "/Index", StringComparison.OrdinalIgnoreCase) &&
            !item.PagePath.StartsWith("/Administration", StringComparison.OrdinalIgnoreCase))
        .ToArray();
    var administrationItems = shell.NavigationItems
        .Where(item => item.PagePath.StartsWith("/Administration", StringComparison.OrdinalIgnoreCase))
        .ToArray();
    var activeItem = shell.NavigationItems.FirstOrDefault(item =>
        string.Equals(item.PagePath, "/Index", StringComparison.OrdinalIgnoreCase)
            ? string.Equals(currentPath, "/", StringComparison.OrdinalIgnoreCase) || string.Equals(currentPath, "/Index", StringComparison.OrdinalIgnoreCase)
            : currentPath.StartsWith(item.PagePath, StringComparison.OrdinalIgnoreCase));
    var brandInitials = "KF";
    var currentUserInitials = shell.CurrentUser is null ? null : BuildInitials(shell.CurrentUser.DisplayName);
    var navigationDrawerId = "shellSidebar";
    var showShellSidebar = operationalItems.Length + administrationItems.Length > 1;
}
<!DOCTYPE html>
<html lang="@currentCulture" dir="@currentDirection">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BG</title>
    
    @* Institutional Typography: Cairo (Arabic) & Inter (English) *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

    @if (currentDirection == "rtl")
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.0/dist/css/bootstrap.rtl.min.css" crossorigin="anonymous" />
    }
    else
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/workspace-shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/bg-components.css" asp-append-version="true" />
</head>
<body class="theme-@currentTheme" hx-boost="true">
    @{
        var suppressSupportRail = ViewData["HideSupportRail"] as bool? == true;
        var suppressDetailDrawer = ViewData["HideDetailDrawer"] as bool? == true;
        var suppressDossier = ViewData["HideDossier"] as bool? == true;
        var hasSupportRail = IsSectionDefined("SupportRail") && !suppressSupportRail;
        var hasDetailDrawer = IsSectionDefined("DetailDrawer") && !suppressDetailDrawer;
        var hasDossier = IsSectionDefined("Dossier") && !suppressDossier;
        if (suppressSupportRail && IsSectionDefined("SupportRail"))
        {
            IgnoreSection("SupportRail");
        }

        if (suppressDetailDrawer && IsSectionDefined("DetailDrawer"))
        {
            IgnoreSection("DetailDrawer");
        }

        if (suppressDossier && IsSectionDefined("Dossier"))
        {
            IgnoreSection("Dossier");
        }
        var pageTitleOverride = ViewData["Title"]?.ToString();
        var stageTitle = !string.IsNullOrWhiteSpace(pageTitleOverride) 
                        ? pageTitleOverride 
                        : (activeItem is not null ? T[activeItem.ResourceKey].Value : "BG");
        string? stageSummary = null;
    }
    <div class="shell-app @(showShellSidebar ? null : "shell-app-no-sidebar")">
        @if (showShellSidebar)
        {
            <aside id="@navigationDrawerId"
                   class="shell-sidebar bg-shell-sidebar offcanvas offcanvas-start"
                   tabindex="-1"
                   aria-labelledby="shellSidebarLabel">
                <div class="offcanvas-header d-lg-none px-4 pt-4 pb-0">
                    <div>
                        <div id="shellSidebarLabel" class="fw-bold text-white">KFSHRC</div>
                        <div class="x-small text-white opacity-50">@T["AppBrandSubtitle"]</div>
                    </div>
                    <button type="button"
                            class="btn btn-sm btn-outline-light rounded-circle border-white border-opacity-25"
                            data-bs-dismiss="offcanvas"
                            aria-label="@T["Shared_CloseAction"]">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="offcanvas-body shell-sidebar-body">
                    <div class="shell-sidebar-frame">
                        <div class="shell-brand-block p-4 border-bottom border-white border-opacity-10 mb-3">
                            <a class="shell-brand d-flex align-items-center gap-2 text-decoration-none" asp-area="" asp-page="/Index">
                                <span class="d-inline-flex align-items-center justify-content-center rounded-circle fw-bold text-white"
                                      style="width: 32px; height: 32px; background: linear-gradient(135deg, #006847 0%, #F0B52B 100%);"
                                      aria-hidden="true">
                                    @brandInitials
                                </span>
                                <div class="d-flex flex-column">
                                    <span class="fw-bold text-white small">KFSHRC</span>
                                    <span class="x-small text-white opacity-50">@T["AppBrandSubtitle"]</span>
                                </div>
                            </a>
                        </div>

                        @if (operationalItems.Length > 0)
                        {
                            <section class="shell-sidebar-section px-3">
                                <nav class="nav flex-column gap-1" aria-label="@T["WorkspaceShell_WorkspacesLabel"]">
                                    @foreach (var item in operationalItems)
                                    {
                                        var isActive = currentPath.StartsWith(item.PagePath, StringComparison.OrdinalIgnoreCase);
                                        <a class="nav-link rounded-4 px-3 py-2 d-flex align-items-center gap-2 @(isActive ? "active" : "text-dark opacity-75")" href="@item.PagePath">
                                            <i class="bi @GetSidebarIcon(item.PagePath)"></i>
                                            <span class="small fw-bold">@T[item.ResourceKey]</span>
                                        </a>
                                    }
                                </nav>
                            </section>
                        }

                        @if (administrationItems.Length > 0)
                        {
                            <section class="shell-sidebar-section px-3 mt-4">
                                <div class="px-3 mb-2 d-flex justify-content-between align-items-center">
                                    <span class="x-small fw-bold text-white opacity-25 text-uppercase letter-spacing-1">@T["WorkspaceShell_AdminLabel"]</span>
                                </div>
                                <nav class="nav flex-column gap-1" aria-label="@T["WorkspaceShell_AdminLabel"]">
                                    @foreach (var item in administrationItems)
                                    {
                                        var isActive = currentPath.StartsWith(item.PagePath, StringComparison.OrdinalIgnoreCase);
                                        <a class="nav-link rounded-4 px-3 py-2 d-flex align-items-center gap-2 @(isActive ? "active" : "text-dark opacity-75")" href="@item.PagePath">
                                            <i class="bi @GetSidebarIcon(item.PagePath)"></i>
                                            <span class="small fw-bold">@T[item.ResourceKey]</span>
                                        </a>
                                    }
                                </nav>
                            </section>
                        }
                    </div>
                </div>
            </aside>
        }

        <div class="shell-stage bg-shell-content d-flex flex-column p-0">
            <header class="shell-stage-header bg-shell-topbar d-flex justify-content-between align-items-center px-4 py-3 sticky-top shadow-sm">
                <div class="shell-stage-header-main d-flex align-items-center gap-3">
                    @if (showShellSidebar)
                    {
                        <button type="button"
                                class="btn btn-light d-lg-none rounded-circle p-2"
                                data-bs-toggle="offcanvas"
                                data-bs-target="#@navigationDrawerId"
                                aria-controls="@navigationDrawerId"
                                aria-label="@T["WorkspaceShell_OpenNavigationAction"]">
                            <i class="bi bi-list"></i>
                        </button>
                    }
                    <div>
                        <nav aria-label="breadcrumb" class="mb-1">
                            <ol class="breadcrumb x-small mb-0 opacity-75">
                                @if (string.Equals(currentPath, "/", StringComparison.OrdinalIgnoreCase) || string.Equals(currentPath, "/Index", StringComparison.OrdinalIgnoreCase))
                                {
                                    <li class="breadcrumb-item active text-white" aria-current="page">@T["Navigation_Home"]</li>
                                }
                                else
                                {
                                    <li class="breadcrumb-item"><a href="/" class="text-white text-decoration-none">@T["Navigation_Home"]</a></li>
                                    @if (activeItem != null && !string.Equals(activeItem.PagePath, "/Index", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <li class="breadcrumb-item active text-white" aria-current="page">@T[activeItem.ResourceKey]</li>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(pageTitleOverride) && !string.Equals(pageTitleOverride, T["Navigation_Home"].Value, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <li class="breadcrumb-item active text-white" aria-current="page">@pageTitleOverride</li>
                                    }
                                }
                            </ol>
                        </nav>
                        <h5 class="fw-bold m-0 text-white">@stageTitle</h5>
                        @if (!string.IsNullOrWhiteSpace(stageSummary))
                        {
                            <div class="x-small text-white opacity-75">@stageSummary</div>
                        }
                    </div>
                </div>

                <div class="shell-stage-header-actions">
                    <div class="header-icon-group hx-boost-false">
                        @* Search Input (Image 1, 5) *@
                        <div class="shell-header-search d-none d-md-flex align-items-center px-3 rounded-pill">
                            <i class="bi bi-search text-white opacity-50 me-2"></i>
                            <input type="text" 
                                   class="bg-transparent border-0 text-white placeholder-white-50 small w-100" 
                                   placeholder="@T["Shared_SearchAction"]..." 
                                   aria-label="@T["Shared_SearchAction"]" />
                        </div>

                        @* Notifications Tray *@
                        <partial name="_NotificationTray" />

                        @* Language Switcher *@
                        <div class="shell-language-switch d-flex rounded-pill p-1">
                            @foreach (var culture in UiConfiguration.SupportedCultures)
                            {
                                var isActive = culture.Culture == currentCulture;
                                <a class="btn btn-sm rounded-pill px-3 @(isActive ? "bg-brand-green text-white shadow-sm" : "text-white opacity-50")"
                                   href="@Url.Action("SetCulture", "UiPreferences", new { culture = culture.Culture, returnUrl })">
                                    @T[$"Culture_{culture.Culture}"]
                                </a>
                            }
                        </div>
                    </div>

                        @* User Profile Dropdown *@
                        @if (shell.CurrentUser is not null)
                        {
                            <div class="dropdown hx-boost-false ms-2">
                                <button class="btn d-flex align-items-center gap-2 p-1 rounded-pill border border-white border-opacity-10 text-decoration-none dropdown-toggle hide-caret" 
                                        type="button" 
                                        id="userDropdown" 
                                        data-bs-toggle="dropdown" 
                                        aria-expanded="false">
                                    <div class="text-end d-none d-md-block text-white ms-2">
                                        <div class="small fw-bold lh-1">@(shell.CurrentUser.DisplayName == "System Admin" ? T["Shared_Role_SystemAdmin"] : shell.CurrentUser.DisplayName)</div>
                                        <div class="x-small opacity-50">@shell.CurrentUser.Username</div>
                                    </div>
                                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-white bg-opacity-20 fw-bold text-white shadow-sm"
                                          style="width: 32px; height: 32px; font-size: 0.75rem;"
                                          aria-label="@shell.CurrentUser.DisplayName">
                                        @currentUserInitials
                                    </span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 mt-2 py-2" aria-labelledby="userDropdown">
                                    <li class="d-md-none">
                                        <div class="px-3 py-2 border-bottom mb-1">
                                            <div class="small fw-bold">@(shell.CurrentUser.DisplayName == "System Admin" ? T["Shared_Role_SystemAdmin"] : shell.CurrentUser.DisplayName)</div>
                                            <div class="x-small text-muted">@shell.CurrentUser.Username</div>
                                        </div>
                                    </li>
                                    <li>
                                        <a asp-page="/Account/Profile" class="dropdown-item d-flex align-items-center gap-2 py-2">
                                            <i class="bi bi-person-circle text-primary"></i>
                                            @T["NavProfile"]
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider opacity-50"></li>
                                    <li>
                                        <form method="post" asp-page="/SignIn" asp-page-handler="SignOut">
                                            <button type="submit" class="dropdown-item text-danger d-flex align-items-center gap-2 py-2">
                                                <i class="bi bi-box-arrow-right"></i>
                                                @T["Shared_SignOut"]
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                    </div>
            </header>

            <main role="main" class="shell-stage-main flex-grow-1 p-4">
                @if (!string.IsNullOrWhiteSpace(shellMessageKey) && (ViewData["HideShellMessage"] as bool? != true))
                {
                    <div class="alert alert-info border-0 rounded-4 shadow-sm mb-4">
                        <i class="bi bi-info-circle-fill me-2"></i>@T[shellMessageKey]
                    </div>
                }

                <div class="workspace-shell @(hasSupportRail ? "has-support-rail" : null) @(hasDetailDrawer ? "has-detail-drawer" : null)">
                    <div class="workspace-main">
                        @RenderBody()
                    </div>

                    @if (hasSupportRail)
                    {
                        <aside class="workspace-support-rail">
                            @await RenderSectionAsync("SupportRail", required: false)
                        </aside>
                    }

                    @if (hasDetailDrawer)
                    {
                        <aside class="workspace-detail-drawer">
                            @await RenderSectionAsync("DetailDrawer", required: false)
                        </aside>
                    }
                </div>

                @if (hasDossier)
                {
                    <section class="workspace-dossier mt-4">
                        @await RenderSectionAsync("Dossier", required: false)
                    </section>
                }
            </main>

            <footer class="shell-stage-footer p-4 border-top bg-white mt-auto">
                <div class="d-flex justify-content-between align-items-center x-small text-muted">
                    <span>@T["FooterBaseline"]</span>
                    <div class="d-flex gap-3">
                        <a href="#" class="text-decoration-none text-muted">@T["Footer_HelpCenter"]</a>
                        <a href="/Privacy" class="text-decoration-none text-muted">@T["Privacy_PageTitle"]</a>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @* HTMX for partial workflow updates *@
    <script src="~/lib/htmx/htmx.min.js"></script>

    @* SignalR for real-time notifications *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
