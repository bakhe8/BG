@model BG.Web.UI.InlineNoticeModel
@{
    var classes = string.IsNullOrWhiteSpace(Model.ToneClass)
        ? "notice-banner"
        : $"notice-banner {Model.ToneClass}";
}
<div class="bg-card-premium p-4 mb-5 border-0 shadow-md position-relative overflow-hidden @Model.ToneClass">
    <div class="d-flex align-items-center gap-3">
        <div class="bg-white bg-opacity-25 rounded-circle p-2 d-flex align-items-center justify-content-center text-white" style="width: 40px; height: 40px;">
            <i class="bi bi-info-circle-fill fs-5"></i>
        </div>
        <div>
            <h6 class="fw-bold text-white m-0">@Model.Title</h6>
            <p class="small text-white opacity-90 m-0 mt-1">@Model.Summary</p>
        </div>
    </div>
</div>
