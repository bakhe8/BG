@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.UI.SurfaceUnifiedLink

<a href="@Url.Page(Model.PagePath, Model.RouteValues)" class="bg_unified_stageitem @(Model.IsActive ? "active" : "")">
    <div class="d-flex justify-content-between align-items-center mb-1">
        <span class="bg_unified_stageitemid">@Model.Subtitle</span>
        <span class="xx-small text-muted opacity-75">@Model.MetaPrimary</span>
    </div>
    
    <div class="bg_unified_stageitemtitle">@Model.Title</div>
    
    <div class="bg_unified_stageitemmeta">
        <div class="d-flex align-items-center gap-2">
            <span class="fw-bold" style="color: var(--kfshrc-green); opacity: 0.9;">@Model.Status</span>
            <span class="opacity-25">|</span>
            <span>@Model.Summary</span>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.MetaSecondary))
        {
            <div class="xx-small text-muted opacity-75 mt-1 border-top pt-1 mt-auto">
                <i class="bi bi-hash me-1"></i>@Model.MetaSecondary
            </div>
        }
    </div>
</a>
