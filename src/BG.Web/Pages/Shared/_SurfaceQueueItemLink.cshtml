@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.UI.SurfaceQueueItemLinkModel

<a class="request-queue-link @(Model.IsActive ? "active shadow-sm" : null)"
   aria-current="@(Model.IsActive ? "true" : "false")"
   asp-page="@Model.PagePath"
   asp-all-route-data="Model.RouteValues">
    
    @* Column 1: Reference *@
    <div class="bg-grid-col">
        <span class="bg-grid-value">@Model.Title</span>
    </div>

    @* Column 2: Entity *@
    <div class="bg-grid-col">
        <span class="bg-grid-value text-truncate">@Model.Subtitle</span>
    </div>

    @* Column 3: Type *@
    <div class="bg-grid-col">
        <span class="bg-grid-value">@Model.Summary</span>
    </div>

    @* Column 4: Value *@
    <div class="bg-grid-col">
        <span class="bg-grid-value text-brand-green">@Model.MetaPrimary</span>
    </div>

    @* Column 5: Date *@
    <div class="bg-grid-col">
        <span class="bg-grid-value">@Model.MetaSecondary</span>
    </div>

    @* Column 6: Status & Action *@
    <div class="bg-grid-col text-center">
        <bg-badge class="bg-badge-@(Model.Status.Contains("Pending") || Model.Status.Contains("انتظار") ? "pending" : "returned")">
            @Model.Status
        </bg-badge>
    </div>
</a>
