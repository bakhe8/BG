@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.UI.SurfaceQueueItemLinkModel

<a class="request-queue-link @(Model.IsActive ? "active" : null)"
   aria-current="@(Model.IsActive ? "true" : "false")"
   asp-page="@Model.PagePath"
   asp-all-route-data="Model.RouteValues">
    
    @* Column 1: Reference *@
    <div class="bg-grid-col">
        <strong class="bg-grid-value text-dark d-block">@Model.Title</strong>
    </div>

    @* Column 2: Entity *@
    <div class="bg-grid-col overflow-hidden">
        <span class="bg-grid-value text-dark opacity-75 text-truncate d-block">@Model.Subtitle</span>
    </div>

    @* Column 3: Type *@
    <div class="bg-grid-col">
        <span class="bg-grid-value x-small text-muted text-uppercase fw-bold">@Model.Summary</span>
    </div>

    @* Column 4: Value (Optional Meta) *@
    <div class="bg-grid-col">
        <span class="bg-grid-value fw-bold text-brand-green">@Model.MetaPrimary</span>
    </div>

    @* Column 5: Date *@
    <div class="bg-grid-col">
        <span class="bg-grid-value small text-muted">@Model.MetaSecondary</span>
    </div>

    @* Column 6: Status & Action Indicator *@
    <div class="bg-grid-col text-center">
        @{
            var badgeClass = "bg-badge-pending";
            if (Model.Status.Contains("Approved") || Model.Status.Contains("Success")) badgeClass = "bg-badge-success";
            if (Model.Status.Contains("Returned") || Model.Status.Contains("Rejected")) badgeClass = "bg-badge-returned";
            if (Model.Status.Contains("Draft")) badgeClass = "bg-badge-draft";
        }
        <bg-badge class="@badgeClass">
            @Model.Status
        </bg-badge>
    </div>
</a>
