@using System.Globalization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Requests.WorkspaceModel

<div class="bg-card-premium h-100 d-flex flex-column">
    @if (Model.ActiveRequest is null)
    {
        <div class="h-100 d-flex flex-column align-items-center justify-content-center text-center py-5">
            <div class="bg-brand-gold-soft rounded-circle p-4 mb-4">
                <i class="bi bi-file-earmark-text fs-1 text-brand-gold"></i>
            </div>
            <h2 class="fw-bold text-dark">@T["RequestsWorkspace_Empty"]</h2>
            <bg-button variant="primary" class="mt-4">@T["RequestsWorkspace_CreateAction"]</bg-button>
        </div>
    }
    else
    {
        var request = Model.ActiveRequest;
        var stageTitle = Model.ResolveStageTitle(request);
        var requestedChange = Model.ResolveRequestedChange(request);
        var currentActionTitle = request.CanSubmitForApproval && !request.CanWithdraw
            ? T["RequestsWorkspace_SubmitAction"].Value
            : request.CanWithdraw && !request.CanSubmitForApproval
                ? T["RequestsWorkspace_WithdrawAction"].Value
                : T["SurfaceAction_CurrentActionLabel"].Value;

        <div class="d-flex justify-content-between align-items-start mb-5 pb-4 border-bottom">
            <div>
                <section-caption>@T["RequestsWorkspace_TrackingSummaryHeading"]</section-caption>
                <h1 class="fw-bold text-dark m-0">@request.GuaranteeNumber</h1>
                <p class="text-secondary mt-1">@T[Model.ResolveStateSummaryResourceKey(request.StatusResourceKey)]</p>
            </div>
            <bg-badge variant="success" size="lg">@T[request.StatusResourceKey]</bg-badge>
        </div>

        <div class="request-active-facts">
            <section class="surface-stat">
                <span class="section-caption">@T["RequestsWorkspace_CurrentStageLabel"]</span>
                <strong>@stageTitle</strong>
            </section>
            <section class="surface-stat">
                <span class="section-caption">@T["RequestsWorkspace_RequestedChangeTitle"]</span>
                <strong>@requestedChange</strong>
            </section>
            <section class="surface-stat">
                <span class="section-caption">@T["CreatedAtField"]</span>
                <strong>@request.CreatedAtUtc.ToLocalTime().ToString("d", CultureInfo.CurrentCulture)</strong>
            </section>
            <section class="surface-stat">
                <span class="section-caption">@T["RequestsWorkspace_CorrespondenceLabel"]</span>
                <strong>@request.CorrespondenceCount</strong>
            </section>
        </div>

        <div class="surface-action-stack">
            @if (!Model.HasOwnerAction(request))
            {
                var noActionReasonResourceKey = Model.ResolveNoOwnerActionReasonResourceKey(request);
                if (!string.IsNullOrWhiteSpace(noActionReasonResourceKey))
                {
                    <div class="surface-action-zone is-blocked">
                        <div class="surface-action-header">
                            <span class="surface-action-kicker">@T["SurfaceAction_BlockedLabel"]</span>
                            <h3 class="surface-action-title">@T["RequestsWorkspace_NoAvailableOwnerActionTitle"]</h3>
                        </div>
                        <p class="surface-action-copy">@T[noActionReasonResourceKey]</p>
                    </div>
                }
            }

            @if (request.CanSubmitForApproval || request.CanWithdraw)
            {
                <div class="surface-action-zone is-primary">
                    <div class="surface-action-header">
                        <span class="surface-action-kicker">@T["SurfaceAction_CurrentActionLabel"]</span>
                        <h3 class="surface-action-title">@currentActionTitle</h3>
                    </div>

                    <div class="action-row">
                        @if (request.CanSubmitForApproval)
                        {
                            <form method="post" asp-page-handler="Submit">
                                <input type="hidden" name="requestId" value="@request.Id" />
                                <input type="hidden" name="request" value="@request.Id" />
                                <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor!.Id" />
                                <input type="hidden" name="page" value="@Model.Snapshot.OwnedRequestsPage.PageNumber" />
                                <bg-button type="submit" variant="primary">@T["RequestsWorkspace_SubmitAction"]</bg-button>
                            </form>
                        }

                        @if (request.CanWithdraw)
                        {
                            <form method="post" asp-page-handler="Withdraw">
                                <input type="hidden" name="requestId" value="@request.Id" />
                                <input type="hidden" name="request" value="@request.Id" />
                                <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor!.Id" />
                                <input type="hidden" name="page" value="@Model.Snapshot.OwnedRequestsPage.PageNumber" />
                                <bg-button type="submit" variant="light" class="text-danger border-danger border-opacity-25">@T["RequestsWorkspace_WithdrawAction"]</bg-button>
                            </form>
                        }
                    </div>
                </div>
            }

            <details class="details-panel">
                <summary>
                    <span>@T["RequestsWorkspace_TrackingSummaryTitle"]</span>
                    <span class="section-caption">@T["RequestsWorkspace_TrackingSummaryHeading"]</span>
                </summary>
                <div class="details-panel-body">
                    <section class="request-active-section">
                        <span class="section-caption">@T["RequestsWorkspace_TrackingSummaryTitle"]</span>
                        <p class="compact-copy">@T[Model.ResolveNextActionResourceKey(request)]</p>
                        <div class="pill-list">
                            <span class="pill">@T[request.RequestTypeResourceKey]</span>
                            <span class="pill">@T[request.GuaranteeCategoryResourceKey]</span>
                            @if (request.PrimaryDocumentForm is not null)
                            {
                                <span class="pill">@T[request.PrimaryDocumentForm.TitleResourceKey]</span>
                                <span class="pill">@T[request.PrimaryDocumentForm.BankResourceKey]</span>
                            }
                        </div>
                    </section>
                    <section class="request-active-section">
                        <span class="section-caption">@T["RequestsWorkspace_LastDecisionLabel"]</span>
                        <p class="compact-copy italic">@(string.IsNullOrWhiteSpace(request.Notes) ? T["RequestsWorkspace_NoNotes"].Value : request.Notes)</p>
                        @if (!string.IsNullOrWhiteSpace(request.LastDecisionResourceKey))
                        {
                            <div class="x-small fw-bold">
                                @T[request.LastDecisionResourceKey]
                                @if (!string.IsNullOrWhiteSpace(request.LastDecisionNote))
                                {
                                    <span class="text-secondary fw-normal"> - @request.LastDecisionNote</span>
                                }
                            </div>
                        }
                    </section>
                </div>
            </details>

            @if (request.CanRevise)
            {
                <details class="details-panel">
                    <summary>
                        <span>@T["RequestsWorkspace_EditRequestTitle"]</span>
                        <span class="section-caption">@T["RequestsWorkspace_EditRequestSummary"]</span>
                    </summary>
                    <div class="details-panel-body">
                        <form method="post" asp-page-handler="Update" class="row g-4">
                            <input type="hidden" name="requestId" value="@request.Id" />
                            <input type="hidden" name="request" value="@request.Id" />
                            <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor!.Id" />
                            <input type="hidden" name="page" value="@Model.Snapshot.OwnedRequestsPage.PageNumber" />

                            @if (request.RequiresRequestedAmount)
                            {
                                <div class="col-md-6">
                                    <label class="form-label fw-bold x-small" for="update-amount-@request.Id">@T["RequestsWorkspace_RequestedAmountField"]</label>
                                    <input id="update-amount-@request.Id" name="requestedAmount" class="form-control" inputmode="decimal" value="@request.RequestedAmount" />
                                </div>
                            }

                            @if (request.RequiresRequestedExpiryDate)
                            {
                                <div class="col-md-6">
                                    <label class="form-label fw-bold x-small" for="update-expiry-@request.Id">@T["RequestsWorkspace_RequestedExpiryDateField"]</label>
                                    <input id="update-expiry-@request.Id" name="requestedExpiryDate" class="form-control" type="date" value="@request.RequestedExpiryDate" />
                                </div>
                            }

                            <div class="col-12">
                                <label class="form-label fw-bold x-small" for="update-notes-@request.Id">@T["RequestsWorkspace_NotesField"]</label>
                                <textarea id="update-notes-@request.Id" name="notes" class="form-control" rows="3">@request.Notes</textarea>
                            </div>

                            <div class="col-12 d-flex justify-content-end mt-4">
                                <bg-button type="submit" variant="secondary">@T["RequestsWorkspace_UpdateAction"]</bg-button>
                            </div>
                        </form>

                        @if (request.CanCancel)
                        {
                            <form method="post" asp-page-handler="Cancel">
                                <input type="hidden" name="requestId" value="@request.Id" />
                                <input type="hidden" name="request" value="@request.Id" />
                                <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor!.Id" />
                                <input type="hidden" name="page" value="@Model.Snapshot.OwnedRequestsPage.PageNumber" />
                                <bg-button type="submit" variant="light" class="text-secondary bg-transparent border-0">@T["RequestsWorkspace_CancelAction"]</bg-button>
                            </form>
                        }
                    </div>
                </details>
            }
        </div>
    }
</div>
