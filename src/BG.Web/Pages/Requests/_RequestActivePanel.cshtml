@using System.Globalization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Requests.WorkspaceModel

<div class="h-100 d-flex flex-column request-active-panel bg-white border rounded-4 overflow-hidden shadow-sm">
    @if (Model.ActiveRequest is null)
    {
        <div class="h-100 d-flex flex-column align-items-center justify-content-center text-center py-5">
            <i class="bi bi-file-earmark-plus fs-1 text-muted opacity-25 d-block mb-3"></i>
            <h2 class="fw-bold text-dark">@T["RequestsWorkspace_StartNowTitle"]</h2>
            <p class="text-secondary mt-2 mb-0">@T["RequestsWorkspace_StartNowBody"]</p>
        </div>
    }
    else
    {
        var request = Model.ActiveRequest;
        var stageTitle = Model.ResolveStageTitle(request);
        var requestedChange = Model.ResolveRequestedChange(request);
        var hasAction = Model.HasOwnerAction(request);

        @* 1. Institutional Header *@
        <div class="p-4 border-bottom bg-white">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="d-flex align-items-center gap-3">
                    <span class="badge bg-light text-dark border px-3 py-2 rounded-pill fw-bold">@request.GuaranteeNumber</span>
                    <bg-badge class="bg-badge-success">@T[request.StatusResourceKey]</bg-badge>
                </div>
                <button type="button" class="btn-close" aria-label="Close"></button>
            </div>
            <h3 class="fw-bold text-dark mb-2">@T[request.RequestTypeResourceKey]</h3>
            <div class="d-flex align-items-center gap-2 text-muted x-small text-uppercase fw-bold">
                <i class="bi bi-calendar3"></i>
                <span>@T["CreatedAtField"]: @request.CreatedAtUtc.ToLocalTime().ToString("d")</span>
                <span class="mx-1">·</span>
                <i class="bi bi-layers"></i>
                <span>@stageTitle</span>
            </div>
        </div>

        @* 2. Scrollable Work Surface *@
        <div class="flex-grow-1 overflow-auto p-4">
            
            @* Stats Grid *@
            <div class="row g-4 mb-5">
                <div class="col-6">
                    <div class="bg-light p-4 rounded-4 border-0">
                        <div class="bg-grid-label">@T["RequestsWorkspace_RequestedChangeTitle"]</div>
                        <div class="bg-grid-value fs-5 mt-1">@requestedChange</div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="bg-light p-4 rounded-4 border-0">
                        <div class="bg-grid-label">@T["RequestsWorkspace_CurrentStageLabel"]</div>
                        <div class="bg-grid-value fs-5 mt-1">@stageTitle</div>
                    </div>
                </div>
            </div>

            @if (request.CanRevise)
            {
                <form method="post" id="request-form" class="stack-form d-flex flex-column gap-4">
                    <input type="hidden" name="requestId" value="@request.Id" />
                    <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor!.Id" />
                    
                    <div class="row g-3">
                        @if (request.RequiresRequestedAmount)
                        {
                            <div class="col-md-6">
                                <label class="form-label x-small text-muted text-uppercase fw-bold" for="update-amount">@T["RequestsWorkspace_RequestedAmountField"]</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0 x-small fw-bold">SAR</span>
                                    <input id="update-amount" name="requestedAmount" class="form-control rounded-3" inputmode="decimal" value="@request.RequestedAmount" />
                                </div>
                            </div>
                        }

                        @if (request.RequiresRequestedExpiryDate)
                        {
                            <div class="col-md-6">
                                <label class="form-label x-small text-muted text-uppercase fw-bold" for="update-expiry">@T["RequestsWorkspace_RequestedExpiryDateField"]</label>
                                <input id="update-expiry" name="requestedExpiryDate" class="form-control rounded-3" type="date" value="@request.RequestedExpiryDate" />
                            </div>
                        }
                    </div>

                    <div>
                        <label class="form-label x-small text-muted text-uppercase fw-bold" for="update-notes">@T["RequestsWorkspace_NotesField"]</label>
                        <textarea id="update-notes" name="notes" class="form-control rounded-3" rows="3">@request.Notes</textarea>
                    </div>
                </form>
            }
            else if (!hasAction)
            {
                <div class="alert alert-light border-0 shadow-none small italic mb-4">
                    <i class="bi bi-info-circle me-2"></i>@T[Model.ResolveNextActionResourceKey(request)]
                </div>
            }

            @* Details Accordion (Image 4 style details) *@
            <div class="mt-5 pt-4 border-top">
                <h6 class="x-small text-muted text-uppercase fw-bold mb-4">@T["RequestsWorkspace_RequestDetailsTitle"]</h6>
                
                <div class="d-flex flex-column gap-3">
                    <div class="p-3 bg-light rounded-3">
                        <span class="x-small text-muted d-block mb-1">@T["RequestsWorkspace_LastDecisionLabel"]</span>
                        <div class="small fw-bold text-dark">@(string.IsNullOrWhiteSpace(request.LastDecisionNote) ? T["RequestsWorkspace_NoNotes"].Value : request.LastDecisionNote)</div>
                    </div>
                    
                    @if (request.PrimaryDocumentForm is not null)
                    {
                        <div class="p-3 bg-light rounded-3">
                            <span class="x-small text-muted d-block mb-1">@T["RequestsWorkspace_TrackingSummaryTitle"]</span>
                            <div class="d-flex flex-wrap gap-2 mt-1">
                                <span class="badge bg-white text-dark border x-small">@T[request.PrimaryDocumentForm.TitleResourceKey]</span>
                                <span class="badge bg-white text-dark border x-small">@T[request.PrimaryDocumentForm.BankResourceKey]</span>
                                <span class="badge bg-white text-dark border x-small">@T[request.GuaranteeCategoryResourceKey]</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (hasAction || request.CanRevise || request.CanWithdraw)
        {
            @* 3. Institutional Action Bar *@
            <div class="bg-sticky-action-bar">
                <div class="d-flex gap-2 w-100">
                    @if (request.CanSubmitForApproval)
                    {
                        <form method="post" asp-page-handler="Submit" class="flex-grow-1">
                            <input type="hidden" name="requestId" value="@request.Id" />
                            <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor!.Id" />
                            <button type="submit" class="bg-btn bg-btn-primary w-100 py-3 shadow-none">
                                <i class="bi bi-send-check-fill me-2 rotate-rtl"></i>@T["RequestsWorkspace_SubmitAction"]
                            </button>
                        </form>
                    }
                    
                    @if (request.CanRevise)
                    {
                        <button type="submit" form="request-form" formaction="/Requests/Workspace?handler=Update" class="bg-btn bg-btn-primary py-3 shadow-none flex-grow-1">
                            <i class="bi bi-save2 me-2"></i>@T["RequestsWorkspace_UpdateAction"]
                        </button>
                    }

                    @if (request.CanWithdraw)
                    {
                        <form method="post" asp-page-handler="Withdraw" class="flex-grow-0">
                            <input type="hidden" name="requestId" value="@request.Id" />
                            <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor!.Id" />
                            <button type="submit" class="bg-btn bg-btn-secondary px-4 py-3 border text-danger">
                                <i class="bi bi-trash3 me-1"></i>
                            </button>
                        </form>
                    }
                </div>
            </div>
        }
    }
</div>
