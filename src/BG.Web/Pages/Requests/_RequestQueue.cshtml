@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Requests.WorkspaceModel

<div class="bg-card shadow-sm p-0 overflow-hidden h-100 d-flex flex-column">
    <div class="p-3 bg-brand-gold-soft border-bottom d-flex justify-content-between align-items-center">
        <div>
            <span class="fw-bold text-dark d-block">@T["RequestsWorkspace_MyRequestsTitle"]</span>
        </div>
        <bg-badge variant="secondary">@Model.Snapshot.OwnedRequests.Count</bg-badge>
    </div>

    <div class="flex-grow-1 overflow-auto p-3">
        @if (Model.Snapshot.OwnedRequests.Count == 0)
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted opacity-25 d-block mb-3"></i>
                <p class="x-small text-secondary">@T["RequestsWorkspace_Empty"]</p>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-2">
                @foreach (var request in Model.Snapshot.OwnedRequests)
                {
                    var isActive = Model.ActiveRequest?.Id == request.Id;
                    var stageTitle = Model.ResolveStageTitle(request);
                    var requestedChange = Model.ResolveRequestedChange(request);
                    
                    <a href="@Url.Page("/Requests/Workspace", Model.BuildSelectionRoute(request.Id))" 
                       aria-current="@(isActive ? "true" : "false")"
                       class="request-queue-link @(isActive ? "active" : null)">
                        <div class="request-queue-copy">
                            <div class="entity-subtitle">@T[request.RequestTypeResourceKey]</div>
                            <strong>@request.GuaranteeNumber</strong>
                            <p class="compact-copy">@requestedChange</p>
                        </div>
                        <div class="request-queue-meta">
                            @if (isActive)
                            {
                                <span class="surface-action-kicker">@T["SurfaceQueue_CurrentItemLabel"]</span>
                            }
                            <span class="status-badge is-active">@T[request.StatusResourceKey]</span>
                            <span class="section-caption">@stageTitle</span>
                            <span class="compact-copy">@request.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd")</span>
                        </div>
                    </a>
                }
            </div>
        }
    </div>

    @if (Model.Snapshot.OwnedRequestsPage.TotalPageCount > 1)
    {
        var pageInfo = Model.Snapshot.OwnedRequestsPage;
        <div class="p-3 bg-light border-top d-flex justify-content-between">
            <a class="btn btn-sm btn-white border rounded-pill px-3 @(pageInfo.HasPreviousPage ? "" : "disabled")" 
               href="@Url.Page("/Requests/Workspace", Model.BuildPageRoute(pageInfo.PreviousPageNumber))">
                <i class="bi bi-chevron-left me-1"></i>@T["Pagination_Previous"]
            </a>
            <a class="btn btn-sm btn-white border rounded-pill px-3 @(pageInfo.HasNextPage ? "" : "disabled")" 
               href="@Url.Page("/Requests/Workspace", Model.BuildPageRoute(pageInfo.NextPageNumber))">
                @T["Pagination_Next"]<i class="bi bi-chevron-right ms-1"></i>
            </a>
        </div>
    }
</div>
