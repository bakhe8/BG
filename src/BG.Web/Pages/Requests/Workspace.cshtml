@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Requests.WorkspaceModel
@{
    ViewData["Title"] = T["RequestsWorkspace_PageTitle"];
    var headerModel = new SurfaceHeaderModel(
        T["NavRequests"].Value,
        T["RequestsWorkspace_Heading"].Value,
        null);
    var noEligibleActorModel = new SurfaceMessageCardModel(
        T["RequestsWorkspace_NoEligibleActor"].Value,
        T["RequestsWorkspace_NoEligibleActorBody"].Value);
    var showTrackingQueue = Model.Snapshot.OwnedRequests.Count > 1;
}

<section class="section-shell requests-surface">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice-banner is-success">@Model.StatusMessage</div>
    }

    <partial name="/Pages/Shared/_SurfaceHeader.cshtml" model="headerModel" />

    @if (!Model.Snapshot.HasEligibleActor || Model.Snapshot.ActiveActor is null)
    {
        <partial name="/Pages/Shared/_SurfaceMessageCard.cshtml" model="noEligibleActorModel" />
    }
    else
    {
        @if (Model.ActiveRequest is null && Model.Snapshot.OwnedRequests.Count == 0)
        {
            <div class="requests-create-column">
                <partial name="_RequestSupportRail" model="Model" />
            </div>
        }
        else
        {
            <div class="request-workspace-grid">
                <div class="requests-create-column">
                    <partial name="_RequestSupportRail" model="Model" />
                </div>

                <div class="requests-tracking-column">
                    @if (Model.ActiveRequest is not null)
                    {
                        <partial name="_RequestActivePanel" model="Model" />
                        @if (showTrackingQueue)
                        {
                            <partial name="_RequestQueue" model="Model" />
                        }
                    }
                    else
                    {
                        <partial name="_RequestQueue" model="Model" />
                    }
                </div>
            </div>
        }
    }
</section>
