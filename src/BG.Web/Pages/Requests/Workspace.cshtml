@page
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@model BG.Web.Pages.Requests.WorkspaceModel
@{
    ViewData["Title"] = T["RequestsWorkspace_PageTitle"];

    string ResolveStageTitle(BG.Application.Models.Requests.RequestSummaryDto request)
    {
        if (!string.IsNullOrWhiteSpace(request.CurrentStageTitle))
        {
            return request.CurrentStageTitle;
        }

        return string.IsNullOrWhiteSpace(request.CurrentStageTitleResourceKey)
            ? "-"
            : T[request.CurrentStageTitleResourceKey].Value;
    }

    string ResolveStateSummaryResourceKey(string statusResourceKey)
    {
        return statusResourceKey switch
        {
            "RequestStatus_Draft" => "RequestsWorkspace_State_Draft",
            "RequestStatus_InApproval" => "RequestsWorkspace_State_InApproval",
            "RequestStatus_Returned" => "RequestsWorkspace_State_Returned",
            "RequestStatus_ApprovedForDispatch" => "RequestsWorkspace_State_ApprovedForDispatch",
            "RequestStatus_SubmittedToBank" => "RequestsWorkspace_State_AwaitingBankResponse",
            "RequestStatus_AwaitingBankResponse" => "RequestsWorkspace_State_AwaitingBankResponse",
            "RequestStatus_Completed" => "RequestsWorkspace_State_Completed",
            "RequestStatus_Rejected" => "RequestsWorkspace_State_Rejected",
            "RequestStatus_Cancelled" => "RequestsWorkspace_State_Cancelled",
            _ => "RequestsWorkspace_State_Draft"
        };
    }

    string ResolveNextActionResourceKey(BG.Application.Models.Requests.RequestSummaryDto request)
    {
        if (request.CanSubmitForApproval)
        {
            return "RequestsWorkspace_NextActionSubmit";
        }

        if (request.CanRevise)
        {
            return "RequestsWorkspace_NextActionRevise";
        }

        if (request.CanWithdraw)
        {
            return "RequestsWorkspace_NextActionWithdraw";
        }

        return request.StatusResourceKey switch
        {
            "RequestStatus_ApprovedForDispatch" or "RequestStatus_SubmittedToBank" or "RequestStatus_AwaitingBankResponse"
                => "RequestsWorkspace_NextActionAwaitExternal",
            "RequestStatus_Completed" => "RequestsWorkspace_NextActionCompleted",
            "RequestStatus_Rejected" or "RequestStatus_Cancelled" => "RequestsWorkspace_NextActionClosed",
            _ => "RequestsWorkspace_NextActionMonitor"
        };
    }

    string ResolveRequestedChange(BG.Application.Models.Requests.RequestSummaryDto request)
    {
        var parts = new System.Collections.Generic.List<string>();

        if (!string.IsNullOrWhiteSpace(request.RequestedAmount))
        {
            parts.Add(request.RequestedAmount);
        }

        if (!string.IsNullOrWhiteSpace(request.RequestedExpiryDate))
        {
            parts.Add(request.RequestedExpiryDate);
        }

        return parts.Count == 0 ? "-" : string.Join(" · ", parts);
    }
}

<section class="section-shell">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice-banner is-success">@Model.StatusMessage</div>
    }

    @if (Model.Snapshot.HasEligibleActor && !string.IsNullOrWhiteSpace(Model.Snapshot.ContextNoticeResourceKey))
    {
        <div class="notice-banner is-success">@T[Model.Snapshot.ContextNoticeResourceKey]</div>
    }

    <div class="section-header requests-section-header">
        <div>
            <span class="eyebrow">@T["NavRequests"]</span>
            <h1>@T["RequestsWorkspace_Heading"]</h1>
            <p class="compact-copy">@T["RequestsWorkspace_ActionSummary"]</p>
        </div>
    </div>

    @if (!Model.Snapshot.HasEligibleActor || Model.Snapshot.ActiveActor is null)
    {
        <article class="info-card">
            <h2>@T["RequestsWorkspace_NoEligibleActor"]</h2>
            <p class="compact-copy">@T["RequestsWorkspace_NoEligibleActorBody"]</p>
        </article>
    }
    else
    {
        var draftCount = Model.Snapshot.OwnedRequests.Count(request => request.StatusResourceKey == "RequestStatus_Draft");
        var returnedCount = Model.Snapshot.OwnedRequests.Count(request => request.StatusResourceKey == "RequestStatus_Returned");
        var inApprovalCount = Model.Snapshot.OwnedRequests.Count(request => request.StatusResourceKey == "RequestStatus_InApproval");
        var activeFollowUpCount = Model.Snapshot.OwnedRequests.Count(
            request => request.StatusResourceKey is "RequestStatus_ApprovedForDispatch" or "RequestStatus_SubmittedToBank" or "RequestStatus_AwaitingBankResponse");

        <div class="requests-workbench-grid">
            <div class="requests-tracking-column">
                <article class="info-card requests-owner-shell">
                    <div class="requests-focus-banner-copy">
                        <span class="eyebrow">@T["RequestsWorkspace_PrimaryFlow"]</span>
                        <h2>@Model.Snapshot.ActiveActor.DisplayName</h2>
                        <p class="compact-copy">@T["RequestsWorkspace_IsolationSummary"]</p>
                    </div>
                    <div class="dashboard-mini-metrics">
                        <div class="dashboard-mini-metric">
                            <span>@T["RequestsWorkspace_MetricActor"]</span>
                            <strong>@Model.Snapshot.ActiveActor.Username</strong>
                        </div>
                        <div class="dashboard-mini-metric">
                            <span>@T["RequestsWorkspace_MetricOwned"]</span>
                            <strong>@Model.Snapshot.OwnedRequestsPage.TotalItemCount</strong>
                        </div>
                        <div class="dashboard-mini-metric">
                            <span>@T["RequestStatus_Draft"]</span>
                            <strong>@draftCount</strong>
                        </div>
                        <div class="dashboard-mini-metric">
                            <span>@T["RequestStatus_Returned"]</span>
                            <strong>@returnedCount</strong>
                        </div>
                        <div class="dashboard-mini-metric">
                            <span>@T["RequestStatus_InApproval"]</span>
                            <strong>@inApprovalCount</strong>
                        </div>
                        <div class="dashboard-mini-metric">
                            <span>@T["RequestsWorkspace_TrackingSummaryTitle"]</span>
                            <strong>@activeFollowUpCount</strong>
                        </div>
                    </div>
                </article>

                <article class="info-card full-span">
                    <div class="card-header">
                        <div>
                            <h2>@T["RequestsWorkspace_MyRequestsTitle"]</h2>
                            <p class="compact-copy">@T["RequestsWorkspace_MyRequestsSummary"]</p>
                        </div>
                        <div class="pill-list">
                            <span class="pill">@T["Pagination_PageSummary", Model.Snapshot.OwnedRequestsPage.PageNumber, Model.Snapshot.OwnedRequestsPage.TotalPageCount, Model.Snapshot.OwnedRequestsPage.TotalItemCount]</span>
                        </div>
                    </div>

                    @if (Model.Snapshot.OwnedRequests.Count == 0)
                    {
                        <p class="compact-copy">@T["RequestsWorkspace_Empty"]</p>
                    }
                    else
                    {
                        <div class="stack-list">
                            @foreach (var request in Model.Snapshot.OwnedRequests)
                            {
                                var stageTitle = ResolveStageTitle(request);
                                var requestedChange = ResolveRequestedChange(request);

                                <article class="entity-card request-item-card">
                                    <div class="entity-header">
                                        <div>
                                            <h3>@request.GuaranteeNumber</h3>
                                            <div class="entity-subtitle">@T[request.RequestTypeResourceKey] · @T[request.GuaranteeCategoryResourceKey]</div>
                                        </div>
                                        <span class="status-badge is-active">@T[request.StatusResourceKey]</span>
                                    </div>

                                    <div class="surface-stat-grid request-summary-facts">
                                        <section class="surface-stat">
                                            <span class="section-caption">@T["RequestsWorkspace_CurrentStageLabel"]</span>
                                            <strong>@stageTitle</strong>
                                        </section>
                                        <section class="surface-stat">
                                            <span class="section-caption">@T["RequestsWorkspace_RequestedChangeTitle"]</span>
                                            <strong>@requestedChange</strong>
                                        </section>
                                        <section class="surface-stat">
                                            <span class="section-caption">@T["CreatedAtField"]</span>
                                            <strong>@request.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</strong>
                                        </section>
                                        <section class="surface-stat">
                                            <span class="section-caption">@T["RequestsWorkspace_CorrespondenceLabel"]</span>
                                            <strong>@request.CorrespondenceCount</strong>
                                        </section>
                                    </div>

                                    <div class="request-surface-grid">
                                        <section class="request-surface-panel">
                                            <div class="pill-section">
                                                <span class="section-caption">@T["RequestsWorkspace_TrackingSummaryHeading"]</span>
                                                <p class="compact-copy">@T[ResolveStateSummaryResourceKey(request.StatusResourceKey)]</p>
                                                <p class="compact-copy">@T[ResolveNextActionResourceKey(request)]</p>
                                            </div>

                                            <div class="pill-section">
                                                <span class="section-caption">@T["RequestsWorkspace_LastDecisionLabel"]</span>
                                                <p class="compact-copy">@(string.IsNullOrWhiteSpace(request.Notes) ? T["RequestsWorkspace_NoNotes"].Value : request.Notes)</p>
                                                @if (!string.IsNullOrWhiteSpace(request.LastDecisionResourceKey))
                                                {
                                                    <p class="compact-copy">@T[request.LastDecisionResourceKey]</p>
                                                    @if (!string.IsNullOrWhiteSpace(request.LastDecisionNote))
                                                    {
                                                        <p class="compact-copy">@request.LastDecisionNote</p>
                                                    }
                                                }
                                            </div>
                                        </section>

                                        <section class="request-surface-panel">
                                            <div class="pill-section">
                                                <span class="section-caption">@T["RequestsWorkspace_TrackingSummaryTitle"]</span>
                                                <div class="pill-list">
                                                    <span class="pill">@T["RequestsWorkspace_TrackingSummaryStage", stageTitle]</span>
                                                    <span class="pill">@T["RequestsWorkspace_TrackingSummaryCorrespondence", request.CorrespondenceCount]</span>
                                                    <span class="pill">@T["RequestsWorkspace_TrackingSummaryLedger", request.LedgerEntries.Count]</span>
                                                    @if (request.PrimaryDocumentForm is not null)
                                                    {
                                                        <span class="pill">@T[request.PrimaryDocumentForm.TitleResourceKey]</span>
                                                        <span class="pill">@T[request.PrimaryDocumentForm.BankResourceKey]</span>
                                                    }
                                                </div>
                                            </div>

                                            <div class="action-row">
                                                @if (request.CanSubmitForApproval)
                                                {
                                                    <form method="post" asp-page-handler="Submit">
                                                        <input type="hidden" name="requestId" value="@request.Id" />
                                                        <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor.Id" />
                                                        <input type="hidden" name="page" value="@Model.Snapshot.OwnedRequestsPage.PageNumber" />
                                                        <button type="submit" class="btn btn-primary action-button">
                                                            @T["RequestsWorkspace_SubmitAction"]
                                                        </button>
                                                    </form>
                                                }

                                                @if (request.CanWithdraw)
                                                {
                                                    <form method="post" asp-page-handler="Withdraw">
                                                        <input type="hidden" name="requestId" value="@request.Id" />
                                                        <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor.Id" />
                                                        <input type="hidden" name="page" value="@Model.Snapshot.OwnedRequestsPage.PageNumber" />
                                                        <button type="submit" class="btn btn-outline-danger action-button">
                                                            @T["RequestsWorkspace_WithdrawAction"]
                                                        </button>
                                                    </form>
                                                }
                                            </div>

                                            @if (request.CanRevise)
                                            {
                                                <details class="details-panel">
                                                    <summary>
                                                        <span>@T["RequestsWorkspace_EditRequestTitle"]</span>
                                                        <span class="section-caption">@T["RequestsWorkspace_EditRequestSummary"]</span>
                                                    </summary>
                                                    <div class="details-panel-body">
                                                        <form method="post" asp-page-handler="Update" class="stack-form">
                                                            <input type="hidden" name="requestId" value="@request.Id" />
                                                            <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor.Id" />
                                                            <input type="hidden" name="page" value="@Model.Snapshot.OwnedRequestsPage.PageNumber" />

                                                            @if (request.RequiresRequestedAmount)
                                                            {
                                                                <label class="form-label" for="update-amount-@request.Id">@T["RequestsWorkspace_RequestedAmountField"]</label>
                                                                <input id="update-amount-@request.Id"
                                                                       name="requestedAmount"
                                                                       class="form-control"
                                                                       inputmode="decimal"
                                                                       value="@request.RequestedAmount" />
                                                            }

                                                            @if (request.RequiresRequestedExpiryDate)
                                                            {
                                                                <label class="form-label" for="update-expiry-@request.Id">@T["RequestsWorkspace_RequestedExpiryDateField"]</label>
                                                                <input id="update-expiry-@request.Id"
                                                                       name="requestedExpiryDate"
                                                                       class="form-control"
                                                                       type="date"
                                                                       value="@request.RequestedExpiryDate" />
                                                            }

                                                            <label class="form-label" for="update-notes-@request.Id">@T["RequestsWorkspace_NotesField"]</label>
                                                            <textarea id="update-notes-@request.Id"
                                                                      name="notes"
                                                                      class="form-control"
                                                                      rows="3">@request.Notes</textarea>

                                                            <div class="action-row">
                                                                <button type="submit" class="btn btn-outline-primary action-button">
                                                                    @T["RequestsWorkspace_UpdateAction"]
                                                                </button>
                                                            </div>
                                                        </form>

                                                        @if (request.CanCancel)
                                                        {
                                                            <form method="post" asp-page-handler="Cancel" class="action-row">
                                                                <input type="hidden" name="requestId" value="@request.Id" />
                                                                <input type="hidden" name="actorId" value="@Model.Snapshot.ActiveActor.Id" />
                                                                <input type="hidden" name="page" value="@Model.Snapshot.OwnedRequestsPage.PageNumber" />
                                                                <button type="submit" class="btn btn-outline-danger action-button">
                                                                    @T["RequestsWorkspace_CancelAction"]
                                                                </button>
                                                            </form>
                                                        }
                                                    </div>
                                                </details>
                                            }
                                        </section>
                                    </div>

                                    <details class="details-panel">
                                        <summary>
                                            <span>@T["RequestsWorkspace_LedgerTitle"]</span>
                                            <span class="section-caption">@T["RequestsWorkspace_LedgerSummary"]</span>
                                        </summary>
                                        <div class="details-panel-body">
                                            @if (request.LedgerEntries.Count == 0)
                                            {
                                                <p class="compact-copy">@T["RequestsWorkspace_LedgerEmpty"]</p>
                                            }
                                            else
                                            {
                                                <div class="workflow-stage-list">
                                                    @foreach (var ledgerEntry in request.LedgerEntries)
                                                    {
                                                        <section class="workflow-stage">
                                                            <span class="pipeline-index">#</span>
                                                            <div>
                                                                <strong>@ledgerEntry.OccurredAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</strong>
                                                                <p class="compact-copy">
                                                                    @T["RequestsWorkspace_LedgerActorLabel"]:
                                                                    @(string.IsNullOrWhiteSpace(ledgerEntry.ActorDisplayName)
                                                                        ? T["RequestsWorkspace_LedgerSystemActor"].Value
                                                                        : ledgerEntry.ActorDisplayName)
                                                                </p>
                                                                <p class="compact-copy">@ledgerEntry.Summary</p>
                                                                @if (!string.IsNullOrWhiteSpace(ledgerEntry.ApprovalStageLabel) ||
                                                                     !string.IsNullOrWhiteSpace(ledgerEntry.ApprovalPolicyResourceKey) ||
                                                                     !string.IsNullOrWhiteSpace(ledgerEntry.ApprovalExecutionModeResourceKey) ||
                                                                     !string.IsNullOrWhiteSpace(ledgerEntry.ApprovalResponsibleSignerDisplayName) ||
                                                                     !string.IsNullOrWhiteSpace(ledgerEntry.DispatchStageResourceKey) ||
                                                                     !string.IsNullOrWhiteSpace(ledgerEntry.DispatchMethodResourceKey) ||
                                                                     !string.IsNullOrWhiteSpace(ledgerEntry.DispatchPolicyResourceKey) ||
                                                                     !string.IsNullOrWhiteSpace(ledgerEntry.OperationsScenarioTitleResourceKey) ||
                                                                     !string.IsNullOrWhiteSpace(ledgerEntry.OperationsLaneResourceKey) ||
                                                                     !string.IsNullOrWhiteSpace(ledgerEntry.OperationsMatchConfidenceResourceKey) ||
                                                                     ledgerEntry.OperationsMatchScore.HasValue ||
                                                                     !string.IsNullOrWhiteSpace(ledgerEntry.OperationsPolicyResourceKey))
                                                                {
                                                                    <div class="pill-list">
                                                                        @if (!string.IsNullOrWhiteSpace(ledgerEntry.ApprovalStageLabel))
                                                                        {
                                                                            <span class="pill">@T["RequestsWorkspace_LedgerStageLabel"]: @ledgerEntry.ApprovalStageLabel</span>
                                                                        }
                                                                        @if (!string.IsNullOrWhiteSpace(ledgerEntry.ApprovalPolicyResourceKey))
                                                                        {
                                                                            <span class="pill">@T["RequestsWorkspace_LedgerPolicyLabel"]: @T[ledgerEntry.ApprovalPolicyResourceKey]</span>
                                                                        }
                                                                        @if (!string.IsNullOrWhiteSpace(ledgerEntry.ApprovalExecutionModeResourceKey))
                                                                        {
                                                                            <span class="pill">@T["RequestsWorkspace_LedgerExecutionModeLabel"]: @T[ledgerEntry.ApprovalExecutionModeResourceKey]</span>
                                                                        }
                                                                        @if (!string.IsNullOrWhiteSpace(ledgerEntry.ApprovalResponsibleSignerDisplayName))
                                                                        {
                                                                            <span class="pill">@T["RequestsWorkspace_LedgerResponsibleSignerLabel"]: @ledgerEntry.ApprovalResponsibleSignerDisplayName</span>
                                                                        }
                                                                        @if (!string.IsNullOrWhiteSpace(ledgerEntry.DispatchStageResourceKey))
                                                                        {
                                                                            <span class="pill">@T["RequestsWorkspace_LedgerDispatchStageLabel"]: @T[ledgerEntry.DispatchStageResourceKey]</span>
                                                                        }
                                                                        @if (!string.IsNullOrWhiteSpace(ledgerEntry.DispatchMethodResourceKey))
                                                                        {
                                                                            <span class="pill">@T["RequestsWorkspace_LedgerDispatchMethodLabel"]: @T[ledgerEntry.DispatchMethodResourceKey]</span>
                                                                        }
                                                                        @if (!string.IsNullOrWhiteSpace(ledgerEntry.DispatchPolicyResourceKey))
                                                                        {
                                                                            <span class="pill">@T["RequestsWorkspace_LedgerDispatchPolicyLabel"]: @T[ledgerEntry.DispatchPolicyResourceKey]</span>
                                                                        }
                                                                        @if (!string.IsNullOrWhiteSpace(ledgerEntry.OperationsScenarioTitleResourceKey))
                                                                        {
                                                                            <span class="pill">@T["RequestsWorkspace_LedgerOperationsScenarioLabel"]: @T[ledgerEntry.OperationsScenarioTitleResourceKey]</span>
                                                                        }
                                                                        @if (!string.IsNullOrWhiteSpace(ledgerEntry.OperationsLaneResourceKey))
                                                                        {
                                                                            <span class="pill">@T["RequestsWorkspace_LedgerOperationsLaneLabel"]: @T[ledgerEntry.OperationsLaneResourceKey]</span>
                                                                        }
                                                                        @if (!string.IsNullOrWhiteSpace(ledgerEntry.OperationsMatchConfidenceResourceKey))
                                                                        {
                                                                            <span class="pill">
                                                                                @T["RequestsWorkspace_LedgerOperationsConfidenceLabel"]:
                                                                                @T[ledgerEntry.OperationsMatchConfidenceResourceKey]
                                                                                @if (ledgerEntry.OperationsMatchScore.HasValue)
                                                                                {
                                                                                    @($" ({ledgerEntry.OperationsMatchScore.Value})")
                                                                                }
                                                                            </span>
                                                                        }
                                                                        @if (!string.IsNullOrWhiteSpace(ledgerEntry.OperationsPolicyResourceKey))
                                                                        {
                                                                            <span class="pill">@T["RequestsWorkspace_LedgerOperationsPolicyLabel"]: @T[ledgerEntry.OperationsPolicyResourceKey]</span>
                                                                        }
                                                                    </div>
                                                                }
                                                            </div>
                                                        </section>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </details>
                                </article>
                            }
                        </div>
                    }

                    @if (Model.Snapshot.OwnedRequestsPage.TotalPageCount > 1)
                    {
                        var pageInfo = Model.Snapshot.OwnedRequestsPage;

                        <div class="action-row">
                            @if (pageInfo.HasPreviousPage)
                            {
                                <a class="btn btn-outline-primary action-button"
                                   asp-page="/Requests/Workspace"
                                   asp-all-route-data="Model.BuildPageRoute(pageInfo.PreviousPageNumber)">
                                    @T["Pagination_Previous"]
                                </a>
                            }

                            @if (pageInfo.HasNextPage)
                            {
                                <a class="btn btn-outline-primary action-button"
                                   asp-page="/Requests/Workspace"
                                   asp-all-route-data="Model.BuildPageRoute(pageInfo.NextPageNumber)">
                                    @T["Pagination_Next"]
                                </a>
                            }
                        </div>
                    }
                </article>
            </div>

            <aside class="requests-create-column">
                <article class="info-card requests-create-card">
                    <div class="card-header">
                        <div>
                            <h2>@T["RequestsWorkspace_CreateTitle"]</h2>
                            <p class="compact-copy">@T["RequestsWorkspace_CreateSummary"]</p>
                        </div>
                    </div>

                    <form method="post" class="stack-form">
                        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                        <input asp-for="Input.RequestedByUserId" type="hidden" />
                        <input type="hidden" name="page" value="@Model.Snapshot.OwnedRequestsPage.PageNumber" />

                        <label class="form-label" asp-for="Input.GuaranteeNumber">@T["RequestsWorkspace_GuaranteeNumberField"]</label>
                        <input asp-for="Input.GuaranteeNumber" class="form-control" maxlength="64" />

                        <label class="form-label" asp-for="Input.RequestType">@T["RequestsWorkspace_RequestTypeField"]</label>
                        <select asp-for="Input.RequestType" class="form-control">
                            @foreach (var option in Model.RequestTypeOptions)
                            {
                                <option value="@option.Type">@T[option.ResourceKey]</option>
                            }
                        </select>

                        @if (Model.RequiresAmount)
                        {
                            <label class="form-label" asp-for="Input.RequestedAmount">@T["RequestsWorkspace_RequestedAmountField"]</label>
                            <input asp-for="Input.RequestedAmount" class="form-control" inputmode="decimal" />
                        }

                        @if (Model.RequiresExpiryDate)
                        {
                            <label class="form-label" asp-for="Input.RequestedExpiryDate">@T["RequestsWorkspace_RequestedExpiryDateField"]</label>
                            <input asp-for="Input.RequestedExpiryDate" class="form-control" type="date" />
                        }

                        <label class="form-label" asp-for="Input.Notes">@T["RequestsWorkspace_NotesField"]</label>
                        <textarea asp-for="Input.Notes" class="form-control" rows="4"></textarea>

                        <button type="submit" class="btn btn-primary action-button">@T["RequestsWorkspace_CreateAction"]</button>
                    </form>
                </article>

                <article class="info-card">
                    <div class="card-header">
                        <div>
                            <h2>@T["RequestsWorkspace_ActorContextTitle"]</h2>
                            <p class="compact-copy">@T["RequestsWorkspace_ActorContextSummary"]</p>
                        </div>
                    </div>

                    @if (Model.IsActorContextLocked)
                    {
                        <div class="pill-list">
                            <span class="pill">@T["WorkspaceShell_CurrentUserScopeNotice"]</span>
                            <span class="pill">@Model.Snapshot.ActiveActor.DisplayName (@Model.Snapshot.ActiveActor.Username)</span>
                        </div>
                    }
                    else
                    {
                        <form method="get" class="stack-form">
                            <input type="hidden" name="page" value="@Model.Snapshot.OwnedRequestsPage.PageNumber" />
                            <div>
                                <label class="form-label" for="actor">@T["RequestsWorkspace_ActorField"]</label>
                                <select id="actor" name="actor" class="form-control">
                                    @foreach (var actor in Model.Snapshot.AvailableActors)
                                    {
                                        <option value="@actor.Id" selected="@(actor.Id == Model.Snapshot.ActiveActor.Id ? "selected" : null)">@actor.DisplayName (@actor.Username)</option>
                                    }
                                </select>
                            </div>
                            <button type="submit" class="btn btn-outline-primary action-button">@T["RequestsWorkspace_LoadActorAction"]</button>
                        </form>
                    }
                </article>

                <details class="details-panel" open>
                    <summary>
                        <span>@T["RequestsWorkspace_CurrentWorkflowTitle"]</span>
                        <span class="section-caption">@T["RequestsWorkspace_WorkflowPreviewTitle"]</span>
                    </summary>
                    <div class="details-panel-body">
                        <div class="notice-banner is-info">
                            <strong>@T["RequestsWorkspace_WorkflowPreviewTitle"]</strong>
                            <p class="compact-copy">@T["RequestsWorkspace_WorkflowPreviewSummary"]</p>
                        </div>

                        @if (Model.SelectedWorkflowTemplate is null)
                        {
                            <p class="compact-copy">@T["RequestsWorkspace_NoWorkflowTemplate"]</p>
                        }
                        else
                        {
                            @if (!string.IsNullOrWhiteSpace(Model.SelectedWorkflowTemplate.GuaranteeCategoryResourceKey))
                            {
                                <div class="pill-list">
                                    <span class="pill">@T["RequestsWorkspace_WorkflowCategoryLabel"]</span>
                                    <span class="pill">@T[Model.SelectedWorkflowTemplate.GuaranteeCategoryResourceKey]</span>
                                </div>
                            }

                            <div class="workflow-stage-list">
                                @foreach (var stage in Model.SelectedWorkflowTemplate.Stages)
                                {
                                    var stageTitle = !string.IsNullOrWhiteSpace(stage.TitleText)
                                        ? stage.TitleText
                                        : T[stage.TitleResourceKey!].Value;
                                    var stageSummary = !string.IsNullOrWhiteSpace(stage.SummaryText)
                                        ? stage.SummaryText
                                        : string.IsNullOrWhiteSpace(stage.SummaryResourceKey)
                                            ? "-"
                                            : T[stage.SummaryResourceKey].Value;
                                    <section class="workflow-stage">
                                        <span class="pipeline-index">@stage.Level</span>
                                        <div>
                                            <strong>@stageTitle</strong>
                                            <p class="compact-copy">@stageSummary</p>
                                            @if (stage.RequiresLetterSignature)
                                            {
                                                <div class="workflow-signature-meta">
                                                    <span class="pill">@T[stage.CurrentSignatureModeResourceKey]</span>
                                                    <span class="pill">@T[stage.FinalPdfEffectResourceKey]</span>
                                                    @if (!string.IsNullOrWhiteSpace(stage.AssignedRoleName))
                                                    {
                                                        <span class="pill">@stage.AssignedRoleName</span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </section>
                                }
                            </div>
                        }
                    </div>
                </details>
            </aside>
        </div>
    }
</section>
