@page
@model BG.Web.Pages.SignInModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> T
@{
    ViewData["Title"] = T["SignIn_PageTitle"];
    ViewData["HideShellMessage"] = true;
    Layout = "_Layout";
}

<div class="signin-container d-flex align-items-center justify-content-center min-vh-100 bg-app">
    <div class="signin-card bg-white shadow-lg border rounded-4 overflow-hidden" style="max-width: 450px; width: 100%;">

        @* Institutional Header (Shell) *@
        <div class="signin-header p-4 text-center text-white" style="background-color: var(--kfshrc-green);">
            <div class="brand-badge mb-3 d-inline-flex align-items-center justify-content-center bg-white rounded-circle" style="width: 64px; height: 64px;">
                <span class="fw-bold fs-4" style="color: var(--kfshrc-green);">KF</span>
            </div>
            <h4 class="fw-bold m-0">@T["SignIn_Heading"]</h4>
            <div class="small opacity-75 mt-1">@T["SignIn_Eyebrow"]</div>
        </div>

        @* Content (Workspace) *@
        <div class="signin-body p-5">
            @if (!ModelState.IsValid)
            {
                <div class="alert alert-danger border-0 rounded-3 small mb-4">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <form method="post">
                <div class="mb-4">
                    <label asp-for="Username" class="form-label small fw-bold text-muted text-uppercase mb-2">@T["Shared_UsernameLabel"]</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 rounded-start-3"><i class="bi bi-person text-muted"></i></span>
                        <input asp-for="Username" class="form-control border-start-0 rounded-end-3 p-2 px-3" placeholder="user.name" />
                    </div>
                </div>

                <div class="mb-5">
                    <label asp-for="Password" class="form-label small fw-bold text-muted text-uppercase mb-2">@T["Shared_PasswordLabel"]</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 rounded-start-3"><i class="bi bi-lock text-muted"></i></span>
                        <input asp-for="Password" type="password" class="form-control border-start-0 rounded-end-3 p-2 px-3" />
                    </div>
                </div>

                <button type="submit" class="bg-btn bg-btn-primary w-100 py-3 shadow-sm">
                    <i class="bi bi-shield-lock me-2"></i>@T["SignIn_SubmitAction"]
                </button>
            </form>

            <div class="mt-5 pt-3 border-top text-center">
                <div class="x-small text-muted mb-2">@T["FooterBaseline"]</div>
            </div>
        </div>
    </div>
</div>

<style>
    .signin-container {
        background-image:
            radial-gradient(circle at 100% 0%, rgba(0, 104, 71, 0.03) 0%, transparent 25%),
            radial-gradient(circle at 0% 100%, rgba(0, 104, 71, 0.03) 0%, transparent 25%);
    }

    .signin-card {
        transition: all 0.3s ease;
    }

    .signin-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1) !important;
    }
</style>
